---
import { IconChevronDown, IconPlus, IconRefresh } from "@tabler/icons-svelte";
---

<div data-ps-wrap class="relative [view-transition-name:playlist-switcher]">
	<button
		id="ps-trigger"
		type="button"
		aria-haspopup="menu"
		aria-controls="ps-popover"
		aria-expanded="false"
		title="Switch playlist"
		class="flex w-full items-center gap-2.5 px-2.5 py-2.5 min-h-11 rounded-xl border border-line bg-surface text-sm font-medium text-fg transition-colors hover:bg-surface-2 focus-visible:bg-surface-2 focus-visible:border-accent
			justify-center lg:justify-between">
		<span class="flex items-center gap-2.5 min-w-0">
			<span
				id="ps-badge"
				class="hidden h-5 px-1.5 items-center justify-center rounded-md text-label font-semibold uppercase text-fg-2 ring-1 ring-line shrink-0">
			</span>
			<span
				id="ps-title"
				class="hidden lg:inline truncate tracking-tight text-fg-3">
				No playlist
			</span>
		</span>
		<IconChevronDown
			aria-hidden="true"
			class="hidden lg:block h-4 w-4 text-fg-3 shrink-0 transition-transform duration-200"
			id="ps-chevron"
		/>
	</button>

	<div
		id="ps-popover"
		role="menu"
		aria-labelledby="ps-trigger"
		hidden
		class="ps-popover
			max-h-[min(70dvh,32rem)]
			rounded-t-xl border border-line border-b-0 bg-surface text-fg
			overflow-hidden">
		<div
			id="ps-list"
			class="flex-1 min-h-0 overflow-auto custom-scroll py-2">
			<div class="px-3.5 py-3 text-fg-3 text-xs">Loading…</div>
		</div>

		<div class="flex items-stretch border-t border-line shrink-0">
			<button
				id="ps-refresh"
				type="button"
				class="hidden flex-1 items-center justify-center gap-1.5 px-2 py-3 text-sm font-medium text-fg-2 whitespace-nowrap
					hover:text-fg hover:bg-surface-2
					focus-visible:text-fg focus-visible:bg-surface-2
					min-h-11 transition-colors outline-none border-r border-line">
				<IconRefresh aria-hidden="true" class="h-4 w-4 shrink-0" />
				Refresh
			</button>
			<a
				href="/login"
				class="flex flex-1 items-center justify-center gap-1.5 px-2 py-3 text-sm font-medium text-fg whitespace-nowrap
					hover:bg-surface-2
					focus-visible:bg-surface-2
					min-h-11 transition-colors">
				<IconPlus aria-hidden="true" class="h-4 w-4 text-accent shrink-0" />
				Add playlist
			</a>
		</div>
	</div>
</div>

<style>
	#ps-popover[hidden] {
		display: none;
	}
	[data-ps-wrap][data-open="true"] #ps-popover {
		display: flex;
		flex-direction: column;
		position: absolute;
		bottom: 100%;
		left: 0;
		right: 0;
		z-index: 50;
	}
	#ps-trigger[aria-expanded="true"] #ps-chevron {
		transform: rotate(180deg);
	}
	#ps-trigger[aria-expanded="true"] {
		border-top-left-radius: 0;
		border-top-right-radius: 0;
		background-color: var(--color-surface-2);
	}
</style>

<script>
	import {
		getEntries,
		getActiveEntry,
		refreshActive,
	} from "@/scripts/lib/creds.js";
	import {
		renderPlaylistRow,
		PLAYLIST_LIST_EMPTY_COPY,
	} from "@/scripts/lib/playlist-rows.js";

	const wrap = /** @type {HTMLElement|null} */ (
		document.querySelector("[data-ps-wrap]")
	);
	const trigger = /** @type {HTMLButtonElement|null} */ (
		document.getElementById("ps-trigger")
	);
	const popover = /** @type {HTMLElement|null} */ (
		document.getElementById("ps-popover")
	);
	const chevron = document.getElementById("ps-chevron");
	const listEl = document.getElementById("ps-list");
	const titleEl = document.getElementById("ps-title");
	const badgeEl = document.getElementById("ps-badge");
	const refreshBtn = document.getElementById("ps-refresh");

	let isOpen = false;
	const SECTION_ID = "ps-popover-section";
	let sectionRegistered = false;

	function openPopover() {
		if (!wrap || !popover || !trigger || isOpen) return;
		isOpen = true;
		wrap.setAttribute("data-open", "true");
		trigger.setAttribute("aria-expanded", "true");
		popover.removeAttribute("hidden");
		renderList();
		const SN = window.SpatialNavigation;
		if (SN && !sectionRegistered) {
			try {
				SN.add({
					id: SECTION_ID,
					selector: "#ps-popover button, #ps-popover a",
					restrict: "self-only",
					enterTo: "default-element",
					defaultElement:
						"#ps-popover button[data-id], #ps-popover a",
				});
				sectionRegistered = true;
			} catch {}
		}
		requestAnimationFrame(() => {
			SN?.makeFocusable?.();
			const first = /** @type {HTMLElement|null} */ (
				popover.querySelector("button[data-id], a, button")
			);
			first?.focus?.();
		});
	}

	function closePopover() {
		if (!wrap || !popover || !trigger || !isOpen) return;
		isOpen = false;
		wrap.setAttribute("data-open", "false");
		trigger.setAttribute("aria-expanded", "false");
		popover.setAttribute("hidden", "");
		const SN = window.SpatialNavigation;
		if (SN && sectionRegistered) {
			try {
				SN.remove(SECTION_ID);
			} catch {}
			sectionRegistered = false;
		}
		trigger.focus?.();
	}

	function togglePopover() {
		if (isOpen) closePopover();
		else openPopover();
	}

	trigger?.addEventListener("click", (ev) => {
		ev.stopPropagation();
		if (!window.matchMedia("(min-width: 64rem)").matches) {
			window.location.href = "/settings";
			return;
		}
		togglePopover();
	});

	document.addEventListener("click", (ev) => {
		if (!isOpen) return;
		const target = /** @type {Node} */ (ev.target);
		if (wrap && !wrap.contains(target)) closePopover();
	});

	document.addEventListener("keydown", (ev) => {
		if (ev.key === "Escape" && isOpen) {
			ev.stopPropagation();
			closePopover();
		}
	});

	refreshBtn?.addEventListener("click", async () => {
		await refreshActive();
		closePopover();
	});

	async function renderHeader() {
		const active = await getActiveEntry();
		if (!titleEl || !badgeEl) return;
		if (!active) {
			titleEl.textContent = "No playlist";
			titleEl.classList.add("text-fg-3");
			titleEl.classList.remove("text-fg");
			badgeEl.textContent = "-";
			badgeEl.classList.remove("hidden");
			badgeEl.classList.add("inline-flex");
			refreshBtn?.classList.add("hidden");
			refreshBtn?.classList.remove("flex");
			return;
		}
		titleEl.textContent = active.title;
		titleEl.classList.remove("text-fg-3");
		titleEl.classList.add("text-fg");
		badgeEl.textContent = active.type === "xtream" ? "XT" : "M3U";
		badgeEl.classList.remove("hidden");
		badgeEl.classList.add("inline-flex");
		refreshBtn?.classList.remove("hidden");
		refreshBtn?.classList.add("flex");
	}

	async function renderList() {
		if (!listEl) return;
		const entries = await getEntries();
		if (!entries.length) {
			listEl.innerHTML = `<div class="px-3.5 py-4 text-fg-3 text-xs">${PLAYLIST_LIST_EMPTY_COPY}</div>`;
			return;
		}
		const active = await getActiveEntry();
		const frag = document.createDocumentFragment();
		for (const e of entries) {
			frag.appendChild(
				renderPlaylistRow({
					entry: e,
					isActive: active?._id === e._id,
					density: "compact",
					onAfterSelect: async () => {
						await renderHeader();
						await renderList();
						closePopover();
					},
					onAfterRemove: async () => {
						await renderHeader();
						await renderList();
					},
				})
			);
		}
		listEl.replaceChildren(frag);
	}

	document.addEventListener("xt:active-changed", () => {
		renderHeader();
		renderList();
	});
	document.addEventListener("xt:entries-updated", renderList);

	await renderHeader();
	await renderList();
</script>
