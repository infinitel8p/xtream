---
import { IconSearch } from "@tabler/icons-svelte"

interface Props {
	id: string
	label: string
	placeholder: string
	clearButtonId?: string
}

const { id, label, placeholder, clearButtonId } = Astro.props
---

<div class="flex items-center gap-2 flex-wrap">
	<label class="sr-only" for={id}>{label}</label>
	<div class="relative w-full">
		<IconSearch
			aria-hidden="true"
			stroke={1.75}
			class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 size-4 text-fg-3"
		/>
		<input
			id={id}
			type="search"
			placeholder={placeholder}
			class="w-full rounded-xl border border-line bg-bg pl-9 pr-3 py-2 min-h-11 text-base sm:text-sm text-fg placeholder:text-fg-3 outline-none ring-0 transition focus:border-accent focus:bg-surface-2 focus:ring-2 focus:ring-accent"
		/>
	</div>
	{
		clearButtonId && (
			<button
				id={clearButtonId}
				title="Clear"
				class="hidden shrink-0 rounded-lg border border-line px-2 py-2 min-h-11 text-xs text-fg-2 hover:bg-surface-2">
				Clear
			</button>
		)
	}
</div>
