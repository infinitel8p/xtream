---
import {
  IconHome,
  IconDeviceTv,
  IconMovie,
  IconStack2,
  IconCalendarTime,
  IconDownload,
  IconSettings,
  IconLayoutGrid,
  IconSearch,
  IconSparkles,
  IconStar,
  IconBookmark,
} from "@tabler/icons-svelte"
import PlaylistSwitcher from "@/components/PlaylistSwitcher.svelte"

const path = Astro.url.pathname.replace(/\/$/, "") || "/"

const items = [
  { href: "/",                key: "nav.home",          label: "Home",            Icon: IconHome,         match: (p) => p === "/" },
  { href: "/livetv",          key: "nav.livetv",        label: "Live TV",         Icon: IconDeviceTv,     match: (p) => p === "/livetv" || p.startsWith("/livetv/") },
  { href: "/movies",          key: "nav.movies",        label: "Movies",          Icon: IconMovie,        match: (p) => p === "/movies" || p.startsWith("/movies/") },
  { href: "/series",          key: "nav.series",        label: "Series",          Icon: IconStack2,       match: (p) => p === "/series" || p.startsWith("/series/") },
  { href: "/favorites",       key: "nav.favorites",     label: "Favorites",       Icon: IconStar,         match: (p) => p === "/favorites" || p.startsWith("/favorites/") },
  { href: "/watchlist",       key: "nav.watchlist",     label: "Watchlist",       Icon: IconBookmark,     match: (p) => p === "/watchlist" || p.startsWith("/watchlist/") },
  { href: "/recently-added",  key: "nav.recentlyAdded", label: "Recently added",  Icon: IconSparkles,     match: (p) => p === "/recently-added" || p.startsWith("/recently-added/") },
  { href: "/epg",             key: "nav.epg",           label: "EPG",             Icon: IconCalendarTime, match: (p) => p === "/epg" || p.startsWith("/epg/") },
  { href: "/downloads",       key: "nav.downloads",     label: "Downloads",       Icon: IconDownload,     match: (p) => p === "/downloads" || p.startsWith("/downloads/"), id: "nav-downloads" },
]

const tabItems = [
  items.find((i) => i.href === "/"),
  items.find((i) => i.href === "/livetv"),
  items.find((i) => i.href === "/movies"),
  items.find((i) => i.href === "/series"),
]

const moreItems = [
  { href: "/favorites",      key: "nav.favorites",     label: "Favorites",      Icon: IconStar,     match: (p) => p === "/favorites" || p.startsWith("/favorites/") },
  { href: "/watchlist",      key: "nav.watchlist",     label: "Watchlist",      Icon: IconBookmark, match: (p) => p === "/watchlist" || p.startsWith("/watchlist/") },
  { href: "/recently-added", key: "nav.recentlyAdded", label: "Recently added", Icon: IconSparkles, match: (p) => p === "/recently-added" || p.startsWith("/recently-added/") },
  { href: "/downloads",      key: "nav.downloads",     label: "Downloads",      Icon: IconDownload, match: (p) => p === "/downloads" || p.startsWith("/downloads/"), id: "mobile-more-downloads" },
  { href: "/settings",       key: "nav.settings",      label: "Settings",       Icon: IconSettings, match: (p) => p === "/settings"  || p.startsWith("/settings/") },
]

const moreActive = moreItems.some((i) => i.match(path))
const settingsActive = path === "/settings" || path.startsWith("/settings/")
---

<aside
  class="hidden md:flex landscape-phone:flex md:order-first landscape-phone:order-first
         shrink-0 flex-col gap-2 border-r border-line bg-bg
         w-16 lg:w-64
         p-2 lg:p-3
         pl-[max(0.5rem,env(safe-area-inset-left))]
         pb-[max(0.5rem,env(safe-area-inset-bottom))]
         md:sticky md:top-0 md:self-start md:h-dvh md:overflow-y-auto
         landscape-phone:sticky landscape-phone:top-0
         landscape-phone:h-dvh landscape-phone:overflow-y-auto
         custom-scroll
         landscape-phone:[scrollbar-width:none]
         landscape-phone:[&::-webkit-scrollbar]:hidden">

  <a
    href="/"
    aria-label="Extreme InfiniTV - Home"
    data-i18n-attr="aria-label:sidebar.brandHome"
    class="brand-mark group [view-transition-name:brand-mark]
           flex items-center gap-3 px-2 py-2
           justify-center lg:justify-start outline-none">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      class="brand-mark__svg shrink-0 size-11 text-accent">
      <path
        id="brand-mark-path"
        class="brand-mark__base"
        d="M18.1777 8C23.2737 8 23.2737 16 18.1777 16C13.0827 16 11.0447 8 5.43875 8C0.85375 8 0.85375 16 5.43875 16C11.0447 16 13.0828 8 18.1788 8H18.1777Z" />
      <g class="brand-mark__trail">
        <circle r="1.15" fill="currentColor" opacity="1">
          <animateMotion dur="6s" repeatCount="indefinite" begin="0s">
            <mpath href="#brand-mark-path" />
          </animateMotion>
        </circle>
        <circle r="0.95" fill="currentColor" opacity="0.75">
          <animateMotion dur="6s" repeatCount="indefinite" begin="0.08s">
            <mpath href="#brand-mark-path" />
          </animateMotion>
        </circle>
        <circle r="0.8" fill="currentColor" opacity="0.55">
          <animateMotion dur="6s" repeatCount="indefinite" begin="0.16s">
            <mpath href="#brand-mark-path" />
          </animateMotion>
        </circle>
        <circle r="0.65" fill="currentColor" opacity="0.4">
          <animateMotion dur="6s" repeatCount="indefinite" begin="0.24s">
            <mpath href="#brand-mark-path" />
          </animateMotion>
        </circle>
        <circle r="0.5" fill="currentColor" opacity="0.25">
          <animateMotion dur="6s" repeatCount="indefinite" begin="0.32s">
            <mpath href="#brand-mark-path" />
          </animateMotion>
        </circle>
        <circle r="0.35" fill="currentColor" opacity="0.14">
          <animateMotion dur="6s" repeatCount="indefinite" begin="0.4s">
            <mpath href="#brand-mark-path" />
          </animateMotion>
        </circle>
      </g>
    </svg>
    <span class="hidden lg:inline-flex items-baseline truncate text-[0.9375rem] tracking-[-0.02em]">
      <span class="font-semibold text-fg">Extreme&nbsp;Infini</span><span class="font-extrabold text-accent tracking-[0.04em] ml-[0.05em]">TV</span>
    </span>
  </a>

  {(() => {
    const searchActive = path === "/search" || path.startsWith("/search/")
    return (
      <a
        href="/search"
        aria-label="Search (Ctrl+K)"
        title="Search (Ctrl+K)"
        data-i18n-attr="aria-label:sidebar.searchWithShortcut;title:sidebar.searchWithShortcut"
        aria-current={searchActive ? "page" : undefined}
        class:list={[
          "mt-2 flex items-center gap-3 rounded-xl px-2.5 py-2.5 min-h-11",
          "justify-center lg:justify-start",
          "border border-line bg-surface",
          "transition-colors outline-none",
          searchActive
            ? "bg-surface-2 text-fg ring-1 ring-accent/40 border-transparent"
            : "text-fg-2 hover:bg-surface-2 hover:text-fg focus-visible:bg-surface-2 focus-visible:text-fg focus-visible:border-accent",
        ]}>
        <IconSearch aria-hidden="true" stroke={searchActive ? 2 : 1.75} class:list={["size-5 shrink-0", searchActive ? "text-accent" : "text-fg-3"]} />
        <span data-i18n="nav.search" class="hidden lg:inline truncate text-sm flex-1 text-left">Search</span>
        <kbd class="hidden lg:inline-block text-2xs text-fg-3 border border-line rounded px-1.5 py-0.5 font-sans">
          Ctrl K
        </kbd>
      </a>
    )
  })()}

  <nav class="flex flex-col gap-1 flex-1 mt-1" aria-label="Main" data-i18n-attr="aria-label:sidebar.mainLabel">
    {items.map(({ href, key, label, Icon, match, id }) => {
      const active = match(path)
      const isDownloads = id === "nav-downloads"
      return (
        <a
          href={href}
          id={id}
          aria-label={label}
          aria-current={active ? "page" : undefined}
          title={label}
          data-i18n-attr={`aria-label:${key};title:${key}`}
          class:list={[
            "flex items-center gap-3 rounded-xl px-2.5 py-2.5 min-h-11",
            "justify-center lg:justify-start",
            "transition-[color,background-color,transform] duration-150 outline-none",
            "hover:bg-surface-2 focus-visible:bg-surface-2 active:scale-[0.98]",
            active
              ? "bg-surface-2 text-fg ring-1 ring-accent/40"
              : "text-fg-2 hover:text-fg focus-visible:text-fg",
          ]}>
          <span class:list={["relative inline-flex shrink-0"]}>
            <Icon
              aria-hidden="true"
              stroke={active ? 2 : 1.75}
              class:list={[
                "size-5 shrink-0",
                active ? "text-accent" : "text-fg-3",
              ]}
            />
            {isDownloads && (
              <span
                id="sidebar-downloads-badge"
                aria-hidden="true"
                hidden
                class="absolute -top-1.5 -right-2 min-w-4.5 h-4.5 px-1
                       inline-flex items-center justify-center rounded-full
                       bg-accent text-bg text-[10px] font-semibold leading-none
                       tabular-nums ring-2 ring-bg">0</span>
            )}
          </span>
          <span data-i18n={key} class="hidden lg:inline truncate text-sm font-medium">
            {label}
          </span>
          {isDownloads && (
            <span
              id="sidebar-downloads-sub"
              class="hidden lg:inline ml-auto truncate text-2xs text-fg-3 tabular-nums empty:hidden"></span>
          )}
        </a>
      )
    })}
  </nav>

  <a
    href="/settings"
    data-account-expiration="banner"
    hidden
    aria-label="Account expiration warning"
    title="Account expiration"
    data-i18n-attr="aria-label:sidebar.expirationAria;title:sidebar.expirationTitle"
    class="hidden lg:flex items-center gap-2 rounded-xl px-3 py-2 text-xs font-medium tabular-nums
           border border-warn/30 bg-warn/10 text-warn
           data-[state=critical]:border-bad/40 data-[state=critical]:bg-bad/10 data-[state=critical]:text-bad
           data-[state=expired]:border-bad/40 data-[state=expired]:bg-bad/10 data-[state=expired]:text-bad
           hover:border-current focus-visible:border-current
           outline-none transition-colors">
  </a>

  <div
    data-account-expiration
    class="hidden lg:block px-2.5 text-2xs text-fg-3 tabular-nums truncate empty:hidden">
  </div>

  <div class="flex flex-col gap-1 pt-2 border-t border-line">
    <div class="hidden lg:block">
      <PlaylistSwitcher client:load />
    </div>
    <a
      href="/settings"
      aria-label="Settings"
      aria-current={settingsActive ? "page" : undefined}
      title="Settings"
      data-i18n-attr="aria-label:nav.settings;title:nav.settings"
      class:list={[
        "flex items-center gap-3 rounded-xl px-2.5 py-2.5 min-h-11",
        "justify-center lg:justify-start",
        "transition-colors outline-none",
        "hover:bg-surface-2 focus-visible:bg-surface-2",
        settingsActive
          ? "bg-surface-2 text-fg ring-1 ring-accent/40"
          : "text-fg-2 hover:text-fg focus-visible:text-fg",
      ]}>
      <IconSettings
        aria-hidden="true"
        stroke={settingsActive ? 2 : 1.75}
        class:list={[
          "size-5 shrink-0",
          settingsActive ? "text-accent" : "text-fg-3",
        ]}
      />
      <span data-i18n="nav.settings" class="hidden lg:inline truncate text-sm font-medium">
        Settings
      </span>
    </a>
  </div>
</aside>

<!-- Portrait phone bottom nav. -->
<nav
  data-mobile-nav
  class="md:hidden landscape-phone:hidden order-last
         relative z-30
         shrink-0 flex flex-col bg-bg/95 backdrop-blur
         pb-[max(0.25rem,env(safe-area-inset-bottom))]
         pl-[max(0,env(safe-area-inset-left))]
         pr-[max(0,env(safe-area-inset-right))]"
  aria-label="Main"
  data-i18n-attr="aria-label:sidebar.mainLabel">

  <!-- More panel: floats above the tab row, doesn't push page content. -->
  <div
    id="mobile-more-panel"
    data-open="false"
    aria-hidden="true"
    class="absolute bottom-full inset-x-0 z-10
           border-t border-line bg-bg/95 backdrop-blur-md
           shadow-[0_-12px_32px_-16px_rgba(0,0,0,0.45)]
           translate-y-1 opacity-0 pointer-events-none
           transition-[transform,opacity] duration-200 ease-out
           data-[open=true]:translate-y-0 data-[open=true]:opacity-100 data-[open=true]:pointer-events-auto">
    <ul class="flex flex-col gap-1 px-3 py-3">
      <li>
        <a
          href="/search"
          aria-label="Search"
          data-i18n-attr="aria-label:common.search"
          class="group w-full flex items-center gap-3 rounded-xl px-2.5 py-2 min-h-12
                 transition-[color,background-color,transform] duration-150 outline-none
                 hover:bg-surface-2 focus-visible:bg-surface-2 active:scale-[0.99]
                 text-fg-2 hover:text-fg focus-visible:text-fg">
          <span class="relative flex size-10 shrink-0 items-center justify-center rounded-lg ring-1 transition-colors bg-surface ring-line group-hover:ring-line-soft">
            <IconSearch aria-hidden="true" stroke={1.75} class="size-5 shrink-0 text-fg-2" />
          </span>
          <span data-i18n="nav.search" class="truncate text-sm font-medium">Search</span>
        </a>
      </li>
      {moreItems.map(({ href, key, label, Icon, match, id }) => {
        const active = match(path)
        const isDownloads = id === "mobile-more-downloads"
        return (
          <li>
            <a
              href={href}
              id={id}
              aria-label={label}
              aria-current={active ? "page" : undefined}
              data-i18n-attr={`aria-label:${key}`}
              class:list={[
                "group flex items-center gap-3 rounded-xl px-2.5 py-2 min-h-12",
                "transition-[color,background-color,transform] duration-150 outline-none",
                "hover:bg-surface-2 focus-visible:bg-surface-2 active:scale-[0.99]",
                active
                  ? "bg-surface-2 text-fg ring-1 ring-accent/40"
                  : "text-fg-2 hover:text-fg focus-visible:text-fg",
              ]}>
              <span class:list={[
                "relative flex size-10 shrink-0 items-center justify-center rounded-lg",
                "ring-1 transition-colors",
                active
                  ? "bg-accent-soft ring-accent/30"
                  : "bg-surface ring-line group-hover:ring-line-soft",
              ]}>
                <Icon
                  aria-hidden="true"
                  stroke={active ? 2 : 1.75}
                  class:list={[
                    "size-5 shrink-0",
                    active ? "text-accent" : "text-fg-2",
                  ]}
                />
                {isDownloads && (
                  <span
                    id="mobile-more-downloads-badge"
                    aria-hidden="true"
                    hidden
                    class="absolute -top-1 -right-1 min-w-4.5 h-4.5 px-1
                           inline-flex items-center justify-center rounded-full
                           bg-accent text-bg text-[10px] font-semibold leading-none
                           tabular-nums ring-2 ring-bg">0</span>
                )}
              </span>
              <span data-i18n={key} class="truncate text-sm font-medium">{label}</span>
              {isDownloads && (
                <span
                  id="mobile-more-downloads-sub"
                  class="ml-auto truncate text-2xs text-fg-3 tabular-nums empty:hidden"></span>
              )}
            </a>
          </li>
        )
      })}
    </ul>
  </div>

  <!-- Tab row: 2 destinations | More | 2 destinations. -->
  <div class="flex items-stretch border-t border-line">
    {tabItems.slice(0, 2).map(({ href, key, label, Icon, match }) => {
      const active = match(path)
      return (
        <a
          href={href}
          aria-label={label}
          aria-current={active ? "page" : undefined}
          data-i18n-attr={`aria-label:${key}`}
          class:list={[
            "flex flex-1 min-w-0 flex-col items-center justify-center gap-0.5",
            "min-h-14 px-0.5 sm:px-1 py-2 rounded-lg",
            "transition-[color,background-color,transform] duration-150 outline-none",
            "focus-visible:bg-surface-2 active:scale-[0.96]",
            active ? "text-fg" : "text-fg-3 hover:text-fg",
          ]}>
          <Icon
            aria-hidden="true"
            stroke={active ? 2 : 1.75}
            class:list={[
              "size-5 shrink-0",
              active ? "text-accent" : "text-fg-3",
            ]}
          />
          <span data-i18n={key} class:list={[
            "text-2xs leading-none truncate max-w-full",
            active ? "font-medium" : "font-normal",
          ]}>
            {label}
          </span>
        </a>
      )
    })}

    <button
      id="mobile-more-btn"
      type="button"
      aria-label="More"
      aria-controls="mobile-more-panel"
      aria-expanded="false"
      data-i18n-attr="aria-label:sidebar.more"
      class:list={[
        "group flex flex-1 min-w-0 flex-col items-center justify-center gap-0.5 relative",
        "min-h-14 px-0.5 sm:px-1 py-2 rounded-lg",
        "transition-[color,background-color,transform] duration-150 outline-none",
        "focus-visible:bg-surface-2 active:scale-[0.96]",
        "aria-expanded:bg-surface-2",
        moreActive ? "text-fg" : "text-fg-3 hover:text-fg",
      ]}>
      <span class="relative inline-flex shrink-0">
        <IconLayoutGrid
          aria-hidden="true"
          stroke={moreActive ? 2 : 1.75}
          class:list={[
            "size-5 shrink-0 transition-transform duration-200 ease-out",
            "group-aria-expanded:scale-110 group-aria-expanded:rotate-45",
            moreActive ? "text-accent" : "text-fg-3",
          ]}
        />
        <span
          id="mobile-more-btn-badge"
          aria-hidden="true"
          hidden
          class="absolute -top-1.5 -right-2 min-w-4.5 h-4.5 px-1
                 inline-flex items-center justify-center rounded-full
                 bg-accent text-bg text-[10px] font-semibold leading-none
                 tabular-nums ring-2 ring-bg">0</span>
      </span>
      <span data-i18n="sidebar.more" class:list={[
        "text-2xs leading-none truncate max-w-full",
        moreActive ? "font-medium" : "font-normal",
      ]}>
        More
      </span>
    </button>

    {tabItems.slice(2).map(({ href, key, label, Icon, match }) => {
      const active = match(path)
      return (
        <a
          href={href}
          aria-label={label}
          aria-current={active ? "page" : undefined}
          data-i18n-attr={`aria-label:${key}`}
          class:list={[
            "flex flex-1 min-w-0 flex-col items-center justify-center gap-0.5",
            "min-h-14 px-0.5 sm:px-1 py-2 rounded-lg",
            "transition-[color,background-color,transform] duration-150 outline-none",
            "focus-visible:bg-surface-2 active:scale-[0.96]",
            active ? "text-fg" : "text-fg-3 hover:text-fg",
          ]}>
          <Icon
            aria-hidden="true"
            stroke={active ? 2 : 1.75}
            class:list={[
              "size-5 shrink-0",
              active ? "text-accent" : "text-fg-3",
            ]}
          />
          <span data-i18n={key} class:list={[
            "text-2xs leading-none truncate max-w-full",
            active ? "font-medium" : "font-normal",
          ]}>
            {label}
          </span>
        </a>
      )
    })}
  </div>
</nav>

<script>
  import {
    listDownloads,
    DOWNLOADS_LIST_EVENT,
    DOWNLOAD_PROGRESS_EVENT,
  } from "@/scripts/lib/downloads.js"
  import { toastSuccess, toastError } from "@/scripts/lib/toast.js"
  import { t } from "@/scripts/lib/i18n.js"

  function onLoginPage() {
    return (
      location.pathname === "/login" ||
      location.pathname.startsWith("/login/")
    )
  }
  function maybeWarmup() {
    if (onLoginPage()) return
    import("@/scripts/lib/catalog.js")
      .then((m) => m.warmupActive())
      .catch(() => {})
  }
  document.addEventListener("xt:active-changed", () => {
    maybeWarmup()
  })

  if (typeof window !== "undefined") {
    window.requestIdleCallback
      ? window.requestIdleCallback(maybeWarmup, { timeout: 2000 })
      : setTimeout(maybeWarmup, 500)
  }

  const sidebarBadge = document.getElementById("sidebar-downloads-badge")
  const sidebarSub = document.getElementById("sidebar-downloads-sub")
  const mobileBadge = document.getElementById("mobile-more-downloads-badge")
  const mobileSub = document.getElementById("mobile-more-downloads-sub")
  const moreBtnBadge = document.getElementById("mobile-more-btn-badge")

  const ACTIVE = new Set(["downloading", "queued", "stalled"])

  function setBadge(el, count) {
    if (!el) return
    if (count === 0) {
      el.setAttribute("hidden", "")
      el.textContent = ""
    } else {
      el.removeAttribute("hidden")
      el.textContent = count > 9 ? "9+" : String(count)
    }
  }

  function setSub(el, active, downloading, done, total) {
    if (!el) return
    if (active.length === 0) {
      el.textContent = ""
      return
    }
    if (total > 0 && downloading > 0) {
      const pct = Math.max(0, Math.min(100, (done / total) * 100))
      el.textContent = `${pct.toFixed(0)}%`
    } else {
      el.textContent = `${active.length}`
    }
  }

  function update() {
    const list = listDownloads()
    const active = list.filter((d) => ACTIVE.has(d.status))
    const count = active.length
    let done = 0
    let total = 0
    let downloading = 0
    for (const d of active) {
      if (d.status === "downloading") downloading++
      if (d.bytesTotal > 0) {
        done += d.bytesDone || 0
        total += d.bytesTotal
      }
    }

    setBadge(sidebarBadge, count)
    setBadge(mobileBadge, count)
    setBadge(moreBtnBadge, count)
    setSub(sidebarSub, active, downloading, done, total)
    setSub(mobileSub, active, downloading, done, total)
  }

  // Track per-id status so we only toast on the actual transition, not
  // on every list re-render. Initialized from the current list so a
  // page load doesn't fire a toast for items that were already done.
  /** @type {Map<string, string>} */
  const lastStatusById = new Map()
  for (const d of listDownloads()) lastStatusById.set(d.id, d.status)

  function detectTransitions() {
    const list = listDownloads()
    const seen = new Set()
    for (const d of list) {
      seen.add(d.id)
      const prev = lastStatusById.get(d.id)
      lastStatusById.set(d.id, d.status)
      if (prev === d.status) continue
      if (d.status === "done" && prev !== "done") {
        toastSuccess(t("downloads.toast.complete"), {
          description: d.title || d.filename || "",
        })
      } else if (d.status === "error" && prev !== "error") {
        toastError(t("downloads.toast.failed"), {
          description: [d.title || d.filename || "", d.error || ""]
            .filter(Boolean)
            .join("\n"),
          duration: 6000,
        })
      }
    }
    // Drop tracked ids that no longer exist (cancelled/removed).
    for (const id of lastStatusById.keys()) {
      if (!seen.has(id)) lastStatusById.delete(id)
    }
  }

  document.addEventListener(DOWNLOADS_LIST_EVENT, () => {
    detectTransitions()
    update()
  })
  document.addEventListener(DOWNLOAD_PROGRESS_EVENT, update)
  update()

  // Mobile bottom-nav "More" panel
  const moreBtn = /** @type {HTMLButtonElement|null} */ (
    document.getElementById("mobile-more-btn")
  )
  const morePanel = /** @type {HTMLElement|null} */ (
    document.getElementById("mobile-more-panel")
  )
  const mobileNav = /** @type {HTMLElement|null} */ (
    document.querySelector("[data-mobile-nav]")
  )

  function setMoreOpen(open) {
    if (!moreBtn || !morePanel) return
    moreBtn.setAttribute("aria-expanded", open ? "true" : "false")
    morePanel.dataset.open = open ? "true" : "false"
    morePanel.setAttribute("aria-hidden", open ? "false" : "true")
  }

  moreBtn?.addEventListener("click", (ev) => {
    ev.stopPropagation()
    const open = moreBtn.getAttribute("aria-expanded") === "true"
    setMoreOpen(!open)
  })

  document.addEventListener("click", (ev) => {
    if (!moreBtn || !morePanel) return
    if (moreBtn.getAttribute("aria-expanded") !== "true") return
    const target = /** @type {Node} */ (ev.target)
    if (mobileNav && !mobileNav.contains(target)) setMoreOpen(false)
  })

  document.addEventListener("keydown", (ev) => {
    if (ev.key !== "Escape") return
    if (moreBtn?.getAttribute("aria-expanded") === "true") {
      ev.stopPropagation()
      setMoreOpen(false)
      moreBtn.focus()
    }
  })
</script>

<style>
  /* Override the global focus-visible outline (Layout.astro paints an
     accent rectangle around any focused <a>). The glyph's own brightening
     handles focus indication. */
  .brand-mark:focus-visible { outline: none !important; }

  /* Let the comet's drop-shadow extend past the SVG viewBox so the glow
     isn't clipped to a square. */
  .brand-mark__svg { overflow: visible; }

  /* Base infinity: solid enough to read at a glance, calm enough to not
     compete with the comet for attention. */
  .brand-mark__base {
    stroke: var(--color-accent);
    stroke-width: 1.6;
    opacity: 0.5;
    vector-effect: non-scaling-stroke;
  }

  /* Comet trail glow: three drop-shadow layers for a richer falloff than
     a single shadow. Inner punch + medium halo + soft outer bloom. */
  .brand-mark__trail {
    color: var(--color-accent);
    filter: drop-shadow(0 0 2px var(--color-accent))
            drop-shadow(0 0 5px var(--color-accent))
            drop-shadow(0 0 10px var(--color-accent-soft));
    transition: filter 280ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .brand-mark__trail {
    animation: brand-mark-trail-show 240ms ease-out 500ms backwards;
  }
  @keyframes brand-mark-trail-show {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .brand-mark:hover .brand-mark__base,
  .brand-mark:focus-visible .brand-mark__base { opacity: 0.75; }
  .brand-mark:hover .brand-mark__trail,
  .brand-mark:focus-visible .brand-mark__trail {
    filter: drop-shadow(0 0 3px var(--color-accent))
            drop-shadow(0 0 8px var(--color-accent))
            drop-shadow(0 0 16px var(--color-accent));
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-mark__trail { display: none; }
    .brand-mark__base { opacity: 0.7; }
  }
</style>
