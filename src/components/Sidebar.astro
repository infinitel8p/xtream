---
import {
  IconInfinity,
  IconHome,
  IconDeviceTv,
  IconMovie,
  IconStack2,
  IconCalendarTime,
  IconSettings,
} from "@tabler/icons-svelte"
import PlaylistSwitcher from "@/components/PlaylistSwitcher.astro"

const path = Astro.url.pathname.replace(/\/$/, "") || "/"

// Primary destinations on the desktop rail. EPG sits here too — on mobile
// we drop it from the bottom bar (Live TV's toolbar already links to it).
const items = [
  { href: "/",        label: "Home",    Icon: IconHome,         match: (p) => p === "/" },
  { href: "/livetv",  label: "Live TV", Icon: IconDeviceTv,     match: (p) => p === "/livetv" || p.startsWith("/livetv/") },
  { href: "/movies",  label: "Movies",  Icon: IconMovie,        match: (p) => p === "/movies" || p.startsWith("/movies/") },
  { href: "/series",  label: "Series",  Icon: IconStack2,       match: (p) => p === "/series" || p.startsWith("/series/") },
  { href: "/epg",     label: "EPG",     Icon: IconCalendarTime, match: (p) => p === "/epg" || p.startsWith("/epg/") },
]

// Bottom nav on mobile: drop EPG to keep tap targets comfortable on small
// phones, include Settings as the 5th tab.
const mobileItems = [
  ...items.filter((i) => i.href !== "/epg"),
  { href: "/settings", label: "Settings", Icon: IconSettings, match: (p) => p === "/settings" || p.startsWith("/settings/") },
]

const settingsActive = path === "/settings" || path.startsWith("/settings/")
---

<!-- Desktop / tablet side rail (md+). Hidden on phones. -->
<aside
  class="hidden md:flex md:order-first
         shrink-0 flex-col gap-2 border-r border-line bg-bg
         w-16 lg:w-64
         p-2 lg:p-3
         pl-[max(0.5rem,env(safe-area-inset-left))]
         pb-[max(0.5rem,env(safe-area-inset-bottom))]">

  <a
    href="/"
    aria-label="Extreme InfiniTV - Home"
    class="[view-transition-name:brand-mark]
           flex items-center gap-3 rounded-xl px-2 py-2
           justify-center lg:justify-start
           hover:bg-surface-2 focus-visible:bg-surface-2
           transition-colors">
    <span class="flex size-9 shrink-0 items-center justify-center rounded-lg bg-accent ring-1 ring-line">
      <IconInfinity aria-hidden="true" class="size-5 text-bg" />
    </span>
    <span class="hidden lg:inline truncate text-sm font-semibold tracking-tight text-fg">
      Extreme InfiniTV
    </span>
  </a>

  <nav class="flex flex-col gap-1 flex-1 mt-2" aria-label="Main">
    {items.map(({ href, label, Icon, match }) => {
      const active = match(path)
      return (
        <a
          href={href}
          aria-label={label}
          aria-current={active ? "page" : undefined}
          title={label}
          class:list={[
            "flex items-center gap-3 rounded-xl px-2.5 py-2.5 min-h-11",
            "justify-center lg:justify-start",
            "transition-colors outline-none",
            "hover:bg-surface-2 focus-visible:bg-surface-2",
            active
              ? "bg-surface-2 text-fg ring-1 ring-accent/40"
              : "text-fg-2 hover:text-fg focus-visible:text-fg",
          ]}>
          <Icon
            aria-hidden="true"
            stroke={active ? 2 : 1.75}
            class:list={[
              "size-5 shrink-0",
              active ? "text-accent" : "text-fg-3",
            ]}
          />
          <span class="hidden lg:inline truncate text-sm font-medium">
            {label}
          </span>
        </a>
      )
    })}
  </nav>

  <a
    href="/settings"
    data-account-expiration="banner"
    hidden
    aria-label="Account expiration warning"
    title="Account expiration"
    class="hidden lg:flex items-center gap-2 rounded-xl px-3 py-2 text-xs font-medium tabular-nums
           border border-warn/30 bg-warn/10 text-warn
           data-[state=critical]:border-bad/40 data-[state=critical]:bg-bad/10 data-[state=critical]:text-bad
           data-[state=expired]:border-bad/40 data-[state=expired]:bg-bad/10 data-[state=expired]:text-bad
           hover:border-current focus-visible:border-current
           outline-none transition-colors">
  </a>

  <div
    data-account-expiration
    class="hidden lg:block px-2.5 text-2xs text-fg-3 tabular-nums truncate empty:hidden">
  </div>

  <div class="flex flex-col gap-1 pt-2 border-t border-line">
    <PlaylistSwitcher />
    <a
      href="/settings"
      aria-label="Settings"
      aria-current={settingsActive ? "page" : undefined}
      title="Settings"
      class:list={[
        "flex items-center gap-3 rounded-xl px-2.5 py-2.5 min-h-11",
        "justify-center lg:justify-start",
        "transition-colors outline-none",
        "hover:bg-surface-2 focus-visible:bg-surface-2",
        settingsActive
          ? "bg-surface-2 text-fg ring-1 ring-accent/40"
          : "text-fg-2 hover:text-fg focus-visible:text-fg",
      ]}>
      <IconSettings
        aria-hidden="true"
        stroke={settingsActive ? 2 : 1.75}
        class:list={[
          "size-5 shrink-0",
          settingsActive ? "text-accent" : "text-fg-3",
        ]}
      />
      <span class="hidden lg:inline truncate text-sm font-medium">
        Settings
      </span>
    </a>
  </div>
</aside>

<!-- Mobile bottom nav (< md). Sits at the bottom of the column flex thanks
     to `order-last`, so it's in flow rather than fixed-positioned — no
     overlap padding gymnastics needed on individual pages. -->
<nav
  class="md:hidden order-last
         shrink-0 flex items-stretch border-t border-line bg-bg/95 backdrop-blur
         pb-[max(0.25rem,env(safe-area-inset-bottom))]
         pl-[max(0,env(safe-area-inset-left))]
         pr-[max(0,env(safe-area-inset-right))]"
  aria-label="Main">
  {mobileItems.map(({ href, label, Icon, match }) => {
    const active = match(path)
    return (
      <a
        href={href}
        aria-label={label}
        aria-current={active ? "page" : undefined}
        class:list={[
          "flex flex-1 min-w-0 flex-col items-center justify-center gap-0.5",
          "min-h-14 px-1 py-2 rounded-lg",
          "transition-colors outline-none",
          "focus-visible:bg-surface-2",
          active ? "text-fg" : "text-fg-3 hover:text-fg",
        ]}>
        <Icon
          aria-hidden="true"
          stroke={active ? 2 : 1.75}
          class:list={[
            "size-5 shrink-0",
            active ? "text-accent" : "text-fg-3",
          ]}
        />
        <span class:list={[
          "text-2xs leading-none truncate max-w-full",
          active ? "font-medium" : "font-normal",
        ]}>
          {label}
        </span>
      </a>
    )
  })}
</nav>

<script>
  import { injectExpirationDate } from "@/scripts/expiration.js"
  injectExpirationDate()
  document.addEventListener("xt:active-changed", () => injectExpirationDate())
</script>
