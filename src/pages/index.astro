---
import Layout from "@/layouts/Layout.astro";
import {
	IconDeviceTv,
	IconMovie,
	IconStack2,
	IconPlus,
	IconSparkles,
} from "@tabler/icons-svelte";
---

<Layout>
	<script is:inline>
		try {
			var raw = localStorage.getItem("xt_playlists") || "";
			var hasEntries = false;
			if (raw) {
				var parsed = JSON.parse(raw);
				hasEntries = !!(
					parsed &&
					Array.isArray(parsed.entries) &&
					parsed.entries.length
				);
			}
			if (!hasEntries) {
				document.documentElement.setAttribute("data-first-run", "true");
			}
		} catch (e) {}
	</script>

	<main
		class="flex-1 w-full mx-auto px-4 py-6 md:px-6 lg:px-8 max-w-7xl flex flex-col">
		<section
			id="welcome"
			aria-labelledby="welcome-heading"
			class="hidden flex-1 min-h-0 items-center justify-center py-6">
			<div
				class="welcome-enter w-full max-w-2xl rounded-2xl border border-line bg-surface p-6 sm:p-10 lg:p-14 text-center">
				<p
					class="font-sans text-eyebrow font-medium uppercase tracking-wider text-fg-3 mb-5">
					Welcome
				</p>
				<h1
					id="welcome-heading"
					class="font-normal text-accent tracking-[-0.01em] leading-none"
					style="font-size: clamp(2.25rem, 4vw + 1rem, 4.25rem);">
					Pick something to watch.
				</h1>
				<p
					class="mt-5 sm:mt-6 mx-auto max-w-md text-sm sm:text-base text-fg-2 font-sans tracking-tight leading-relaxed">
					Connect an IPTV subscription, or paste a playlist URL.
					Channels, movies, and series will appear here.
				</p>

				<div
					class="mt-8 sm:mt-10 flex flex-col sm:flex-row gap-2.5 sm:gap-3 sm:justify-center">
					<a
						id="welcome-add"
						href="/login"
						class="inline-flex items-center justify-center gap-2 h-11 px-5 rounded-lg bg-fg text-bg text-sm font-semibold transition-opacity hover:opacity-90">
						<IconPlus aria-hidden="true" class="h-4 w-4" />
						Add a playlist
					</a>
					<a
						href="/login?demo=1"
						class="inline-flex items-center justify-center gap-2 h-11 px-5 rounded-lg border border-line bg-surface text-sm font-medium text-fg transition-colors hover:bg-surface-2 hover:border-line-soft focus-visible:bg-surface-2 focus-visible:border-accent">
						<IconSparkles
							aria-hidden="true"
							class="h-4 w-4 text-accent"
						/>
						Try a demo playlist
					</a>
				</div>

				<p class="mt-8 text-xs text-fg-3 leading-relaxed">
					This app does not provide any content. The demo loads a
					public playlist from iptv-org.
				</p>
			</div>
		</section>

		<nav
			id="hub-tiles"
			aria-label="Browse"
			class="grid gap-3 sm:gap-4 flex-1 min-h-0
				grid-cols-1
				landscape:grid-cols-[2fr_1fr] landscape:grid-rows-2
				lg:grid-cols-[2fr_1fr] lg:grid-rows-2">
			<a
				href="/livetv"
				aria-label="Watch Live TV"
				style="animation-delay: 50ms;"
				class="tile-enter lg:row-span-2 landscape:row-span-2 group relative flex flex-col justify-between
					rounded-2xl border border-line bg-surface
					p-6 sm:p-8 lg:p-12
					min-h-56 landscape:min-h-0 lg:min-h-0 overflow-hidden
					transition-[transform,border-color,background-color] duration-300 ease-out
					hover:border-accent hover:bg-surface-2
					focus-visible:border-accent focus-visible:bg-surface-2
					hover:transform-[translateY(-2px)]
					focus-visible:transform-[translateY(-2px)]">
				<div class="flex items-start justify-between gap-4">
					<IconDeviceTv
						aria-hidden="true"
						stroke={1}
						class="size-12 sm:size-16 lg:size-24 text-fg-3 shrink-0 transition-colors duration-200 group-hover:text-accent group-focus-visible:text-accent"
					/>
					<p
						id="hero-eyebrow"
						class="font-sans text-eyebrow font-medium uppercase text-fg-3 text-right pt-2 tabular-nums"
						aria-hidden="true">
					</p>
				</div>
				<div class="mt-auto pt-6">
					<h2
						class="font-semibold tracking-[-0.02em] leading-[0.92] text-fg
							group-hover:text-accent group-focus-visible:text-accent
							transition-colors duration-200 ms-[-0.05em]"
						style="font-size: clamp(3rem, 6vw + 1.5rem, 8.5rem);">
						Live TV
					</h2>
					<p class="mt-4 sm:mt-5 text-sm sm:text-base text-fg-2 max-w-md font-sans tracking-tight">
						Channels, and what's on right now.
					</p>
				</div>
			</a>

			<a
				href="/movies"
				aria-label="Browse Movies"
				style="animation-delay: 150ms;"
				class="tile-enter group flex flex-col justify-between
					rounded-2xl border border-line bg-surface
					p-5 sm:p-6
					min-h-28 landscape:min-h-0 lg:min-h-0
					transition-[transform,border-color,background-color] duration-300 ease-out
					hover:border-accent hover:bg-surface-2
					focus-visible:border-accent focus-visible:bg-surface-2
					hover:transform-[translateY(-2px)]
					focus-visible:transform-[translateY(-2px)]">
				<IconMovie
					aria-hidden="true"
					stroke={1.25}
					class="size-9 sm:size-10 lg:size-12 text-fg-3 transition-colors duration-200 group-hover:text-accent group-focus-visible:text-accent"
				/>
				<div class="mt-auto pt-4">
					<h2 class="text-2xl sm:text-3xl lg:text-5xl font-semibold tracking-[-0.02em] leading-[0.95]
						text-fg group-hover:text-accent group-focus-visible:text-accent
						transition-colors duration-200 ms-[-0.05em]">
						Movies
					</h2>
					<p class="mt-1.5 text-sm text-fg-2">
						Browse the library.
					</p>
				</div>
			</a>

			<a
				href="/series"
				aria-label="Browse Series"
				style="animation-delay: 250ms;"
				class="tile-enter group flex flex-col justify-between
					rounded-2xl border border-line bg-surface
					p-5 sm:p-6
					min-h-28 landscape:min-h-0 lg:min-h-0
					transition-[transform,border-color,background-color] duration-300 ease-out
					hover:border-accent hover:bg-surface-2
					focus-visible:border-accent focus-visible:bg-surface-2
					hover:transform-[translateY(-2px)]
					focus-visible:transform-[translateY(-2px)]">
				<IconStack2
					aria-hidden="true"
					stroke={1.25}
					class="size-9 sm:size-10 lg:size-12 text-fg-3 transition-colors duration-200 group-hover:text-accent group-focus-visible:text-accent"
				/>
				<div class="mt-auto pt-4">
					<h2 class="text-2xl sm:text-3xl lg:text-5xl font-semibold tracking-[-0.02em] leading-[0.95]
						text-fg group-hover:text-accent group-focus-visible:text-accent
						transition-colors duration-200 ms-[-0.05em]">
						Series
					</h2>
					<p class="mt-1.5 text-sm text-fg-2">
						Shows and full seasons.
					</p>
				</div>
			</a>
		</nav>
	</main>
</Layout>

<style>
	@keyframes tile-enter {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
	}
	.tile-enter {
		animation: tile-enter 500ms cubic-bezier(0.16, 1, 0.3, 1) backwards;
	}
	.welcome-enter {
		animation: tile-enter 500ms cubic-bezier(0.16, 1, 0.3, 1) backwards;
	}
	html[data-first-run="true"] #hub-tiles {
		display: none;
	}
	html[data-first-run="true"] #welcome {
		display: flex;
	}
</style>

<script>
	import "../scripts/updater-startup.js";
	import { getEntries } from "@/scripts/lib/creds.js";

	const eyebrow = document.getElementById("hero-eyebrow");
	if (eyebrow) {
		const update = () => {
			const now = new Date();
			const date = new Intl.DateTimeFormat(undefined, {
				weekday: "short",
				day: "2-digit",
				month: "short",
			}).format(now);
			const time = new Intl.DateTimeFormat(undefined, {
				hour: "numeric",
				minute: "2-digit",
			}).format(now);
			eyebrow.textContent = `${date} · ${time}`;
		};
		update();
		setInterval(update, 30_000);
	}

	async function reconcileFirstRun() {
		const entries = await getEntries();
		const hasEntries = entries.length > 0;
		document.documentElement.toggleAttribute("data-first-run", !hasEntries);
		return hasEntries;
	}

	window.addEventListener("load", async () => {
		const hasEntries = await reconcileFirstRun();
		setTimeout(() => {
			const target = hasEntries
				? /** @type {HTMLAnchorElement | null} */ (
						document.querySelector('#hub-tiles a[href="/livetv"]')
					)
				: /** @type {HTMLAnchorElement | null} */ (
						document.getElementById("welcome-add")
					);
			target?.focus({ preventScroll: true });
		}, 0);
	});

	document.addEventListener("xt:entries-updated", reconcileFirstRun);
	document.addEventListener("xt:active-changed", reconcileFirstRun);
</script>
