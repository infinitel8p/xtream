---
import Layout from "@/layouts/Layout.astro";
import { IconDeviceTv, IconMovie, IconStack2 } from "@tabler/icons-svelte";
---

<Layout>
	<main
		class="flex-1 w-full mx-auto px-4 py-6 md:px-6 lg:px-8 max-w-7xl flex flex-col">
		<nav
			aria-label="Browse"
			class="grid gap-3 sm:gap-4 flex-1 min-h-0
				grid-cols-1
				landscape:grid-cols-[2fr_1fr] landscape:grid-rows-2
				lg:grid-cols-[2fr_1fr] lg:grid-rows-2">
			<a
				href="/livetv"
				aria-label="Watch Live TV"
				style="animation-delay: 50ms; view-transition-name: active-nav-livetv;"
				class="tile-enter lg:row-span-2 landscape:row-span-2 group relative flex flex-col justify-between
					rounded-2xl border border-line bg-surface
					p-6 sm:p-8 lg:p-12
					min-h-56 landscape:min-h-0 lg:min-h-0 overflow-hidden
					transition-[transform,border-color,background-color] duration-300 ease-out
					hover:border-accent hover:bg-surface-2
					focus-visible:border-accent focus-visible:bg-surface-2
					hover:transform-[translateY(-2px)]
					focus-visible:transform-[translateY(-2px)]">
				<div class="flex items-start justify-between gap-4">
					<IconDeviceTv
						aria-hidden="true"
						stroke={1}
						class="size-12 sm:size-16 lg:size-24 text-accent shrink-0"
					/>
					<p
						id="hero-eyebrow"
						class="font-sans text-eyebrow font-medium uppercase text-fg-3 text-right pt-2 tabular-nums"
						aria-hidden="true">
					</p>
				</div>
				<div class="mt-auto pt-6">
					<h2
						class="font-semibold tracking-[-0.02em] leading-[0.92] text-fg
							group-hover:text-accent group-focus-visible:text-accent
							transition-colors duration-200 ms-[-0.05em]"
						style="font-size: clamp(3rem, 6vw + 1.5rem, 8.5rem);">
						Live TV
					</h2>
					<p class="mt-4 sm:mt-5 text-sm sm:text-base text-fg-2 max-w-md font-sans tracking-tight">
						Channels, and what's on right now.
					</p>
				</div>
			</a>

			<a
				href="/movies"
				aria-label="Browse Movies"
				style="animation-delay: 150ms; view-transition-name: active-nav-movies;"
				class="tile-enter group flex flex-col justify-between
					rounded-2xl border border-line bg-surface
					p-5 sm:p-6
					min-h-28 landscape:min-h-0 lg:min-h-0
					transition-[transform,border-color,background-color] duration-300 ease-out
					hover:border-accent hover:bg-surface-2
					focus-visible:border-accent focus-visible:bg-surface-2
					hover:transform-[translateY(-2px)]
					focus-visible:transform-[translateY(-2px)]">
				<IconMovie
					aria-hidden="true"
					stroke={1.25}
					class="size-9 sm:size-10 lg:size-12 text-fg-3 transition-colors group-hover:text-accent group-focus-visible:text-accent"
				/>
				<div class="mt-auto pt-4">
					<h2 class="text-2xl sm:text-3xl lg:text-5xl font-semibold tracking-[-0.02em] leading-[0.95]
						text-fg group-hover:text-accent group-focus-visible:text-accent
						transition-colors duration-200 ms-[-0.05em]">
						Movies
					</h2>
					<p class="mt-1.5 text-sm text-fg-2">
						Browse the library.
					</p>
				</div>
			</a>

			<a
				href="/series"
				aria-label="Browse Series"
				style="animation-delay: 250ms; view-transition-name: active-nav-series;"
				class="tile-enter group flex flex-col justify-between
					rounded-2xl border border-line bg-surface
					p-5 sm:p-6
					min-h-28 landscape:min-h-0 lg:min-h-0
					transition-[transform,border-color,background-color] duration-300 ease-out
					hover:border-accent hover:bg-surface-2
					focus-visible:border-accent focus-visible:bg-surface-2
					hover:transform-[translateY(-2px)]
					focus-visible:transform-[translateY(-2px)]">
				<IconStack2
					aria-hidden="true"
					stroke={1.25}
					class="size-9 sm:size-10 lg:size-12 text-fg-3 transition-colors group-hover:text-accent group-focus-visible:text-accent"
				/>
				<div class="mt-auto pt-4">
					<h2 class="text-2xl sm:text-3xl lg:text-5xl font-semibold tracking-[-0.02em] leading-[0.95]
						text-fg group-hover:text-accent group-focus-visible:text-accent
						transition-colors duration-200 ms-[-0.05em]">
						Series
					</h2>
					<p class="mt-1.5 text-sm text-fg-2">
						Shows and full seasons.
					</p>
				</div>
			</a>
		</nav>
	</main>
</Layout>

<style>
	@keyframes tile-enter {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
	}
	.tile-enter {
		animation: tile-enter 500ms cubic-bezier(0.16, 1, 0.3, 1) backwards;
	}
</style>

<script>
	import "../scripts/updater-startup.js";

	const eyebrow = document.getElementById("hero-eyebrow");
	if (eyebrow) {
		const update = () => {
			const now = new Date();
			const date = new Intl.DateTimeFormat(undefined, {
				weekday: "short",
				day: "2-digit",
				month: "short",
			}).format(now);
			const time = new Intl.DateTimeFormat(undefined, {
				hour: "numeric",
				minute: "2-digit",
			}).format(now);
			eyebrow.textContent = `${date} · ${time}`;
		};
		update();
		setInterval(update, 30_000);
	}
	
	window.addEventListener("load", () => {
		setTimeout(() => {
			/** @type {HTMLAnchorElement | null} */
			const heroTile = document.querySelector('a[href="/livetv"]');
			heroTile?.focus({ preventScroll: true });
		}, 0);
	});
</script>
