---
import Layout from "@/layouts/Layout.astro"
import { IconChevronLeft } from "@tabler/icons-svelte"
---

<Layout pageTitle="Series">
  <main class="flex-1 min-w-0 min-h-0 overflow-y-auto overflow-x-hidden custom-scroll">
    <div
      class="relative w-full max-w-4xl mx-auto px-4 md:px-6 lg:px-8 pt-4 lg:pt-6 pb-12 flex flex-col gap-5 isolate">

      <div data-modal-ambient id="series-detail-ambient" aria-hidden="true"></div>

      <div class="relative z-10 flex flex-col gap-5">

        <a
          href="/series"
          id="series-detail-back"
          aria-label="Back to Series"
          class="dt-enter dt-stagger-0 self-start inline-flex items-center gap-1.5 rounded-lg px-2.5 py-2 min-h-11 text-sm text-fg-2
                 hover:bg-surface-2 focus-visible:bg-surface-2 outline-none transition-colors">
          <IconChevronLeft aria-hidden="true" stroke={2} class="size-4" />
          Series
        </a>

        <div class="dt-enter dt-stagger-1 flex flex-col gap-1">
          <h1
            id="series-detail-title"
            class="font-semibold tracking-[-0.02em] leading-tight text-2xl sm:text-3xl">
            -
          </h1>
          <div
            id="series-now-playing"
            class="text-xs text-fg-3 truncate tabular-nums">
          </div>
          <div
            id="series-detail-meta"
            class="text-xs text-fg-3 space-x-2 tabular-nums">
          </div>
        </div>

        <!-- Hero -->
        <div class="w-full">
          <div
            id="series-detail-poster"
            class="dt-hero aspect-2/3 sm:aspect-video w-full mx-auto overflow-hidden rounded-xl bg-surface-2 ring-1 ring-line
                   max-h-[40dvh] max-w-[calc(40dvh*2/3)] sm:max-w-[calc(40dvh*16/9)]"
            style="view-transition-name: active-poster;">
          </div>
          <div
            id="series-detail-player-wrap"
            class="hidden aspect-video w-full mx-auto overflow-hidden rounded-xl bg-black ring-1 ring-line
                   max-h-[60dvh] max-w-[calc(60dvh*16/9)]">
            <video
              id="series-player"
              class="video-js vjs-default-skin vjs-big-play-centered h-full w-full"
              controls
              hidden
              playsinline></video>
          </div>
        </div>

        <button
          id="series-detail-fav"
          type="button"
          aria-pressed="false"
          class="dt-enter dt-stagger-2 self-start rounded-xl border border-line px-4 min-h-11 text-sm
                 hover:bg-surface-2 focus-visible:bg-surface-2 focus-visible:border-accent
                 transition-colors">
          Add to favorites
        </button>

        <div
          id="series-detail-plot"
          class="dt-enter dt-stagger-3 text-sm text-fg-2 leading-relaxed max-w-prose">
          Loading details…
        </div>

        <!-- Season tabs -->
        <div
          id="series-season-tabs"
          class="dt-enter dt-stagger-4 flex flex-wrap gap-2 border-b border-line pb-3"
          role="tablist">
        </div>

        <!-- Episode list -->
        <div
          id="series-episode-list"
          class="flex flex-col gap-1.5">
        </div>

      </div>
    </div>

    <div
      id="app-version"
      class="fixed bottom-[max(0.5rem,env(safe-area-inset-bottom))] right-[max(0.75rem,env(safe-area-inset-right))] text-2xs text-fg-3 opacity-70 tabular-nums pointer-events-none">
      Loading…
    </div>
  </main>

  <script>
    import "@/scripts/series/detail.js"
    import "@/scripts/updater-startup.js"
    import { injectVersion } from "@/scripts/version.js"
    injectVersion()
  </script>
</Layout>
