---
import Layout from "@/layouts/Layout.astro";
import SearchInput from "@/components/SearchInput.astro";
import { IconRefresh, IconArrowLeft, IconChevronDown, IconClockHour3 } from "@tabler/icons-svelte";
---

<Layout pageTitle="EPG">
	<main
		class="w-full max-w-480 mx-auto px-4 md:px-6 lg:px-8 pt-4 lg:pt-6 md:landscape:pt-6 pb-6
			flex flex-col gap-3 flex-1 min-h-0">

		<header class="route-hero shrink-0">
			<h1 class="route-hero__title">N<em>o</em>w &amp; next</h1>
			<p
				id="epg-title"
				class="route-hero__sub truncate min-w-0">
				EPG · All categories
			</p>
		</header>

		<!-- Toolbar -->
		<section class="flex items-center gap-3 shrink-0 flex-wrap">
			<a
				href="/livetv"
				aria-label="Back to Live TV"
				class="rounded-xl border border-line bg-surface px-3 py-2 text-sm text-fg-2 inline-flex items-center gap-2
					hover:bg-surface-2 focus-visible:bg-surface-2 focus-visible:border-accent transition-colors">
				<IconArrowLeft aria-hidden="true" stroke={2} class="size-4" />
				Live TV
			</a>
			<button
				id="epg-category-trigger"
				type="button"
				aria-haspopup="dialog"
				aria-controls="epg-category-dialog"
				class="rounded-xl border border-line bg-surface px-3 py-2 text-sm flex items-center gap-2 text-left max-w-[18rem] min-w-0
					hover:bg-surface-2 focus-visible:bg-surface-2 focus-visible:border-accent transition-colors">
				<span class="text-fg-3 shrink-0">Category</span>
				<span
					id="epg-category-label"
					class="text-fg truncate flex-1">All categories</span>
				<IconChevronDown
					aria-hidden="true"
					stroke={2}
					class="size-4 text-fg-3 shrink-0"
				/>
			</button>
			<button
				id="epg-now"
				type="button"
				aria-label="Snap timeline to now"
				title="Snap to now"
				class="rounded-xl border border-line bg-surface p-2 sm:px-3 text-sm text-fg-2 inline-flex items-center gap-2 shrink-0
					hover:bg-surface-2 focus-visible:bg-surface-2 focus-visible:border-accent transition-colors">
				<IconClockHour3 aria-hidden="true" stroke={2} class="size-4" />
				<span class="hidden sm:inline">Now</span>
			</button>
			<button
				id="epg-refresh"
				type="button"
				aria-label="Refresh EPG"
				class="rounded-xl border border-line bg-surface p-2 text-fg-2
					hover:bg-surface-2 focus-visible:bg-surface-2 focus-visible:border-accent transition-colors">
				<IconRefresh aria-hidden="true" stroke={2} class="size-4" />
			</button>
		</section>

		<!-- Status message (shown while loading or on error) -->
		<div
			id="epg-status"
			class="rounded-2xl border border-line bg-surface px-4 py-6 text-fg-2 text-sm">
			Loading…
		</div>

		<!-- Grid container -->
		<section
			id="epg-grid"
			class="hidden flex-1 min-h-0 overflow-auto custom-scroll
				rounded-2xl border border-line bg-bg">

			<!-- Time header -->
			<div
				class="sticky top-0 z-30 flex items-stretch border-b border-line bg-bg/95 backdrop-blur-sm">
				<div
					class="shrink-0 sticky left-0 z-30 bg-bg border-r border-line"
					style="width: 240px; height: 40px;">
				</div>
				<div
					id="epg-time-header-inner"
					class="relative shrink-0"
					style="height: 40px;">
				</div>
			</div>

			<!-- Body -->
			<div id="epg-body" class="relative">
			</div>
		</section>

		<dialog
			id="epg-category-dialog"
			aria-labelledby="epg-category-title"
			class="fixed inset-0 m-auto rounded-2xl border border-line bg-surface text-fg p-0
				w-[min(34rem,calc(100vw-2rem))] h-[min(80dvh,42rem)]
				backdrop:bg-black/60">
			<div class="flex flex-col h-full p-4 gap-3">
				<div class="flex items-center justify-between gap-3 shrink-0">
					<h2 id="epg-category-title" class="text-base font-semibold">
						Choose a category
					</h2>
					<button
						id="epg-category-close"
						type="button"
						class="rounded-lg border border-line px-3 py-1.5 text-xs text-fg-2
							hover:bg-surface-2 focus-visible:bg-surface-2 focus-visible:border-accent">
						Close
					</button>
				</div>

				<SearchInput
					id="epg-category-search"
					label="Search categories"
					placeholder="Search categories…"
				/>

				<div
					id="epg-category-list"
					class="relative flex-1 min-h-0 overflow-auto custom-scroll">
				</div>

				<div
					id="epg-category-list-status"
					class="px-2.5 text-sm text-fg-3 tabular-nums shrink-0">
				</div>
			</div>
		</dialog>
	</main>

	<script>
		import "../scripts/epg/epg.js";
		import { attachDialogSpatialNav } from "../scripts/lib/dialog-spatial-nav.js";

		const trigger = document.getElementById("epg-category-trigger");
		const dlg = /** @type {HTMLDialogElement|null} */ (
			document.getElementById("epg-category-dialog")
		);
		if (dlg) attachDialogSpatialNav(dlg, { defaultElement: "#epg-category-search" });
		const closeBtn = document.getElementById("epg-category-close");
		const list = document.getElementById("epg-category-list");
		const search = /** @type {HTMLInputElement|null} */ (
			document.getElementById("epg-category-search")
		);

		trigger?.addEventListener("click", () => {
			if (!dlg) return;
			if (typeof dlg.showModal === "function") dlg.showModal();
			else dlg.setAttribute("open", "");
			setTimeout(() => {
				window.SpatialNavigation?.makeFocusable?.();
				search?.focus();
				search?.select?.();
			}, 0);
		});

		closeBtn?.addEventListener("click", () => dlg?.close?.());

		list?.addEventListener("click", (e) => {
			const t = /** @type {HTMLElement} */ (e.target);
			if (!t.closest("button[role='option']")) return;
			queueMicrotask(() => {
				if (dlg?.open) dlg.close();
			});
		});

		dlg?.addEventListener("click", (e) => {
			if (e.target === dlg) dlg.close();
		});

		dlg?.addEventListener("close", () => trigger?.focus());
	</script>
</Layout>
