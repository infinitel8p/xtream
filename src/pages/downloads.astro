---
import Layout from "@/layouts/Layout.astro"
import {
  IconDownload,
  IconSettings,
} from "@tabler/icons-svelte"
---

<Layout pageTitle="Downloads">
  <main class="flex-1 min-h-0 overflow-y-auto overflow-x-clip custom-scroll">
    <div
      class="w-full max-w-480 mx-auto px-4 md:px-6 lg:px-8 pt-4 lg:pt-6 pb-12
             flex flex-col gap-6 sm:gap-8">

    <header class="route-hero shrink-0 dl-page-enter dl-stagger-1">
      <h1 class="route-hero__title">D<em>o</em>wnloads</h1>
      <p
        id="downloads-summary"
        aria-live="polite"
        class="route-hero__sub tabular-nums">
        Movies and series episodes you save will appear here.
      </p>
    </header>

    <!-- Folder summary -->
    <a
      id="downloads-folder-summary"
      href="/settings#downloads-folder-section"
      class="rounded-xl border border-line bg-surface px-4 py-2.5 flex items-center gap-3 text-sm
             hover:bg-surface-2 focus-visible:bg-surface-2 focus-visible:border-accent
             outline-none transition-colors dl-page-enter dl-stagger-2">
      <IconSettings aria-hidden="true" class="size-4 text-fg-3 shrink-0" />
      <span class="flex-1 min-w-0 flex flex-wrap items-baseline gap-x-2">
        <span class="text-fg-3 shrink-0">Saving to</span>
        <span
          id="downloads-folder-path"
          class="font-mono text-xs text-fg truncate min-w-0">
          Not set
        </span>
      </span>
      <span class="text-xs text-accent shrink-0">Change in Settings</span>
    </a>

    <!-- Active downloads (only shown when something is in flight). -->
    <section
      id="downloads-active-section"
      hidden
      class="flex flex-col gap-3 dl-page-enter dl-stagger-3">
      <div class="flex items-center justify-between gap-2">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-fg-2">In progress</h2>
      </div>

      <!-- Aggregate throughput sparkline. -->
      <section
        id="downloads-throughput"
        hidden
        class="rounded-xl border border-line bg-surface px-4 pt-3 pb-2.5 flex flex-col gap-2">
        <div class="flex items-center justify-between gap-3 text-2xs uppercase tracking-wider font-medium">
          <span class="text-fg-3">Throughput</span>
          <span
            id="downloads-throughput-now"
            class="text-fg tabular-nums normal-case tracking-normal text-xs font-medium">0 B/s</span>
        </div>
        <canvas
          id="downloads-throughput-canvas"
          aria-hidden="true"
          class="w-full block"
          style="height: 40px;"></canvas>
        <div class="flex items-center justify-between gap-3 text-2xs text-fg-3 tabular-nums">
          <span>
            <span class="opacity-60">min</span>
            <span id="downloads-throughput-min" class="ml-1 text-fg-2">-</span>
          </span>
          <span class="opacity-50 normal-case">last 120s</span>
          <span>
            <span id="downloads-throughput-max" class="mr-1 text-fg-2">-</span>
            <span class="opacity-60">max</span>
          </span>
        </div>
      </section>

      <article
        id="downloads-active-list"
        aria-label="Active downloads"
        class="rounded-2xl border border-line bg-surface overflow-hidden flex flex-col divide-y divide-line/60">
      </article>
    </section>

    <!-- Downloaded files (always shown, with empty state). -->
    <section class="flex flex-col gap-3 dl-page-enter dl-stagger-3">
      <div class="flex items-center justify-between gap-2">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-fg-2">Downloaded</h2>
        <span
          id="downloads-done-count"
          class="text-xs text-fg-3 tabular-nums empty:hidden"></span>
      </div>
      <article
        id="downloads-done-list"
        aria-label="Downloaded files"
        class="rounded-2xl border border-line bg-surface overflow-hidden flex flex-col divide-y divide-line/60">
        <div
          data-empty
          class="px-5 py-10 text-sm text-fg-3 flex flex-col items-center gap-4 text-center">
          <IconDownload aria-hidden="true" stroke={1.5} class="size-10 text-fg-3 dl-empty-icon" />
          <div class="flex flex-col gap-1">
            <p class="text-fg/80">No downloaded files yet.</p>
            <p class="text-xs text-fg-3 max-w-prose">
              Open a movie or series episode and tap Download to save it here.
            </p>
          </div>
        </div>
      </article>
    </section>

    </div>
    <div
      id="app-version"
      class="fixed bottom-[max(0.5rem,env(safe-area-inset-bottom))] right-[max(0.75rem,env(safe-area-inset-right))] text-2xs text-fg-3 opacity-70 tabular-nums pointer-events-none">
      Loading…
    </div>
  </main>

  <!-- Delete confirmation. -->
  <dialog
    id="downloads-delete-dialog"
    aria-labelledby="downloads-delete-title"
    class="fixed inset-0 m-auto rounded-2xl border border-line bg-surface text-fg p-0
           w-[min(28rem,calc(100vw-2rem))]
           backdrop:bg-black/70">
    <div class="flex flex-col gap-4 p-5">
      <div class="flex flex-col gap-1.5">
        <h2 id="downloads-delete-title" class="text-base font-semibold">
          Delete this download?
        </h2>
        <p id="downloads-delete-body" class="text-sm text-fg-2">
          The file will be removed from disk.
        </p>
      </div>
      <div class="flex gap-2 justify-end">
        <button
          id="downloads-delete-cancel"
          type="button"
          class="rounded-xl border border-line px-4 py-2 text-sm
                 hover:bg-surface-2 focus-visible:bg-surface-2 focus-visible:border-accent">
          Cancel
        </button>
        <button
          id="downloads-delete-confirm"
          type="button"
          class="rounded-xl px-4 py-2 text-sm font-semibold bg-bad text-bg
                 hover:opacity-90 focus-visible:opacity-90
                 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bad">
          Delete
        </button>
      </div>
    </div>
  </dialog>

  <script>
    import {
      listDownloads,
      isDownloadable,
      pauseDownload,
      resumeDownload,
      removeDownload,
      tryAndroidIntentPlayback,
      getAggregateThroughputHistory,
      getAggregateThroughputEwma,
      getRowThroughputHistory,
      getRowThroughputEwma,
      DOWNLOADS_LIST_EVENT,
      DOWNLOAD_PROGRESS_EVENT,
      THROUGHPUT_EVENT,
    } from "@/scripts/lib/downloads.js"
    import { getDownloadDir } from "@/scripts/lib/app-settings.js"
    import { injectVersion } from "@/scripts/version.js"
    import { attachDialogSpatialNav } from "@/scripts/lib/dialog-spatial-nav.js"
    injectVersion()

    // ----------------------------
    // DOM refs
    // ----------------------------
    const summaryEl = document.getElementById("downloads-summary")
    const folderPathEl = document.getElementById("downloads-folder-path")

    const activeSection = document.getElementById("downloads-active-section")
    const activeListEl = document.getElementById("downloads-active-list")

    const doneListEl = document.getElementById("downloads-done-list")
    const doneCountEl = document.getElementById("downloads-done-count")

    const throughputSection = document.getElementById("downloads-throughput")
    const throughputCanvas = /** @type {HTMLCanvasElement|null} */ (
      document.getElementById("downloads-throughput-canvas")
    )
    const throughputNowEl = document.getElementById("downloads-throughput-now")
    const throughputMinEl = document.getElementById("downloads-throughput-min")
    const throughputMaxEl = document.getElementById("downloads-throughput-max")

    const deleteDlg = /** @type {HTMLDialogElement|null} */ (
      document.getElementById("downloads-delete-dialog")
    )
    const deleteCancelBtn = document.getElementById("downloads-delete-cancel")
    const deleteConfirmBtn = document.getElementById("downloads-delete-confirm")
    const deleteBodyEl = document.getElementById("downloads-delete-body")

    if (deleteDlg) attachDialogSpatialNav(deleteDlg, { defaultElement: "#downloads-delete-cancel" })

    // ----------------------------
    // Folder summary
    // ----------------------------
    function syncFolderSummary() {
      if (!folderPathEl) return
      const v = getDownloadDir() || ""
      folderPathEl.textContent = v || "Not set"
      folderPathEl.classList.toggle("text-fg-3", !v)
      folderPathEl.classList.toggle("text-fg", !!v)
    }
    syncFolderSummary()

    window.addEventListener("storage", (e) => {
      if (e.key === "xt_download_dir" || e.key === null) syncFolderSummary()
    })

    // ----------------------------
    // Formatters
    // ----------------------------
    function fmtSize(n: number): string {
      if (!n) return "0 B"
      if (n < 1024) return `${n} B`
      if (n < 1024 * 1024) return `${(n / 1024).toFixed(1)} KB`
      if (n < 1024 * 1024 * 1024) return `${(n / (1024 * 1024)).toFixed(1)} MB`
      return `${(n / (1024 * 1024 * 1024)).toFixed(2)} GB`
    }

    function fmtSpeed(bytesPerSec: number): string {
      if (!bytesPerSec || !isFinite(bytesPerSec) || bytesPerSec <= 0) return ""
      if (bytesPerSec < 1024) return `${bytesPerSec.toFixed(0)} B/s`
      if (bytesPerSec < 1024 * 1024)
        return `${(bytesPerSec / 1024).toFixed(1)} KB/s`
      return `${(bytesPerSec / (1024 * 1024)).toFixed(2)} MB/s`
    }

    function statusLabel(s: string): string {
      switch (s) {
        case "downloading": return "Downloading"
        case "queued":      return "Queued"
        case "done":        return "Done"
        case "error":       return "Failed"
        case "stalled":     return "Stalled"
        case "paused":      return "Paused"
        case "cancelled":   return "Cancelled"
        default:            return s || "-"
      }
    }

    function statusToneClass(s: string): string {
      switch (s) {
        case "done":      return "text-ok"
        case "error":     return "text-bad"
        case "stalled":   return "text-warn"
        case "paused":    return "text-fg-2"
        case "queued":    return "text-fg-3"
        case "cancelled": return "text-fg-3"
        default:          return "text-accent"
      }
    }

    function statusOrder(s: string): number {
      switch (s) {
        case "downloading": return 0
        case "stalled":     return 1
        case "queued":      return 2
        case "paused":      return 3
        case "error":       return 4
        case "done":        return 5
        default:            return 6
      }
    }

    // ----------------------------
    // Sparkline helpers
    // ----------------------------
    const HISTORY_MAX = 240

    function resolveCssColor(varName: string): string {
      const probe = document.createElement("span")
      probe.style.color = `var(${varName})`
      probe.style.position = "fixed"
      probe.style.visibility = "hidden"
      document.body.appendChild(probe)
      const c = getComputedStyle(probe).color
      probe.remove()
      return c || "rgb(190, 73, 142)"
    }

    let cachedAccent = ""
    let cachedFg3 = ""
    function getAccentRgb(): string {
      if (!cachedAccent) cachedAccent = resolveCssColor("--color-accent")
      return cachedAccent
    }
    function getFg3Rgb(): string {
      if (!cachedFg3) cachedFg3 = resolveCssColor("--color-fg-3")
      return cachedFg3
    }
    const themeObserver = new MutationObserver(() => {
      cachedAccent = ""
      cachedFg3 = ""
    })
    themeObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["style", "data-theme"],
    })

    function withAlpha(rgbColor: string, alpha: number): string {
      const m = rgbColor.match(/(\d+(?:\.\d+)?)/g)
      if (!m || m.length < 3) return rgbColor
      return `rgba(${m[0]}, ${m[1]}, ${m[2]}, ${alpha})`
    }

    function drawSparkline(
      canvas: HTMLCanvasElement,
      samples: number[],
      opts: {
        stroke: string
        fill?: string
        minHeight?: number
        references?: { value: number; color: string }[]
      }
    ) {
      const ctx = canvas.getContext("2d")
      if (!ctx) return
      const dpr = Math.max(1, window.devicePixelRatio || 1)
      const cw = canvas.clientWidth
      const ch = canvas.clientHeight
      if (cw === 0 || ch === 0) return
      const wantW = Math.round(cw * dpr)
      const wantH = Math.round(ch * dpr)
      if (canvas.width !== wantW || canvas.height !== wantH) {
        canvas.width = wantW
        canvas.height = wantH
      }
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0)
      ctx.clearRect(0, 0, cw, ch)

      if (samples.length < 2) return
      const max = Math.max(...samples, opts.minHeight ?? 1)
      const padded =
        samples.length < HISTORY_MAX
          ? Array(HISTORY_MAX - samples.length).fill(0).concat(samples)
          : samples

      const stepX = cw / (HISTORY_MAX - 1)
      const points: Array<[number, number]> = []
      for (let i = 0; i < padded.length; i++) {
        const x = i * stepX
        const y = ch - 2 - (padded[i] / max) * (ch - 4)
        points.push([x, y])
      }

      if (opts.references && opts.references.length) {
        ctx.save()
        ctx.setLineDash([2, 3])
        ctx.lineWidth = 1
        for (const ref of opts.references) {
          if (ref.value <= 0) continue
          const y = ch - 2 - (ref.value / max) * (ch - 4)
          ctx.strokeStyle = ref.color
          ctx.beginPath()
          ctx.moveTo(0, y)
          ctx.lineTo(cw, y)
          ctx.stroke()
        }
        ctx.restore()
      }

      function tracePath(c: CanvasRenderingContext2D) {
        c.beginPath()
        c.moveTo(points[0][0], points[0][1])
        if (points.length === 2) {
          c.lineTo(points[1][0], points[1][1])
          return
        }
        for (let i = 1; i < points.length - 1; i++) {
          const cx = points[i][0]
          const cy = points[i][1]
          const mx = (points[i][0] + points[i + 1][0]) / 2
          const my = (points[i][1] + points[i + 1][1]) / 2
          c.quadraticCurveTo(cx, cy, mx, my)
        }
        const last = points[points.length - 1]
        c.lineTo(last[0], last[1])
      }

      if (opts.fill) {
        tracePath(ctx)
        ctx.lineTo(cw, ch)
        ctx.lineTo(0, ch)
        ctx.closePath()
        const grad = ctx.createLinearGradient(0, 0, 0, ch)
        grad.addColorStop(0, opts.fill)
        grad.addColorStop(1, "rgba(0,0,0,0)")
        ctx.fillStyle = grad
        ctx.fill()
      }

      tracePath(ctx)
      ctx.lineWidth = 1.25
      ctx.strokeStyle = opts.stroke
      ctx.lineJoin = "round"
      ctx.lineCap = "round"
      ctx.stroke()
    }

    function prefersReducedMotion(): boolean {
      return (
        window.matchMedia &&
        window.matchMedia("(prefers-reduced-motion: reduce)").matches
      )
    }

    // ----------------------------
    // Active list (downloading / queued / paused / stalled / error)
    // ----------------------------
    function makeAction(
      label: string,
      ariaLabel: string,
      onClick: () => void,
      tone: "neutral" | "primary" | "danger" = "neutral"
    ): HTMLButtonElement {
      const b = document.createElement("button")
      b.type = "button"
      const toneClass =
        tone === "primary"
          ? "text-accent hover:bg-accent-soft focus-visible:bg-accent-soft"
          : tone === "danger"
          ? "text-bad hover:bg-bad/10 focus-visible:bg-bad/10"
          : "text-fg-3 hover:text-fg hover:bg-surface-2 focus-visible:text-fg focus-visible:bg-surface-2"
      b.className = `rounded-md px-2.5 py-1.5 text-xs min-h-9 transition-colors ${toneClass}`
      b.textContent = label
      b.setAttribute("aria-label", ariaLabel)
      b.addEventListener("click", onClick)
      return b
    }

    function buildActiveActions(d: any, container: HTMLDivElement) {
      container.replaceChildren()
      if (d.status === "downloading") {
        container.append(
          makeAction("Pause", `Pause ${d.title}`, () => pauseDownload(d.id))
        )
      } else if (d.status === "queued") {
        container.append(
          makeAction("Cancel", `Cancel queued ${d.title}`, () =>
            pauseDownload(d.id)
          ),
          makeAction("Remove", `Remove ${d.title}`, () => removeDownload(d.id))
        )
      } else {
        // paused / stalled / error
        container.append(
          makeAction(
            "Resume",
            `Resume ${d.title}`,
            () => resumeDownload(d.id),
            "primary"
          ),
          makeAction("Remove", `Remove ${d.title}`, () => {
            confirmDelete(d, "Remove this download? The partial file will also be deleted.")
          })
        )
      }
    }

    function buildStatusContent(statusEl: HTMLSpanElement, status: string) {
      statusEl.replaceChildren()
      if (status === "downloading") {
        const dot = document.createElement("span")
        dot.className = "dl-status-dot"
        dot.setAttribute("aria-hidden", "true")
        statusEl.appendChild(dot)
      }
      statusEl.appendChild(document.createTextNode(statusLabel(status)))
    }

    function toneClassForBar(s: string): string {
      switch (s) {
        case "error":   return "bg-bad"
        case "stalled": return "bg-warn"
        default:        return "bg-accent"
      }
    }
    const ALL_BAR_TONES = ["bg-bad", "bg-warn", "bg-ok", "bg-accent"]

    type ActiveRow = {
      el: HTMLDivElement
      status: string
      bytesTotal: number
      titleStr: string
      titleEl: HTMLElement
      statusEl: HTMLSpanElement
      sizesEl: HTMLSpanElement
      speedEl: HTMLSpanElement
      sparkCanvas: HTMLCanvasElement
      speedTextEl: HTMLSpanElement
      actionsEl: HTMLDivElement
      barShellEl: HTMLDivElement
      barFillEl: HTMLDivElement | null
      errorEl: HTMLDivElement
    }

    const activeRowsById = new Map<string, ActiveRow>()

    function createActiveRow(d: any): ActiveRow {
      const row = document.createElement("div")
      row.className = "px-4 py-3 flex flex-col gap-1.5"

      const top = document.createElement("div")
      top.className = "flex items-center gap-3"

      const info = document.createElement("div")
      info.className = "flex flex-col min-w-0 flex-1 gap-0.5"

      const href = buildSourceHref(d.source)
      let titleEl: HTMLElement
      if (href) {
        const a = document.createElement("a")
        a.href = href
        a.className =
          "dl-row-title truncate text-sm text-fg font-medium " +
          "hover:text-accent focus-visible:text-accent outline-none"
        titleEl = a
      } else {
        titleEl = document.createElement("div")
        titleEl.className = "dl-row-title truncate text-sm text-fg font-medium"
      }
      titleEl.textContent = d.title

      const meta = document.createElement("div")
      meta.className =
        "dl-row-meta text-xs tabular-nums flex flex-wrap items-center gap-x-2.5 gap-y-0.5"

      const statusEl = document.createElement("span")
      statusEl.className = `font-medium ${statusToneClass(d.status)}`
      buildStatusContent(statusEl, d.status)
      meta.appendChild(statusEl)

      const sizesEl = document.createElement("span")
      sizesEl.className = "text-fg-3"
      meta.appendChild(sizesEl)

      const speedEl = document.createElement("span")
      speedEl.className = "text-fg-3 inline-flex items-center gap-1.5 min-w-0"
      speedEl.style.display = "none"
      const sparkCanvas = document.createElement("canvas")
      sparkCanvas.setAttribute("aria-hidden", "true")
      sparkCanvas.className = "block shrink-0"
      sparkCanvas.style.width = "60px"
      sparkCanvas.style.height = "14px"
      const speedTextEl = document.createElement("span")
      speedTextEl.className = "shrink-0"
      speedEl.append(sparkCanvas, speedTextEl)
      meta.appendChild(speedEl)

      info.append(titleEl, meta)

      const actionsEl = document.createElement("div")
      actionsEl.className = "shrink-0 flex items-center gap-1"
      buildActiveActions(d, actionsEl)

      top.append(info, actionsEl)
      row.appendChild(top)

      const barShellEl = document.createElement("div")
      barShellEl.className =
        "dl-bar-shell h-1 rounded-full bg-bg overflow-hidden ring-1 ring-line"
      const barFillEl = document.createElement("div")
      barFillEl.className = "h-full dl-bar-fill"
      barShellEl.appendChild(barFillEl)
      row.appendChild(barShellEl)

      const errorEl = document.createElement("div")
      errorEl.className = "text-xs text-bad/80 hidden"
      row.appendChild(errorEl)

      const entry: ActiveRow = {
        el: row,
        status: d.status,
        bytesTotal: d.bytesTotal || 0,
        titleStr: d.title,
        titleEl,
        statusEl,
        sizesEl,
        speedEl,
        sparkCanvas,
        speedTextEl,
        actionsEl,
        barShellEl,
        barFillEl,
        errorEl,
      }
      paintActiveRow(entry, d)
      return entry
    }

    function paintActiveRow(entry: ActiveRow, d: any) {
      const prevStatus = entry.status

      if (entry.titleStr !== d.title) {
        entry.titleEl.textContent = d.title
        entry.titleStr = d.title
      }

      if (prevStatus !== d.status) {
        entry.statusEl.className = `font-medium ${statusToneClass(d.status)}`
        buildStatusContent(entry.statusEl, d.status)
        buildActiveActions(d, entry.actionsEl)
      }

      const sizeStr =
        d.bytesTotal > 0
          ? `${fmtSize(d.bytesDone)} / ${fmtSize(d.bytesTotal)}`
          : fmtSize(d.bytesDone)
      entry.sizesEl.textContent = sizeStr

      if (d.status === "downloading") {
        const speed = getRowThroughputEwma(d.id)
        entry.speedTextEl.textContent = fmtSpeed(speed) || "0 B/s"
        entry.speedEl.style.display = ""
        drawSparkline(entry.sparkCanvas, getRowThroughputHistory(d.id), {
          stroke: getAccentRgb(),
          fill: withAlpha(getAccentRgb(), 0.18),
        })
      } else {
        entry.speedTextEl.textContent = ""
        entry.speedEl.style.display = "none"
        if (entry.sparkCanvas.width > 0) {
          entry.sparkCanvas.width = entry.sparkCanvas.width
        }
      }

      const wantsDeterminate = d.bytesTotal > 0
      const wantsIndeterminate = !wantsDeterminate && d.status === "downloading"
      const fill = entry.barFillEl
      if (wantsDeterminate && fill) {
        entry.barShellEl.classList.remove("hidden", "dl-bar-indeterminate")
        const tone = toneClassForBar(d.status)
        for (const c of ALL_BAR_TONES) fill.classList.toggle(c, c === tone)
        fill.classList.toggle("dl-bar-active", d.status === "downloading")
        fill.classList.remove("hidden")
        const pctV = Math.max(
          0,
          Math.min(100, (d.bytesDone / d.bytesTotal) * 100)
        )
        fill.style.width = `${pctV}%`
      } else if (wantsIndeterminate && fill) {
        entry.barShellEl.classList.remove("hidden")
        entry.barShellEl.classList.add("dl-bar-indeterminate")
        for (const c of ALL_BAR_TONES) fill.classList.remove(c)
        fill.classList.remove("dl-bar-active")
        fill.classList.add("hidden")
      } else {
        entry.barShellEl.classList.add("hidden")
        entry.barShellEl.classList.remove("dl-bar-indeterminate")
      }

      if (d.status === "error" && d.error) {
        entry.errorEl.textContent = d.error
        entry.errorEl.classList.remove("hidden")
      } else {
        entry.errorEl.textContent = ""
        entry.errorEl.classList.add("hidden")
      }

      entry.status = d.status
      entry.bytesTotal = d.bytesTotal || 0
    }

    // ----------------------------
    // Done list (completed downloads, primary view)
    // ----------------------------
    type DoneRow = {
      el: HTMLDivElement
      titleStr: string
      titleEl: HTMLElement
      metaEl: HTMLDivElement
      posterImg: HTMLImageElement | null
      bytesTotal: number
    }

    const doneRowsById = new Map<string, DoneRow>()

    function buildSourceHref(source: any): string | null {
      if (!source) return null
      if (source.kind === "vod" && source.id != null) {
        return `/movies/detail?id=${encodeURIComponent(String(source.id))}`
      }
      if (source.kind === "episode" && source.seriesId != null) {
        return `/series/detail?id=${encodeURIComponent(String(source.seriesId))}`
      }
      return null
    }

    function metaForDone(d: any): string {
      const bits: string[] = []
      const src = d.source || {}
      if (src.kind === "vod") bits.push("Movie")
      else if (src.kind === "episode") {
        const s = src.season != null ? `S${src.season}` : ""
        const e = src.episode != null ? `E${src.episode}` : ""
        const tag = (s + e) || ""
        if (src.seriesName) bits.push(tag ? `${src.seriesName} · ${tag}` : src.seriesName)
        else if (tag) bits.push(`Episode · ${tag}`)
        else bits.push("Episode")
      }
      if (d.bytesTotal > 0) bits.push(fmtSize(d.bytesTotal))
      else if (d.bytesDone > 0) bits.push(fmtSize(d.bytesDone))
      return bits.join(" · ")
    }

    function makePosterFallback(title: string): HTMLDivElement {
      const fb = document.createElement("div")
      fb.className =
        "h-full w-full flex items-center justify-center text-center px-1 text-fg-3 text-2xs leading-tight bg-surface-2"
      fb.textContent = title || "File"
      return fb
    }

    function createDoneRow(d: any): DoneRow {
      const row = document.createElement("div")
      row.className = "p-3 sm:p-4 flex items-center gap-3 sm:gap-4"

      // Poster thumbnail (kind-aware, gracefully falls back).
      const posterWrap = document.createElement("div")
      posterWrap.className =
        "shrink-0 w-12 h-16 sm:w-14 sm:h-20 rounded-md overflow-hidden bg-surface-2 ring-1 ring-line"
      let posterImg: HTMLImageElement | null = null
      const logoUrl = d.source?.logo || null
      if (logoUrl) {
        posterImg = document.createElement("img")
        posterImg.src = logoUrl
        posterImg.alt = ""
        posterImg.loading = "lazy"
        posterImg.decoding = "async"
        posterImg.referrerPolicy = "no-referrer"
        posterImg.className = "h-full w-full object-cover"
        posterImg.onerror = () => {
          posterImg?.remove()
          posterWrap.appendChild(makePosterFallback(d.title))
        }
        posterWrap.appendChild(posterImg)
      } else {
        posterWrap.appendChild(makePosterFallback(d.title))
      }

      const info = document.createElement("div")
      info.className = "flex flex-col min-w-0 flex-1 gap-0.5"
      const href = buildSourceHref(d.source)
      let titleEl: HTMLElement
      if (href) {
        const a = document.createElement("a")
        a.href = href
        a.className =
          "dl-row-title truncate text-sm sm:text-base text-fg font-medium " +
          "hover:text-accent focus-visible:text-accent outline-none"
        titleEl = a
      } else {
        titleEl = document.createElement("div")
        titleEl.className =
          "dl-row-title truncate text-sm sm:text-base text-fg font-medium"
      }
      titleEl.textContent = d.title
      const metaEl = document.createElement("div")
      metaEl.className = "dl-row-meta truncate text-xs text-fg-3 tabular-nums"
      metaEl.textContent = metaForDone(d)
      info.append(titleEl, metaEl)

      const actions = document.createElement("div")
      actions.className = "shrink-0 flex items-center gap-1.5"

      const playBtn = document.createElement("button")
      playBtn.type = "button"
      playBtn.setAttribute("aria-label", `Play ${d.title}`)
      playBtn.title = "Play"
      playBtn.className =
        "inline-flex items-center justify-center gap-1.5 rounded-lg bg-accent text-bg " +
        "min-h-11 min-w-11 px-3 text-sm font-semibold " +
        "hover:opacity-90 focus-visible:opacity-90 transition-opacity"
      playBtn.innerHTML =
        '<svg viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true" class="size-4"><path d="M8 5.14v13.72a1 1 0 0 0 1.5.87l11-6.86a1 1 0 0 0 0-1.74l-11-6.86a1 1 0 0 0-1.5.87z"/></svg>' +
        '<span class="hidden sm:inline">Play</span>'
      playBtn.addEventListener("click", () => playDoneRow(d))
      actions.appendChild(playBtn)

      const deleteBtn = document.createElement("button")
      deleteBtn.type = "button"
      deleteBtn.setAttribute("aria-label", `Delete ${d.title}`)
      deleteBtn.title = "Delete"
      deleteBtn.className =
        "inline-flex items-center justify-center rounded-lg border border-line " +
        "min-h-11 min-w-11 p-2 text-fg-3 " +
        "hover:bg-bad/10 hover:text-bad hover:border-bad/40 " +
        "focus-visible:bg-bad/10 focus-visible:text-bad focus-visible:border-bad " +
        "transition-colors"
      deleteBtn.innerHTML =
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="size-4"><path d="M4 7h16"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2l1-12"/><path d="M9 7V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v3"/></svg>'
      deleteBtn.addEventListener("click", () => confirmDelete(d))
      actions.appendChild(deleteBtn)

      row.append(posterWrap, info, actions)

      return {
        el: row,
        titleStr: d.title,
        titleEl,
        metaEl,
        posterImg,
        bytesTotal: d.bytesTotal || 0,
      }
    }

    function paintDoneRow(entry: DoneRow, d: any) {
      if (entry.titleStr !== d.title) {
        entry.titleEl.textContent = d.title
        entry.titleStr = d.title
      }
      entry.metaEl.textContent = metaForDone(d)
      entry.bytesTotal = d.bytesTotal || 0
    }

    // ----------------------------
    // Throughput strip
    // ----------------------------
    function updateAggregateStrip() {
      if (!throughputSection || !throughputCanvas || !throughputNowEl) return
      const history = getAggregateThroughputHistory()
      const ewma = getAggregateThroughputEwma()
      const anyActive = listDownloads().some((d) => d.status === "downloading")

      if (!anyActive && history.length === 0) {
        throughputSection.setAttribute("hidden", "")
        if (throughputMinEl) throughputMinEl.textContent = "-"
        if (throughputMaxEl) throughputMaxEl.textContent = "-"
        return
      }

      if (throughputSection.hasAttribute("hidden")) {
        throughputSection.removeAttribute("hidden")
        if (!prefersReducedMotion()) {
          throughputSection.animate(
            [{ opacity: 0, transform: "translateY(-4px)" }, { opacity: 1, transform: "translateY(0)" }],
            { duration: 320, easing: "cubic-bezier(0.16, 1, 0.3, 1)" }
          )
        }
      }
      throughputNowEl.textContent = fmtSpeed(ewma) || "0 B/s"

      let mn = Infinity
      let mx = 0
      const MIN_FLOOR = 256
      for (const v of history) {
        if (v < MIN_FLOOR) continue
        if (v < mn) mn = v
        if (v > mx) mx = v
      }
      const haveRange = mx > 0 && mn !== Infinity
      if (throughputMinEl) {
        throughputMinEl.textContent = haveRange ? fmtSpeed(mn) : "-"
      }
      if (throughputMaxEl) {
        throughputMaxEl.textContent = haveRange ? fmtSpeed(mx) : "-"
      }

      const refs = haveRange
        ? [
            { value: mx, color: withAlpha(getFg3Rgb(), 0.5) },
            { value: mn, color: withAlpha(getFg3Rgb(), 0.35) },
          ]
        : undefined

      drawSparkline(throughputCanvas, history, {
        stroke: getAccentRgb(),
        fill: withAlpha(getAccentRgb(), 0.22),
        references: refs,
      })
    }

    // ----------------------------
    // Play handoff. Android still goes through the system chooser; on
    // every other platform we navigate to the source's detail page with
    // ?autoplay=1, where the inline player is wired up. Reusing the
    // detail page keeps the layout consistent with the rest of the app
    // (poster -> player swap, ambient backdrop, back button) and means
    // the Video.js bundle only ships from one place.
    async function playDoneRow(d: any) {
      if (await tryAndroidIntentPlayback(d.url)) return

      const src = d.source
      if (src?.kind === "vod" && src.id != null) {
        location.href =
          `/movies/detail?id=${encodeURIComponent(String(src.id))}&autoplay=1`
        return
      }
      if (src?.kind === "episode" && src.seriesId != null) {
        const epId = src.id != null ? `&episode=${encodeURIComponent(String(src.id))}` : ""
        location.href =
          `/series/detail?id=${encodeURIComponent(String(src.seriesId))}&autoplay=1${epId}`
        return
      }

      // Older download records (pre-source-metadata) have no kind/id to
      // route to. Fall back to opening the saved URL directly so the user
      // still gets *something*.
      window.open(d.url, "_blank", "noopener,noreferrer")
    }

    // ----------------------------
    // Delete confirm
    // ----------------------------
    let pendingDeleteId: string | null = null

    function confirmDelete(d: any, message?: string) {
      if (!deleteDlg) {
        if (confirm(message || `Delete "${d.title}"? The file will also be removed.`)) {
          removeDownload(d.id)
        }
        return
      }
      pendingDeleteId = d.id
      if (deleteBodyEl) {
        deleteBodyEl.textContent =
          message || `"${d.title}" will be removed from disk.`
      }
      if (typeof deleteDlg.showModal === "function") deleteDlg.showModal()
      else deleteDlg.setAttribute("open", "")
    }

    deleteCancelBtn?.addEventListener("click", () => deleteDlg?.close?.())
    deleteDlg?.addEventListener("click", (e) => {
      if (e.target === deleteDlg) deleteDlg.close()
    })
    deleteDlg?.addEventListener("close", () => {
      pendingDeleteId = null
    })
    deleteConfirmBtn?.addEventListener("click", () => {
      const id = pendingDeleteId
      deleteDlg?.close?.()
      if (id) removeDownload(id)
    })

    // ----------------------------
    // Render orchestration
    // ----------------------------
    function renderList() {
      const list = listDownloads().slice()

      const active = list
        .filter(
          (d) =>
            d.status !== "done" &&
            d.status !== "cancelled"
        )
        .sort((a, b) => statusOrder(a.status) - statusOrder(b.status))
      const done = list
        .filter((d) => d.status === "done")
        .sort(
          (a, b) =>
            (b.startedAt || 0) - (a.startedAt || 0)
        )

      // Active section
      if (activeListEl && activeSection) {
        const currentIds = new Set<string>()
        for (const d of active) currentIds.add(d.id)
        for (const [id, entry] of activeRowsById) {
          if (!currentIds.has(id)) {
            entry.el.remove()
            activeRowsById.delete(id)
          }
        }
        for (const d of active) {
          let entry = activeRowsById.get(d.id)
          if (!entry) {
            entry = createActiveRow(d)
            activeRowsById.set(d.id, entry)
          } else {
            paintActiveRow(entry, d)
          }
        }
        // Re-append in sort order to keep DOM in sync.
        for (const d of active) {
          const entry = activeRowsById.get(d.id)
          if (entry) activeListEl.appendChild(entry.el)
        }

        if (active.length > 0) activeSection.removeAttribute("hidden")
        else activeSection.setAttribute("hidden", "")
      }

      // Done section
      if (doneListEl) {
        const emptyEl = doneListEl.querySelector("[data-empty]")
        if (done.length === 0) {
          for (const [id, entry] of doneRowsById) {
            entry.el.remove()
            doneRowsById.delete(id)
          }
          if (emptyEl) (emptyEl as HTMLElement).hidden = false
        } else {
          if (emptyEl) (emptyEl as HTMLElement).hidden = true
          const currentIds = new Set<string>()
          for (const d of done) currentIds.add(d.id)
          for (const [id, entry] of doneRowsById) {
            if (!currentIds.has(id)) {
              entry.el.remove()
              doneRowsById.delete(id)
            }
          }
          for (const d of done) {
            let entry = doneRowsById.get(d.id)
            if (!entry) {
              entry = createDoneRow(d)
              doneRowsById.set(d.id, entry)
            } else {
              paintDoneRow(entry, d)
            }
          }
          for (const d of done) {
            const entry = doneRowsById.get(d.id)
            if (entry) doneListEl.appendChild(entry.el)
          }
        }
      }

      if (doneCountEl) {
        doneCountEl.textContent = done.length > 0 ? `${done.length}` : ""
      }

      if (summaryEl) {
        if (list.length === 0) {
          summaryEl.textContent =
            "Movies and series episodes you save will appear here."
        } else {
          const bits: string[] = []
          const downloadingN = active.filter(
            (d) => d.status === "downloading" || d.status === "stalled"
          ).length
          const queuedN = active.filter((d) => d.status === "queued").length
          const pausedN = active.filter(
            (d) => d.status === "paused" || d.status === "error"
          ).length
          if (downloadingN) bits.push(`${downloadingN} active`)
          if (queuedN) bits.push(`${queuedN} queued`)
          if (pausedN) bits.push(`${pausedN} paused`)
          if (done.length) bits.push(`${done.length} downloaded`)
          summaryEl.textContent = bits.join(" · ") || "Nothing pending."
        }
      }

      try { window.SpatialNavigation?.makeFocusable?.() } catch {}
      updateAggregateStrip()
    }

    renderList()

    document.addEventListener(DOWNLOADS_LIST_EVENT, renderList)
    document.addEventListener(DOWNLOAD_PROGRESS_EVENT, renderList)
    document.addEventListener(THROUGHPUT_EVENT, renderList)
  </script>
</Layout>
