---
import Layout from "@/layouts/Layout.astro"
import AllFavoritesView from "@/components/AllFavoritesView.svelte"
---

<Layout pageTitle="Favorites">
  <main
    class="w-full max-w-480 mx-auto px-4 md:px-6 lg:px-8 pt-4 lg:pt-6 md:landscape:pt-6 pb-6
           flex flex-col gap-4 flex-1 min-h-0">

    <header class="route-hero shrink-0">
      <h1 class="route-hero__title">F<em>a</em>vorites</h1>
      <p class="route-hero__sub">
        Every starred channel, movie, and series across all your playlists.
        Opening a favorite from a different playlist switches you over first.
      </p>
    </header>

    <AllFavoritesView client:load />

    <div
      id="app-version"
      class="fixed bottom-[max(0.5rem,env(safe-area-inset-bottom))] right-[max(0.75rem,env(safe-area-inset-right))] text-2xs text-fg-3 opacity-70 tabular-nums pointer-events-none">
      Loading…
    </div>
  </main>

  <script>
    import "@/scripts/updater-startup.js"
    import { injectVersion } from "@/scripts/version.js"
    injectVersion()
  </script>
</Layout>
