---
import Layout from "@/layouts/Layout.astro";
import SearchView from "@/components/SearchView.svelte";
---

<Layout pageTitle="Search">
  <main
    class="w-full max-w-3xl mx-auto px-4 md:px-6 lg:px-8 pt-4 lg:pt-6 pb-6
           flex flex-col gap-4 flex-1 min-h-0">
    <header class="route-hero shrink-0">
      <h1 class="route-hero__title">Find <em>anything</em></h1>
      <p class="route-hero__sub">
        Channels, movies, and series from the active playlist. Press
        <kbd class="rounded border border-line bg-surface px-1.5 py-0.5 text-[0.6875rem] font-medium tabular-nums text-fg-2 align-baseline">Ctrl K</kbd>
        from anywhere to jump back here.
      </p>
    </header>

    <SearchView client:load focusOnMount={true} />
  </main>
</Layout>
