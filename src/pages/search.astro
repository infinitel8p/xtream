---
import Layout from "@/layouts/Layout.astro";
import SearchView from "@/components/SearchView.svelte";
---

<Layout pageTitle="Search">
  <main
    class="w-full max-w-3xl mx-auto px-4 md:px-6 lg:px-8 pt-4 lg:pt-6 pb-6
           flex flex-col gap-4 flex-1 min-h-0">
    <header class="shrink-0 flex flex-col gap-1">
      <h1 class="text-base font-semibold text-fg">Search</h1>
      <p class="text-xs text-fg-3">
        Channels, movies, and series from the active playlist.
      </p>
    </header>

    <SearchView client:load focusOnMount={true} />
  </main>
</Layout>
