---
import Layout from "@/layouts/Layout.astro";
import SearchInput from "@/components/SearchInput.astro";
import { IconDeviceTv, IconChevronDown, IconCalendarTime, IconLayoutGrid } from "@tabler/icons-svelte";
---

<Layout pageTitle="Live TV">
	<main
		class="w-full max-w-[120rem] mx-auto px-4 md:px-6 lg:px-8 pt-4 lg:pt-6 md:landscape:pt-6 pb-6
			flex flex-col gap-4 flex-1 min-h-0">

		<section
			class="flex flex-col md:landscape:flex-row lg:flex-row gap-4 flex-1 min-h-0">

			<!-- Channels (bottom on mobile, left column on desktop) -->
			<aside
				class="order-2 md:landscape:order-1 lg:order-1
					md:landscape:w-[var(--xt-channels-w,24rem)] lg:w-[var(--xt-channels-w,28rem)]
					md:landscape:shrink-0 lg:shrink-0 min-h-0">
				<div
					class="rounded-2xl border border-line bg-surface p-3 h-full flex flex-col gap-3 min-h-0">

					<div class="flex gap-2 shrink-0">
						<button
							id="category-picker-trigger"
							type="button"
							aria-haspopup="dialog"
							aria-controls="category-picker-dialog"
							class="rounded-xl border border-line bg-bg px-3.5 py-2 min-h-11 text-sm flex items-center gap-2 text-left flex-1 min-w-0
								hover:bg-surface-2 focus-visible:bg-surface-2 focus-visible:border-accent
								transition-colors">
							<span class="text-fg-3 shrink-0">Category</span>
							<span
								id="category-picker-label"
								class="text-fg truncate flex-1">All categories</span>
							<IconChevronDown
								aria-hidden="true"
								stroke={2}
								class="size-4 text-fg-3 shrink-0"
							/>
						</button>
						<button
							id="epg-toggle"
							type="button"
							aria-pressed="true"
							aria-label="Show EPG for the current channel"
							title="Show EPG"
							class="rounded-xl border border-line bg-bg px-3.5 py-2 min-h-11 min-w-11 text-sm text-fg-2 inline-flex items-center justify-center gap-2 shrink-0
								hover:bg-surface-2 focus-visible:bg-surface-2 focus-visible:border-accent
								aria-pressed:border-accent aria-pressed:bg-surface-2 aria-pressed:text-fg
								transition-colors">
							<IconCalendarTime
								aria-hidden="true"
								stroke={2}
								class="size-4"
							/>
							<span class="hidden sm:inline">EPG</span>
						</button>
						<a
							href="/epg"
							aria-label="Open the full EPG schedule grid"
							title="Open schedule grid"
							class="rounded-xl border border-line bg-bg px-3.5 py-2 min-h-11 min-w-11 text-sm text-fg-2 inline-flex items-center justify-center shrink-0
								hover:bg-surface-2 focus-visible:bg-surface-2 focus-visible:border-accent
								transition-colors">
							<IconLayoutGrid
								aria-hidden="true"
								stroke={2}
								class="size-4"
							/>
							<span class="sr-only">Schedule grid</span>
						</a>
					</div>

					<SearchInput
						id="search"
						label="Search channels"
						placeholder="Search channels…"
						clearButtonId="clear-search"
					/>

					<div
						id="list"
						class="relative flex-1 min-h-0 overflow-auto pr-1 custom-scroll
							max-h-96 md:landscape:max-h-[100dvh] lg:max-h-[100dvh]">
						<div id="spacer"></div>
						<div id="viewport" class="absolute inset-x-0 top-0"></div>
					</div>

					<div
						id="list-status"
						class="px-2.5 text-sm text-fg-3 tabular-nums shrink-0">
						No playlist selected.
					</div>
				</div>
			</aside>

			<!-- Player + EPG (top on mobile, right column on desktop/landscape) -->
			<section
				class="order-1 md:landscape:order-2 lg:order-2
					md:landscape:flex-1 lg:flex-1 min-w-0 min-h-0">
				<div
					class="rounded-2xl border border-line bg-surface p-3 h-full flex flex-col gap-3 min-h-0">
					<div
						class="aspect-video w-full mx-auto overflow-hidden rounded-xl bg-black ring-1 ring-line flex items-center justify-center shrink-0 relative"
						style="max-height: 60dvh; max-width: calc(60dvh * 16 / 9);">
						<div
							id="player-empty"
							class="absolute inset-0 flex flex-col items-center justify-center gap-6 text-center px-6 pointer-events-none">
							<div class="player-empty-glow" aria-hidden="true"></div>
							<IconDeviceTv
								aria-hidden="true"
								stroke={0.6}
								class="size-24 sm:size-28 lg:size-36 text-fg-3/55 relative z-10"
							/>
							<div class="flex flex-col gap-2.5 relative z-10">
								<span class="inline-flex items-center gap-2 self-center text-eyebrow font-semibold uppercase tracking-[0.22em] text-fg-3">
									<span aria-hidden="true" class="size-1.5 rounded-full bg-accent shadow-[0_0_0_4px_var(--color-accent-soft)]"></span>
									Idle
								</span>
								<p class="text-fg leading-[0.95] tracking-[-0.03em] font-bold"
									style="font-size: clamp(1.75rem, 3vw + 1rem, 3.5rem);">
									Pick a <em class="not-italic text-accent">channel</em>.
								</p>
								<p class="text-fg-3 text-xs sm:text-sm">
									Choose from the list, or change category.
								</p>
							</div>
						</div>
						<video
							id="player"
							class="video-js vjs-default-skin vjs-big-play-centered h-full w-full"
							controls
							hidden
							playsinline></video>
					</div>

					<div
						id="current"
						class="flex items-center justify-between gap-2 text-sm text-fg-2 shrink-0">
						<div class="flex items-center gap-2 min-w-0">
							<span class="status-badge status-badge--off">OFF</span>
							<span class="truncate">-</span>
						</div>
					</div>

					<div
						id="epg"
						class="border-t border-line pt-3 flex-1 min-h-0 overflow-auto custom-scroll">
						<div class="mb-2 text-sm font-medium text-fg">EPG</div>
						<div id="epg-list" class="space-y-2 text-sm"></div>
					</div>
				</div>
			</section>
		</section>

		<!-- Categories popover -->
		<dialog
			id="category-picker-dialog"
			aria-labelledby="category-picker-title"
			class="fixed inset-0 m-auto rounded-2xl border border-line bg-surface text-fg p-0
				w-[min(34rem,calc(100vw-2rem))] h-[min(80dvh,42rem)]
				backdrop:bg-black/60">
			<div class="flex flex-col h-full p-4 gap-3">
				<div class="flex items-center justify-between gap-3 shrink-0">
					<h2
						id="category-picker-title"
						class="text-base font-semibold">
						Choose a category
					</h2>
					<button
						id="category-picker-close"
						type="button"
						class="rounded-lg border border-line px-3 py-1.5 text-xs text-fg-2
							hover:bg-surface-2 focus-visible:bg-surface-2 focus-visible:border-accent">
						Close
					</button>
				</div>

				<SearchInput
					id="category-search"
					label="Search categories"
					placeholder="Search categories…"
					clearButtonId="category-clear-search"
				/>

				<div
					role="radiogroup"
					aria-label="Category filter mode"
					class="cat-mode-toggle flex p-0.5 rounded-lg border border-line bg-surface-2 text-xs shrink-0">
					<button
						id="category-mode-hide"
						type="button"
						role="radio"
						aria-checked="true"
						data-mode="hide"
						class="flex-1 rounded-md px-3 py-1.5 font-medium transition-colors text-fg-2
							hover:text-fg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent
							aria-checked:bg-surface aria-checked:text-fg aria-checked:shadow-sm">
						Hide selected
					</button>
					<button
						id="category-mode-select"
						type="button"
						role="radio"
						aria-checked="false"
						data-mode="select"
						class="flex-1 rounded-md px-3 py-1.5 font-medium transition-colors text-fg-2
							hover:text-fg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent
							aria-checked:bg-surface aria-checked:text-fg aria-checked:shadow-sm">
						Show only selected
					</button>
				</div>

				<div
					id="category-select-actions"
					hidden
					class="flex flex-wrap items-center gap-2 text-xs shrink-0">
					<button
						id="category-show-selected"
						type="button"
						aria-pressed="false"
						class="inline-flex items-center gap-1.5 rounded-lg border border-line px-2.5 py-1 text-fg-2
							hover:text-fg hover:bg-surface-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent
							aria-pressed:bg-accent-soft aria-pressed:text-fg aria-pressed:border-accent">
						<span class="cat-show-selected-box inline-flex size-3.5 items-center justify-center rounded-sm border border-fg-3 transition-colors">
							<svg class="cat-show-selected-tick" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="10" height="10"><polyline points="20 6 9 17 4 12"/></svg>
						</span>
						Show selected only
					</button>
					<span class="ml-auto inline-flex items-center gap-3">
						<button
							id="category-select-all"
							type="button"
							class="text-accent hover:underline focus-visible:underline focus-visible:outline-none">
							Select all visible
						</button>
						<button
							id="category-select-clear"
							type="button"
							class="text-fg-3 hover:text-fg focus-visible:text-fg focus-visible:outline-none">
							Clear
						</button>
					</span>
				</div>

				<div
					id="category-list"
					class="relative flex-1 min-h-0 overflow-auto custom-scroll">
					<div id="category-viewport"></div>
				</div>

				<div
					id="category-list-status"
					class="px-2.5 text-sm text-fg-3 tabular-nums shrink-0">
					No playlist selected.
				</div>
			</div>
		</dialog>

		<div
			id="app-version"
			class="fixed bottom-[max(0.5rem,env(safe-area-inset-bottom))] right-[max(0.75rem,env(safe-area-inset-right))] text-2xs text-fg-3 opacity-70 tabular-nums pointer-events-none">
			Loading…
		</div>
	</main>

	<script>
		import "../scripts/stream/stream.js";
		import "../scripts/updater-startup.js";
		import { injectVersion } from "../scripts/version.js";
		import { attachDialogSpatialNav } from "../scripts/lib/dialog-spatial-nav.js";
		injectVersion();

		const trigger = document.getElementById("category-picker-trigger");
		const dlg = /** @type {HTMLDialogElement|null} */ (
			document.getElementById("category-picker-dialog")
		);
		if (dlg) attachDialogSpatialNav(dlg, { defaultElement: "#category-search" });
		const closeBtn = document.getElementById("category-picker-close");
		const labelEl = document.getElementById("category-picker-label");
		const categoryList = document.getElementById("category-list");
		const categorySearch = /** @type {HTMLInputElement|null} */ (
			document.getElementById("category-search")
		);

		const readActive = () => {
			try {
				return localStorage.getItem("xt_active_cat") || "";
			} catch {
				return "";
			}
		};

		const syncLabel = () => {
			if (!labelEl) return;
			const cat = readActive();
			if (cat === "__favorites__") labelEl.textContent = "★ Favorites";
			else if (cat === "__recents__") labelEl.textContent = "🕒 Recently watched";
			else labelEl.textContent = cat || "All categories";
		};

		trigger?.addEventListener("click", () => {
			if (!dlg) return;
			if (typeof dlg.showModal === "function") dlg.showModal();
			else dlg.setAttribute("open", "");
			setTimeout(() => {
				window.SpatialNavigation?.makeFocusable?.();
				categorySearch?.focus();
				categorySearch?.select?.();
			}, 0);
		});

		closeBtn?.addEventListener("click", () => dlg?.close?.());

		categoryList?.addEventListener("click", (e) => {
			const t = /** @type {HTMLElement} */ (e.target);
			if (!t.closest("button[role='option']")) return;
			queueMicrotask(() => {
				if (dlg?.open) dlg.close();
			});
		});

		dlg?.addEventListener("click", (e) => {
			if (e.target === dlg) dlg.close();
		});

		dlg?.addEventListener("close", () => {
			syncLabel();
			trigger?.focus();
		});

		document.addEventListener("xt:cat-changed", syncLabel);

		syncLabel();

		const playerEl = document.getElementById("player");
		const playerEmpty = document.getElementById("player-empty");
		if (playerEl && playerEmpty) {
			const sync = () => {
				playerEmpty.style.display = playerEl.hasAttribute("hidden") ? "" : "none";
			};
			sync();
			new MutationObserver(sync).observe(playerEl, {
				attributes: true,
				attributeFilter: ["hidden"],
			});
		}

		const epgToggle = /** @type {HTMLButtonElement|null} */ (
			document.getElementById("epg-toggle")
		);
		const epgPanel = document.getElementById("epg");
		if (epgToggle && epgPanel) {
			const KEY_VISIBLE = "xt_epg_visible";
			const KEY_DEFAULT = "xt_epg_open_default";

			const readDefault = () => {
				try {
					const v = localStorage.getItem(KEY_DEFAULT);
					return v === null ? true : v === "true";
				} catch {
					return true;
				}
			};
			const readVisible = () => {
				try {
					const v = localStorage.getItem(KEY_VISIBLE);
					return v === null ? readDefault() : v === "true";
				} catch {
					return true;
				}
			};

			const apply = (visible) => {
				epgPanel.classList.toggle("hidden", !visible);
				epgToggle.setAttribute("aria-pressed", String(visible));
			};

			apply(readVisible());

			epgToggle.addEventListener("click", () => {
				const next = epgToggle.getAttribute("aria-pressed") !== "true";
				try {
					localStorage.setItem(KEY_VISIBLE, String(next));
				} catch {}
				apply(next);
			});
		}
	</script>
</Layout>
