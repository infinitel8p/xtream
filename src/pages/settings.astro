    // ---------------------------------------------------------------------
    // Theme: light / dark / system. Persisted to xt_theme; applied by the
    // inline script in <head> on page load. CSS uses `light-dark()` so the
    // single `colorScheme` property on :root drives the whole palette.
    // ---------------------------------------------------------------------
    const themeGroup = document.getElementById("settings-theme")
    function readTheme() {
      try {
        return localStorage.getItem("xt_theme") || "dark"
      } catch {
        return "dark"
      }
    }
    function commitTheme(t) {
      if (t === "light") document.documentElement.style.colorScheme = "light"
      else if (t === "dark") document.documentElement.style.colorScheme = "dark"
      else document.documentElement.style.colorScheme = ""
      try {
        localStorage.setItem("xt_theme", t)
      } catch {}
      try {
        window.__applyAndroidStatusBar?.(t)
      } catch {}
      syncThemeButtons()
    }
    function applyTheme(t, originX, originY) {
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches
      const supportsVT = typeof document.startViewTransition === "function"
      if (!supportsVT || reduceMotion) {
        commitTheme(t)
        return
      }
      const root = document.documentElement
      const x = Number.isFinite(originX) ? originX : window.innerWidth / 2
      const y = Number.isFinite(originY) ? originY : window.innerHeight / 2
      const farX = Math.max(x, window.innerWidth - x)
      const farY = Math.max(y, window.innerHeight - y)
      const radius = Math.hypot(farX, farY)
      root.style.setProperty("--xt-theme-x", `${x}px`)
      root.style.setProperty("--xt-theme-y", `${y}px`)
      root.style.setProperty("--xt-theme-r", `${radius}px`)
      root.classList.add("xt-theme-switching")
      const transition = document.startViewTransition(() => commitTheme(t))
      transition.finished.finally(() => {
        root.classList.remove("xt-theme-switching")
        root.style.removeProperty("--xt-theme-x")
        root.style.removeProperty("--xt-theme-y")
        root.style.removeProperty("--xt-theme-r")
      })
    }
    function syncThemeButtons() {
      const current = readTheme()
      for (const btn of themeGroup?.querySelectorAll(".theme-btn") || []) {
        btn.setAttribute("aria-pressed", String(btn.dataset.theme === current))
      }
    }
    themeGroup?.addEventListener("click", (event) => {
      const target = /** @type {HTMLElement} */ (event.target)
      const btn = target.closest(".theme-btn")
      if (!btn) return
      applyTheme(btn.dataset.theme || "system", event.clientX, event.clientY)
    })
    syncThemeButtons()

