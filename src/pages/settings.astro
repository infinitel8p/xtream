---
import Layout from "@/layouts/Layout.astro"
import {
  IconRefresh,
  IconTrash,
  IconAlertTriangle,
  IconPlus,
  IconFolderOpen,
  IconCloudDownload,
  IconBrandGithub,
  IconDeviceFloppy,
  IconDownload,
  IconUpload,
  IconHeart,
  IconCoffee,
  IconBrandPaypal,
  IconBug,
  IconMail,
  IconChevronDown,
  IconWorld,
  IconPalette,
  IconLayoutSidebar,
  IconClock,
  IconWifi,
  IconFilter,
  IconStar,
  IconArchive,
  IconDatabase,
  IconBrandDiscord,
  IconInfoCircle,
  IconSparkles,
  IconBolt,
} from "@tabler/icons-svelte"
import HiddenCategoriesEditor from "@/components/HiddenCategoriesEditor.svelte"
import LocalePicker from "@/components/LocalePicker.svelte"
import FavoritesReorder from "@/components/FavoritesReorder.svelte"
---

<Layout pageTitle="Settings">
  <main class="flex-1 min-h-0 overflow-y-auto overflow-x-clip custom-scroll">
    <div
      class="settings-stack w-full max-w-480 mx-auto px-4 md:px-6 lg:px-8 pt-4 lg:pt-6 pb-12">

    <header class="route-hero shrink-0">
      <h1 data-i18n="settings.title" class="route-hero__title">Settings</h1>
      <p data-i18n="page.settings.sub" class="route-hero__sub">
        Playlists, preferences, cache, and the app itself.
      </p>
    </header>

    <!-- Group: Playlists -->
    <section class="settings-group">
      <h2 data-i18n="settings.group.playlists" class="settings-group__title">Playlists</h2>
      <div class="rounded-2xl border border-line bg-surface p-5 sm:p-6 flex flex-col gap-4">
        <div
          id="settings-playlists"
          class="flex flex-col divide-y divide-line/60 rounded-xl border border-line bg-bg overflow-hidden">
          <div data-i18n="settings.playlists.empty" class="px-4 py-4 text-xs text-fg-3">No playlists yet.</div>
        </div>
        <div class="flex flex-wrap gap-2 pt-1">
          <a href="/login" class="btn">
            <IconPlus aria-hidden="true" class="btn-icon" />
            <span data-i18n="playlist.add">Add playlist</span>
          </a>
          <button
            id="settings-refresh-active"
            type="button"
            class="btn hidden">
            <IconRefresh aria-hidden="true" class="btn-icon" />
            <span data-i18n="playlist.refreshActive">Refresh active</span>
          </button>
        </div>
      </div>
    </section>

    <!-- Group: Preferences -->
    <section class="settings-group">
      <h2 data-i18n="settings.group.preferences" class="settings-group__title">Preferences</h2>
      <div class="flex flex-col gap-4">

        <!-- Language -->
        <article class="icon-mark-host rounded-2xl border border-line bg-surface p-5 sm:p-6 flex flex-col gap-4">
          <div class="flex items-start gap-3">
            <span class="icon-mark">
              <IconWorld aria-hidden="true" stroke={2} />
            </span>
            <div class="flex flex-col gap-1 min-w-0">
              <h3 data-i18n="settings.section.language" class="text-base font-semibold">Language</h3>
              <p data-i18n="settings.language.cardHelper" class="text-xs text-fg-3">
                Pick a language for the interface. Translations are community-driven - missing strings fall back to English.
              </p>
            </div>
          </div>
          <LocalePicker client:load />
        </article>

        <!-- Display: theme + font scale -->
        <article class="icon-mark-host rounded-2xl border border-line bg-surface p-5 sm:p-6 flex flex-col gap-4">
          <div class="flex items-start gap-3">
            <span class="icon-mark">
              <IconPalette aria-hidden="true" stroke={2} />
            </span>
            <div class="flex flex-col gap-1 min-w-0">
              <h3 data-i18n="settings.section.display" class="text-base font-semibold">Display</h3>
              <p data-i18n="settings.display.helper" class="text-xs text-fg-3">
                Theme and base font size. System theme follows your OS preference.
              </p>
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <span data-i18n="settings.theme.label" class="text-eyebrow font-medium uppercase text-fg-3">Theme</span>
            <div
              id="settings-theme"
              class="flex flex-wrap gap-2"
              role="radiogroup"
              data-i18n-attr="aria-label:settings.theme.label"
              aria-label="Theme">
              <button type="button" data-theme="system" aria-pressed="false" data-i18n="settings.theme.system" class="theme-btn btn">System</button>
              <button type="button" data-theme="light"  aria-pressed="false" data-i18n="settings.theme.light" class="theme-btn btn">Light</button>
              <button type="button" data-theme="dark"   aria-pressed="false" data-i18n="settings.theme.dark" class="theme-btn btn">Dark</button>
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <span data-i18n="settings.fontScale.label" class="text-eyebrow font-medium uppercase text-fg-3">Font scale</span>
            <p data-i18n="settings.fontScale.helper" class="text-xs text-fg-3">
              Bumps the base font size. Use Large or X-Large when viewing on a TV from across the room.
            </p>
            <div
              id="settings-font-scale"
              class="flex flex-wrap gap-2"
              role="radiogroup"
              data-i18n-attr="aria-label:settings.fontScale.label"
              aria-label="Font scale">
              <button type="button" data-scale="1"     aria-pressed="false" data-i18n="settings.fontScale.default" class="font-scale-btn btn">Default</button>
              <button type="button" data-scale="1.125" aria-pressed="false" data-i18n="settings.fontScale.medium" class="font-scale-btn btn">Medium</button>
              <button type="button" data-scale="1.25"  aria-pressed="false" data-i18n="settings.fontScale.large" class="font-scale-btn btn">Large</button>
              <button type="button" data-scale="1.5"   aria-pressed="false" data-i18n="settings.fontScale.xlarge" class="font-scale-btn btn">X-Large</button>
            </div>
          </div>
          <script is:inline>
            try {
              var savedFontScale = parseFloat(localStorage.getItem("xt_font_scale") || "1");
              if (!isFinite(savedFontScale) || savedFontScale < 0.75 || savedFontScale > 2) savedFontScale = 1;
              var fontScaleGroup = document.getElementById("settings-font-scale");
              if (fontScaleGroup) {
                var fontScaleBtns = fontScaleGroup.querySelectorAll(".font-scale-btn");
                for (var i = 0; i < fontScaleBtns.length; i++) {
                  var btnScale = parseFloat(fontScaleBtns[i].getAttribute("data-scale") || "1");
                  fontScaleBtns[i].setAttribute("aria-pressed", Math.abs(btnScale - savedFontScale) < 0.001 ? "true" : "false");
                }
              }
              var currentTheme = localStorage.getItem("xt_theme") || "dark";
              var themeGroup = document.getElementById("settings-theme");
              if (themeGroup) {
                var themeBtns = themeGroup.querySelectorAll(".theme-btn");
                for (var j = 0; j < themeBtns.length; j++) {
                  themeBtns[j].setAttribute("aria-pressed", themeBtns[j].getAttribute("data-theme") === currentTheme ? "true" : "false");
                }
              }
            } catch (e) {}
          </script>
        </article>

        <!-- Performance mode: skip decorative animations + focus-glide for low-end TV WebViews -->
        <article class="icon-mark-host rounded-2xl border border-line bg-surface p-5 sm:p-6 flex flex-col gap-4">
          <div class="flex items-start gap-3">
            <span class="icon-mark">
              <IconBolt aria-hidden="true" stroke={2} />
            </span>
            <div class="flex flex-col gap-1 min-w-0">
              <h3 data-i18n="settings.perfMode.title" class="text-base font-semibold">Performance mode</h3>
              <p data-i18n="settings.perfMode.helperLong" class="text-xs text-fg-3">
                Disables decorative animations (the comet in the sidebar, hub entry stagger, sliding focus ring) for smoother scrolling and D-pad navigation on TV boxes and low-end devices.
              </p>
            </div>
          </div>
          <div class="flex flex-col gap-2">
            <span data-i18n="settings.perfMode.label" class="text-eyebrow font-medium uppercase text-fg-3">Performance mode</span>
            <div
              id="settings-perf-mode"
              class="flex flex-wrap gap-2"
              role="radiogroup"
              aria-label="Performance mode"
              data-i18n-attr="aria-label:settings.perfMode.label">
              <button type="button" data-perf="on"  aria-pressed="false" data-i18n="settings.perfMode.on"  class="perf-mode-btn btn">On</button>
              <button type="button" data-perf="off" aria-pressed="false" data-i18n="settings.perfMode.off" class="perf-mode-btn btn">Off</button>
            </div>
          </div>
          <script is:inline>
            try {
              var perfOn = localStorage.getItem("xt_perf_mode") === "1";
              var perfGroup = document.getElementById("settings-perf-mode");
              if (perfGroup) {
                var perfBtns = perfGroup.querySelectorAll(".perf-mode-btn");
                for (var pIdx = 0; pIdx < perfBtns.length; pIdx++) {
                  var perfBtnOn = perfBtns[pIdx].getAttribute("data-perf") === "on";
                  perfBtns[pIdx].setAttribute("aria-pressed", perfBtnOn === perfOn ? "true" : "false");
                }
              }
            } catch (e) {}
          </script>
        </article>

        <!-- Live TV layout: EPG default + channel column width -->
        <article class="icon-mark-host rounded-2xl border border-line bg-surface p-5 sm:p-6 flex flex-col gap-4">
          <div class="flex items-start gap-3">
            <span class="icon-mark">
              <IconLayoutSidebar aria-hidden="true" stroke={2} />
            </span>
            <div class="flex flex-col gap-1 min-w-0">
              <h3 data-i18n="settings.livetvLayout.title" class="text-base font-semibold">Live TV layout</h3>
              <p data-i18n="settings.livetvLayout.helperLong" class="text-xs text-fg-3">
                Defaults for the channel sidebar and the EPG panel on Live TV. The EPG button on the page itself still toggles per session.
              </p>
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <span data-i18n="settings.livetvLayout.epgDefault" class="text-eyebrow font-medium uppercase text-fg-3">Show EPG by default</span>
            <div
              id="settings-epg-default"
              class="flex flex-wrap gap-2"
              role="radiogroup"
              aria-label="Show EPG by default" data-i18n-attr="aria-label:aria.showEpgDefault">
              <button type="button" data-epg="on"  aria-pressed="false" data-i18n="settings.livetvLayout.epg.on" class="epg-default-btn btn">On</button>
              <button type="button" data-epg="off" aria-pressed="false" data-i18n="settings.livetvLayout.epg.off" class="epg-default-btn btn">Off</button>
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <span data-i18n="settings.livetvLayout.columnWidth" class="text-eyebrow font-medium uppercase text-fg-3">Channel column width</span>
            <div
              id="settings-channel-width"
              class="flex flex-wrap gap-2"
              role="radiogroup"
              aria-label="Channel column width" data-i18n-attr="aria-label:aria.channelColumnWidth">
              <button type="button" data-width="22" aria-pressed="false" data-i18n="settings.livetvLayout.width.compact" class="channel-width-btn btn">Compact</button>
              <button type="button" data-width="28" aria-pressed="false" data-i18n="settings.livetvLayout.width.default" class="channel-width-btn btn">Default</button>
              <button type="button" data-width="34" aria-pressed="false" data-i18n="settings.livetvLayout.width.wide" class="channel-width-btn btn">Wide</button>
              <button type="button" data-width="42" aria-pressed="false" data-i18n="settings.livetvLayout.width.xWide" class="channel-width-btn btn">X-Wide</button>
            </div>
          </div>
        </article>

        <!-- EPG: time zone offset (per active playlist) -->
        <article id="epg-tz-section" class="icon-mark-host rounded-2xl border border-line bg-surface p-5 sm:p-6 flex flex-col gap-4">
          <div class="flex items-start gap-3">
            <span class="icon-mark">
              <IconClock aria-hidden="true" stroke={2} />
            </span>
            <div class="flex flex-col gap-1 min-w-0">
              <h3 data-i18n="settings.epgTimezone.title" class="text-base font-semibold">EPG time zone</h3>
              <p data-i18n="epg.timezoneHelper" class="text-xs text-fg-3">
                Some providers ship XMLTV with timestamps already shifted to the server's local time, so EPG times look off. Auto-detect picks the offset where the most channels have a programme airing right now.
              </p>
            </div>
          </div>
          <label class="flex flex-col gap-1.5">
            <span data-i18n="settings.epgTimezone.offsetLabel" class="text-eyebrow font-medium uppercase text-fg-3">
              Offset for active playlist
            </span>
            <select id="epg-tz-select" disabled class="field-input">
              <option value="auto" data-i18n="epg.timezoneAutoDetect">Auto-detect</option>
            </select>
          </label>
          <div
            id="epg-tz-status"
            aria-live="polite"
            class="text-xs text-fg-3"></div>
        </article>

        <!-- Network: User-Agent spoofing -->
        <article class="icon-mark-host rounded-2xl border border-line bg-surface p-5 sm:p-6 flex flex-col gap-4">
          <div class="flex items-start gap-3">
            <span class="icon-mark">
              <IconWifi aria-hidden="true" stroke={2} />
            </span>
            <div class="flex flex-col gap-1 min-w-0">
              <h3 data-i18n="settings.network.title" class="text-base font-semibold">Network</h3>
              <p data-i18n="settings.network.helperLong" class="text-xs text-fg-3">
                Some IPTV providers reject the default browser User-Agent. Pick a preset or enter a custom string. Applies to provider API, M3U, and EPG fetches. Effective in the desktop build.
              </p>
            </div>
          </div>
          <div class="flex flex-col gap-3">
            <label class="flex flex-col gap-1.5">
              <span data-i18n="settings.network.uaPreset" class="text-eyebrow font-medium uppercase text-fg-3">User-Agent preset</span>
              <select id="ua-preset" class="field-input"></select>
            </label>
            <label class="flex flex-col gap-1.5">
              <span data-i18n="settings.network.uaCustom" class="text-eyebrow font-medium uppercase text-fg-3">Custom (overrides preset)</span>
              <input
                id="ua-custom"
                type="text"
                autocomplete="off"
                spellcheck="false"
                placeholder="e.g. VLC/3.0.20 LibVLC/3.0.20"
                data-i18n-attr="placeholder:settings.network.uaPlaceholder"
                class="field-input font-mono"
              />
            </label>
          </div>
          <div class="grid grid-cols-1 gap-2 pt-1">
            <button id="ua-save" type="button" class="btn justify-start sm:justify-center">
              <IconDeviceFloppy aria-hidden="true" class="btn-icon" />
              <span data-i18n="common.save">Save</span>
            </button>
          </div>
          <span
            id="ua-msg"
            aria-live="polite"
            class="text-xs text-fg-3 transition-opacity duration-300 empty:hidden"></span>
        </article>

        <!-- Discord Rich Presence -->
        <article id="discord-rpc-section" class="icon-mark-host rounded-2xl border border-line bg-surface p-5 sm:p-6 flex flex-col gap-4 hidden">
          <div class="flex items-start gap-3">
            <span class="icon-mark">
              <IconBrandDiscord aria-hidden="true" stroke={2} />
            </span>
            <div class="flex flex-col gap-1 min-w-0">
              <h3 data-i18n="settings.discord.title" class="text-base font-semibold">Discord Rich Presence</h3>
              <p data-i18n="settings.discord.helperLong" class="text-xs text-fg-3">
                Show "Watching X on Extreme InfiniTV" on your Discord profile while you use the app. On by default; uncheck a playlist below to mute presence for that account. Desktop only - requires Discord running on the same machine.
              </p>
            </div>
          </div>

          <input id="discord-client-id" type="hidden" />

          <div class="flex flex-col gap-2">
            <span data-i18n="settings.discord.perPlaylist" class="text-eyebrow font-medium uppercase text-fg-3">Per-playlist</span>
            <div
              id="discord-playlists"
              class="flex flex-col divide-y divide-line/60 rounded-xl border border-line bg-bg overflow-hidden">
              <div data-i18n="settings.playlists.empty" class="px-4 py-4 text-xs text-fg-3">No playlists yet.</div>
            </div>
          </div>
        </article>

      </div>
    </section>

    <!-- Group: Data -->
    <section class="settings-group">
      <h2 data-i18n="settings.group.data" class="settings-group__title">Data</h2>
      <div class="flex flex-col gap-4">

        <!-- Downloads (folder only - queue lives on /downloads) -->
        <article id="downloads-folder-section" class="icon-mark-host rounded-2xl border border-line bg-surface p-5 sm:p-6 flex flex-col gap-3 scroll-mt-6">
          <div class="flex items-start gap-3">
            <span class="icon-mark">
              <IconDownload aria-hidden="true" stroke={2} />
            </span>
            <div class="flex flex-col gap-1 min-w-0 flex-1">
              <h3 data-i18n="settings.downloadsSection.title" class="text-base font-semibold">Downloads</h3>
              <p data-i18n-html="settings.downloadsFolder.intro" class="text-xs text-fg-3">
                Folder where new downloads land. Manage the queue itself on the
                <a href="/downloads" class="text-accent underline">Downloads page</a>.
              </p>
            </div>
            <span id="downloads-availability" class="text-xs text-fg-3 shrink-0 truncate empty:hidden"></span>
          </div>
          <div class="flex flex-col gap-1.5">
            <label data-i18n="settings.downloadsFolder.savedTo" class="text-eyebrow font-medium uppercase text-fg-3" for="download-dir-input">
              Save to
            </label>
            <div class="flex gap-2 flex-wrap">
              <input
                id="download-dir-input"
                type="text"
                readonly
                placeholder="Not set - picked on first download"
                data-i18n-attr="placeholder:settings.downloadsFolder.notSetPlaceholder"
                class="field-input flex-1 min-w-0 font-mono"
              />
              <button id="download-dir-pick" type="button" class="btn">
                <IconFolderOpen aria-hidden="true" class="btn-icon" />
                <span data-i18n="settings.downloadsFolder.choose">Choose…</span>
              </button>
              <button id="download-dir-clear" type="button" class="btn text-fg-2">
                <span data-i18n="common.clear">Clear</span>
              </button>
            </div>
          </div>

          <div class="flex flex-col gap-1.5">
            <span data-i18n="settings.downloadsFolder.restoreLabel" class="text-eyebrow font-medium uppercase text-fg-3">
              Restore from folder
            </span>
            <p data-i18n="settings.downloadsFolder.restoreHelper" class="text-xs text-fg-3">
              After a reinstall, scan the folder above for `.xtmeta.json` sidecars and re-add the matching files to your downloads list.
            </p>
            <div class="grid grid-cols-1 gap-2">
              <button id="downloads-scan" type="button" class="btn justify-start sm:justify-center">
                <IconRefresh aria-hidden="true" class="btn-icon" />
                <span data-i18n="settings.downloadsFolder.scanFolder">Scan folder</span>
              </button>
            </div>
            <span
              id="downloads-scan-msg"
              aria-live="polite"
              class="text-xs text-fg-3 transition-opacity duration-300 empty:hidden"></span>
          </div>

          <div class="flex flex-col gap-1.5">
            <span data-i18n="settings.downloadsFolder.concurrency" class="text-eyebrow font-medium uppercase text-fg-3">
              Concurrent downloads
            </span>
            <p data-i18n="settings.downloadsFolder.concurrencyHelper" class="text-xs text-fg-3">
              Most Xtream providers cap connections per account, so a second
              parallel download fails mid-stream. Keep this at 1 unless your
              provider explicitly allows multiple slots.
            </p>
            <div
              id="settings-download-concurrency"
              class="flex flex-wrap gap-2"
              role="radiogroup"
              aria-label="Concurrent downloads"
              data-i18n-attr="aria-label:settings.downloadsFolder.concurrency">
              <button type="button" data-concurrency="1" aria-pressed="false" class="dl-concurrency-btn btn">1</button>
              <button type="button" data-concurrency="2" aria-pressed="false" class="dl-concurrency-btn btn">2</button>
              <button type="button" data-concurrency="3" aria-pressed="false" class="dl-concurrency-btn btn">3</button>
              <button type="button" data-concurrency="4" aria-pressed="false" class="dl-concurrency-btn btn">4</button>
            </div>
            <p
              id="settings-download-concurrency-cap"
              class="text-2xs text-fg-3 tabular-nums empty:hidden"
              aria-live="polite"></p>
          </div>
        </article>

        <!-- Backup / restore -->
        <article class="icon-mark-host rounded-2xl border border-line bg-surface p-5 sm:p-6 flex flex-col gap-4">
          <div class="flex items-start gap-3">
            <span class="icon-mark">
              <IconArchive aria-hidden="true" stroke={2} />
            </span>
            <div class="flex flex-col gap-1 min-w-0">
              <h3 data-i18n="settings.backup.title" class="text-base font-semibold">Backup</h3>
              <p data-i18n="settings.backup.helperLong" class="text-xs text-fg-3">
                Save all playlists, favorites, recents, watched progress, hidden categories, and app settings to a file. Cache and the downloads queue are not exported.
              </p>
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 pt-1">
            <button id="settings-export" type="button" class="btn justify-start sm:justify-center">
              <IconDownload aria-hidden="true" class="btn-icon" />
              <span data-i18n="settings.backup.export">Export to file</span>
            </button>
            <button id="settings-import" type="button" class="btn justify-start sm:justify-center">
              <IconUpload aria-hidden="true" class="btn-icon" />
              <span data-i18n="settings.backup.import">Import from file</span>
            </button>
          </div>
          <input id="settings-import-input" type="file" accept="application/json,.json" hidden />
          <span id="settings-backup-msg" aria-live="polite" class="text-xs text-fg-3 transition-opacity duration-300 empty:hidden"></span>
        </article>

        <!-- Storage / cache -->
        <article class="icon-mark-host rounded-2xl border border-line bg-surface p-5 sm:p-6 flex flex-col gap-4">
          <div class="flex items-start gap-3">
            <span class="icon-mark">
              <IconDatabase aria-hidden="true" stroke={2} />
            </span>
            <div class="flex flex-col gap-1 min-w-0">
              <h3 data-i18n="settings.storage.title" class="text-base font-semibold">Storage</h3>
              <p data-i18n="settings.storage.helperLong" class="text-xs text-fg-3">
                Clears channel, movie, and series lists. Playlists, favorites, and recents are kept.
              </p>
            </div>
          </div>
          <dl class="grid grid-cols-2 gap-y-3 gap-x-6 text-sm">
            <div class="flex flex-col gap-0.5 min-w-0">
              <dt data-i18n="settings.storage.size" class="text-fg-3 text-eyebrow font-medium uppercase">Cache</dt>
              <dd id="settings-cache-size" class="text-fg tabular-nums truncate">-</dd>
            </div>
            <div class="flex flex-col gap-0.5 min-w-0">
              <dt data-i18n="settings.storage.lastUpdated" class="text-fg-3 text-eyebrow font-medium uppercase">Last updated</dt>
              <dd id="settings-cache-newest" class="text-fg tabular-nums truncate">-</dd>
            </div>
          </dl>
          <div class="grid grid-cols-1 gap-2 pt-1">
            <button id="settings-clear-cache" type="button" class="btn justify-start sm:justify-center">
              <IconTrash aria-hidden="true" class="btn-icon" />
              <span data-i18n="settings.storage.clear">Clear cache</span>
            </button>
          </div>
          <span
            id="settings-cache-msg"
            aria-live="polite"
            class="text-xs text-fg-3 transition-opacity duration-300 empty:hidden"></span>

          <div class="flex flex-col gap-2 pt-2 border-t border-line/60">
            <span data-i18n="settings.progressRetention.label" class="text-eyebrow font-medium uppercase text-fg-3">Continue Watching retention</span>
            <p data-i18n="settings.progressRetention.helper" class="text-xs text-fg-3">
