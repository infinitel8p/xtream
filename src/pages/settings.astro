    import { fetchReleases, renderMarkdown } from "@/scripts/lib/changelog.ts"
    import { attachDialogSpatialNav } from "@/scripts/lib/dialog-spatial-nav.js"
    import {
      UA_PRESETS,
      getUserAgent,
