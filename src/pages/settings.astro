    const epgDefaultGroup = document.getElementById("settings-epg-default")
    function readEpgDefault() {
      try {
        const v = localStorage.getItem("xt_epg_open_default")
        return v === null ? true : v === "true"
      } catch {
        return true
      }
    }
    function applyEpgDefault(on) {
      try {
        localStorage.setItem("xt_epg_open_default", String(on))
        // Reset the per-session override so the new default applies on the
        // next visit to /livetv.
        localStorage.removeItem("xt_epg_visible")
