---
import Layout from "@/layouts/Layout.astro"
import {
  IconRefresh,
  IconTrash,
  IconAlertTriangle,
  IconPlus,
  IconFolderOpen,
  IconCloudDownload,
  IconBrandGithub,
  IconDeviceFloppy,
} from "@tabler/icons-svelte"
---

<Layout pageTitle="Settings">
  <main class="flex-1 min-h-0 overflow-auto custom-scroll">
    <div
      class="w-full max-w-3xl mx-auto px-4 md:px-6 lg:px-8 pt-6 sm:pt-10 pb-12
             flex flex-col gap-8 sm:gap-10">

    <header class="shrink-0 flex flex-col gap-2">
      <h1
        class="font-semibold tracking-[-0.02em] leading-[0.95]"
        style="font-size: clamp(2.5rem, 3vw + 1.5rem, 4.5rem);">
        Settings
      </h1>
      <p class="text-sm sm:text-base text-fg-3 max-w-prose">
        Playlists, preferences, cache, and the app itself.
      </p>
    </header>

    <!-- Group: Playlists -->
    <section class="flex flex-col gap-3">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-fg-2">Playlists</h2>
      <div class="rounded-2xl border border-line bg-surface p-5 sm:p-6 flex flex-col gap-4">
        <div
          id="settings-playlists"
          class="flex flex-col divide-y divide-line/60 rounded-xl border border-line bg-bg overflow-hidden">
          <div class="px-4 py-4 text-xs text-fg-3">No playlists yet.</div>
        </div>
        <div class="flex flex-wrap gap-2 pt-1">
          <a href="/login" class="btn">
            <IconPlus aria-hidden="true" class="btn-icon" />
            Add playlist
          </a>
          <button
            id="settings-refresh-active"
            type="button"
            class="btn hidden">
            <IconRefresh aria-hidden="true" class="btn-icon" />
            Refresh active
          </button>
        </div>
      </div>
    </section>

    <!-- Group: Preferences -->
    <section class="flex flex-col gap-3">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-fg-2">Preferences</h2>
      <div class="flex flex-col gap-4">

        <!-- Display: theme + font scale -->
        <article class="rounded-2xl border border-line bg-surface p-5 sm:p-6 flex flex-col gap-4">
          <div class="flex flex-col gap-1">
            <h3 class="text-base font-semibold">Display</h3>
            <p class="text-xs text-fg-3 max-w-prose">
              Theme and base font size. System theme follows your OS preference.
            </p>
          </div>

          <div class="flex flex-col gap-2">
            <span class="text-eyebrow font-medium uppercase text-fg-3">Theme</span>
            <div
              id="settings-theme"
              class="flex flex-wrap gap-2"
              role="radiogroup"
              aria-label="Theme">
              <button type="button" data-theme="system" aria-pressed="false" class="theme-btn btn">System</button>
              <button type="button" data-theme="light"  aria-pressed="false" class="theme-btn btn">Light</button>
              <button type="button" data-theme="dark"   aria-pressed="false" class="theme-btn btn">Dark</button>
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <span class="text-eyebrow font-medium uppercase text-fg-3">Font scale</span>
            <p class="text-xs text-fg-3 max-w-prose">
              Bumps the base font size. Use Large or X-Large when viewing on a TV from across the room.
            </p>
            <div
              id="settings-font-scale"
              class="flex flex-wrap gap-2"
              role="radiogroup"
              aria-label="Font scale">
              <button type="button" data-scale="1"     aria-pressed="false" class="font-scale-btn btn">Default</button>
              <button type="button" data-scale="1.125" aria-pressed="false" class="font-scale-btn btn">Medium</button>
              <button type="button" data-scale="1.25"  aria-pressed="false" class="font-scale-btn btn">Large</button>
              <button type="button" data-scale="1.5"   aria-pressed="false" class="font-scale-btn btn">X-Large</button>
            </div>
          </div>
          <script is:inline>
            try {
              var savedFontScale = parseFloat(localStorage.getItem("xt_font_scale") || "1");
              if (!isFinite(savedFontScale) || savedFontScale < 0.75 || savedFontScale > 2) savedFontScale = 1;
              var fontScaleGroup = document.getElementById("settings-font-scale");
              if (fontScaleGroup) {
                var fontScaleBtns = fontScaleGroup.querySelectorAll(".font-scale-btn");
                for (var i = 0; i < fontScaleBtns.length; i++) {
                  var btnScale = parseFloat(fontScaleBtns[i].getAttribute("data-scale") || "1");
                  fontScaleBtns[i].setAttribute("aria-pressed", Math.abs(btnScale - savedFontScale) < 0.001 ? "true" : "false");
                }
              }
              var currentTheme = localStorage.getItem("xt_theme") || "dark";
              var themeGroup = document.getElementById("settings-theme");
              if (themeGroup) {
                var themeBtns = themeGroup.querySelectorAll(".theme-btn");
                for (var j = 0; j < themeBtns.length; j++) {
                  themeBtns[j].setAttribute("aria-pressed", themeBtns[j].getAttribute("data-theme") === currentTheme ? "true" : "false");
                }
              }
            } catch (e) {}
          </script>
        </article>

        <!-- Live TV layout: EPG default + channel column width -->
        <article class="rounded-2xl border border-line bg-surface p-5 sm:p-6 flex flex-col gap-4">
          <div class="flex flex-col gap-1">
            <h3 class="text-base font-semibold">Live TV layout</h3>
            <p class="text-xs text-fg-3 max-w-prose">
              Defaults for the channel sidebar and the EPG panel on Live TV. The EPG button on the page itself still toggles per session.
            </p>
          </div>

          <div class="flex flex-col gap-2">
            <span class="text-eyebrow font-medium uppercase text-fg-3">Show EPG by default</span>
            <div
              id="settings-epg-default"
              class="flex flex-wrap gap-2"
              role="radiogroup"
              aria-label="Show EPG by default">
              <button type="button" data-epg="on"  aria-pressed="false" class="epg-default-btn btn">On</button>
              <button type="button" data-epg="off" aria-pressed="false" class="epg-default-btn btn">Off</button>
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <span class="text-eyebrow font-medium uppercase text-fg-3">Channel column width</span>
            <div
              id="settings-channel-width"
              class="flex flex-wrap gap-2"
              role="radiogroup"
              aria-label="Channel column width">
              <button type="button" data-width="22" aria-pressed="false" class="channel-width-btn btn">Compact</button>
              <button type="button" data-width="28" aria-pressed="false" class="channel-width-btn btn">Default</button>
              <button type="button" data-width="34" aria-pressed="false" class="channel-width-btn btn">Wide</button>
              <button type="button" data-width="42" aria-pressed="false" class="channel-width-btn btn">X-Wide</button>
            </div>
          </div>
        </article>

        <!-- Network: User-Agent spoofing -->
        <article class="rounded-2xl border border-line bg-surface p-5 sm:p-6 flex flex-col gap-4">
          <div class="flex flex-col gap-1">
            <h3 class="text-base font-semibold">Network</h3>
            <p class="text-xs text-fg-3 max-w-prose">
              Some IPTV providers reject the default browser User-Agent. Pick a preset or enter a custom string. Applies to provider API, M3U, and EPG fetches. Effective in the desktop build.
            </p>
          </div>
          <div class="flex flex-col gap-3">
            <label class="flex flex-col gap-1.5">
              <span class="text-eyebrow font-medium uppercase text-fg-3">User-Agent preset</span>
              <select
                id="ua-preset"
                class="rounded-xl border border-line bg-bg px-3 py-2 text-sm text-fg
                       hover:bg-surface-2 focus-visible:bg-surface-2 focus-visible:border-accent
                       transition-colors">
              </select>
            </label>
            <label class="flex flex-col gap-1.5">
              <span class="text-eyebrow font-medium uppercase text-fg-3">Custom (overrides preset)</span>
              <input
                id="ua-custom"
                type="text"
                autocomplete="off"
                spellcheck="false"
                placeholder="e.g. VLC/3.0.20 LibVLC/3.0.20"
                class="rounded-xl border border-line bg-bg px-3 py-2 text-sm text-fg font-mono
                       placeholder:text-fg-3
                       hover:bg-surface-2 focus-visible:bg-surface-2 focus-visible:border-accent
                       transition-colors"
              />
            </label>
          </div>
          <div class="flex flex-wrap items-center gap-3 pt-1">
            <button id="ua-save" type="button" class="btn">
              <IconDeviceFloppy aria-hidden="true" class="btn-icon" />
              Save
            </button>
            <span
              id="ua-msg"
              aria-live="polite"
              class="text-xs text-fg-3 transition-opacity duration-300"></span>
          </div>
        </article>

      </div>
    </section>

    <!-- Group: Data -->
    <section class="flex flex-col gap-3">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-fg-2">Data</h2>
      <div class="flex flex-col gap-4">

        <!-- Downloads (folder only - queue lives on /downloads) -->
        <article id="downloads-folder-section" class="rounded-2xl border border-line bg-surface p-5 sm:p-6 flex flex-col gap-3 scroll-mt-6">
          <div class="flex items-start justify-between gap-3">
            <div class="flex flex-col gap-1 min-w-0">
              <h3 class="text-base font-semibold">Downloads</h3>
              <p class="text-xs text-fg-3 max-w-prose">
                Folder where new downloads land. Manage the queue itself on the
                <a href="/downloads" class="text-accent underline">Downloads page</a>.
              </p>
            </div>
            <span id="downloads-availability" class="text-xs text-fg-3 shrink-0 truncate empty:hidden"></span>
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-eyebrow font-medium uppercase text-fg-3" for="download-dir-input">
              Save to
            </label>
            <div class="flex gap-2 flex-wrap">
              <input
                id="download-dir-input"
                type="text"
                readonly
                placeholder="Not set - picked on first download"
                class="flex-1 min-w-0 rounded-xl border border-line bg-bg px-3 py-2 text-sm text-fg font-mono
                       placeholder:text-fg-3"
              />
              <button id="download-dir-pick" type="button" class="btn">
                <IconFolderOpen aria-hidden="true" class="btn-icon" />
                Choose…
              </button>
              <button id="download-dir-clear" type="button" class="btn text-fg-2">
                Clear
              </button>
            </div>
          </div>

          <div class="flex flex-col gap-1.5">
            <span class="text-eyebrow font-medium uppercase text-fg-3">
              Concurrent downloads
            </span>
            <p class="text-xs text-fg-3 max-w-prose">
              Most Xtream providers cap connections per account, so a second
              parallel download fails mid-stream. Keep this at 1 unless your
              provider explicitly allows multiple slots.
            </p>
            <div
              id="settings-download-concurrency"
              class="flex flex-wrap gap-2"
              role="radiogroup"
              aria-label="Concurrent downloads">
              <button type="button" data-concurrency="1" aria-pressed="false" class="dl-concurrency-btn btn">1</button>
              <button type="button" data-concurrency="2" aria-pressed="false" class="dl-concurrency-btn btn">2</button>
              <button type="button" data-concurrency="3" aria-pressed="false" class="dl-concurrency-btn btn">3</button>
              <button type="button" data-concurrency="4" aria-pressed="false" class="dl-concurrency-btn btn">4</button>
            </div>
          </div>
        </article>

        <!-- Storage / cache -->
        <article class="rounded-2xl border border-line bg-surface p-5 sm:p-6 flex flex-col gap-4">
          <div class="flex flex-col gap-1">
            <h3 class="text-base font-semibold">Storage</h3>
            <p class="text-xs text-fg-3 max-w-prose">
              Clears channel, movie, and series lists. Playlists, favorites, and recents are kept.
            </p>
          </div>
          <dl class="grid grid-cols-2 gap-y-3 gap-x-6 text-sm">
            <div class="flex flex-col gap-0.5 min-w-0">
              <dt class="text-fg-3 text-eyebrow font-medium uppercase">Cache</dt>
              <dd id="settings-cache-size" class="text-fg tabular-nums truncate">-</dd>
            </div>
            <div class="flex flex-col gap-0.5 min-w-0">
              <dt class="text-fg-3 text-eyebrow font-medium uppercase">Last updated</dt>
              <dd id="settings-cache-newest" class="text-fg tabular-nums truncate">-</dd>
            </div>
          </dl>
          <div class="flex flex-wrap items-center gap-3 pt-1">
            <button id="settings-clear-cache" type="button" class="btn">
              <IconTrash aria-hidden="true" class="btn-icon" />
              Clear cache
            </button>
            <span
              id="settings-cache-msg"
              aria-live="polite"
              class="text-xs text-fg-3 transition-opacity duration-300"></span>
          </div>
        </article>

      </div>
    </section>

    <!-- Group: About (App update + version + expiration) -->
    <section class="flex flex-col gap-3">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-fg-2">About</h2>
      <article
        id="update-section"
        data-state="idle"
        class="rounded-2xl border border-line bg-surface p-5 sm:p-6 flex flex-col gap-5
               data-[state=available]:border-accent/50 data-[state=available]:bg-accent-soft/30
               transition-colors">
        <div class="flex flex-col gap-1 min-w-0">
          <div class="flex items-center gap-2 flex-wrap">
            <h3 class="text-base font-semibold">Extreme InfiniTV</h3>
            <span
              id="update-pill"
              class="hidden h-5 px-2 items-center justify-center rounded-full text-label font-semibold uppercase tracking-wide bg-accent text-bg shrink-0 pulse-ring">
              Update available
            </span>
          </div>
          <span id="update-availability" class="text-xs text-fg-3 truncate empty:hidden"></span>
        </div>

        <dl class="grid grid-cols-2 sm:grid-cols-3 gap-y-3 gap-x-6 text-sm">
          <div class="flex flex-col gap-0.5 min-w-0">
            <dt class="text-fg-3 text-eyebrow font-medium uppercase">Current</dt>
            <dd id="update-current" class="text-fg tabular-nums truncate">-</dd>
          </div>
          <div class="flex flex-col gap-0.5 min-w-0">
            <dt class="text-fg-3 text-eyebrow font-medium uppercase">Latest</dt>
            <dd id="update-latest" class="text-fg tabular-nums truncate">-</dd>
          </div>
          <div class="flex flex-col gap-0.5 min-w-0 col-span-2 sm:col-span-1">
            <dt class="text-fg-3 text-eyebrow font-medium uppercase">Account expires</dt>
            <dd data-account-expiration="raw" class="text-fg tabular-nums truncate">-</dd>
          </div>
        </dl>

        <div
          id="update-progress-wrap"
          class="hidden flex-col gap-1.5">
          <div class="h-1.5 rounded-full bg-bg overflow-hidden ring-1 ring-line">
            <div id="update-progress-bar" class="h-full bg-accent transition-[width] duration-150" style="width: 0%"></div>
          </div>
          <div id="update-progress-text" class="text-xs text-fg-3 tabular-nums">0%</div>
        </div>

        <div class="flex flex-wrap items-center gap-2 pt-4 border-t border-line/60">
          <button id="update-check" type="button" class="btn">
            <IconRefresh aria-hidden="true" class="btn-icon" />
            Check for updates
          </button>
          <button id="update-install" type="button" hidden class="btn">
            <IconCloudDownload aria-hidden="true" class="btn-icon" />
            <span id="update-install-label">Download &amp; install</span>
          </button>
          <button id="update-relaunch" type="button" hidden class="btn">
            Restart now
          </button>
          <a
            id="update-github"
            href="https://github.com/infinitel8p/xtream/releases/latest"
            target="_blank"
            rel="noopener noreferrer"
            class="btn ml-auto text-fg-2">
            <IconBrandGithub aria-hidden="true" class="btn-icon" />
            GitHub
          </a>
          <span
            id="update-msg"
            aria-live="polite"
            class="text-xs text-fg-3 transition-opacity duration-300 basis-full"></span>
        </div>

        <p id="update-notes" class="hidden text-xs text-fg-3 max-w-prose whitespace-pre-line border-t border-line/60 pt-4 -mt-1"></p>
      </article>

      <span id="app-version" class="hidden"></span>
    </section>

    <!-- Group: Danger zone (always last) -->
    <section class="flex flex-col gap-3 pt-2">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-bad">Danger zone</h2>
      <article class="rounded-2xl border border-bad/30 bg-bad/[0.03] p-5 sm:p-6 flex flex-col gap-4">
        <div class="flex items-start gap-3">
          <span class="inline-flex size-8 shrink-0 items-center justify-center rounded-lg bg-bad/10 ring-1 ring-bad/30">
            <IconAlertTriangle aria-hidden="true" stroke={2} class="size-4 text-bad" />
          </span>
          <div class="flex flex-col gap-1 min-w-0">
            <h3 class="text-base font-semibold text-bad">Reset everything</h3>
            <p class="text-sm text-fg-2 max-w-prose">
              Wipes <span class="text-fg font-medium">all</span> app data: playlists, cached lists, favorites, recents, and locally stored EPG references. Next launch starts from a clean slate.
            </p>
          </div>
        </div>
        <div class="flex flex-wrap items-center gap-3 pt-1">
          <button id="settings-reset-all" type="button" class="btn-danger">
            <IconTrash aria-hidden="true" class="btn-icon" />
            Reset everything
          </button>
          <span
            id="settings-reset-msg"
            aria-live="polite"
            class="text-xs text-fg-3 transition-opacity duration-300"></span>
        </div>
      </article>
    </section>

    </div>
  </main>

  <!-- Reset confirmation dialog -->
  <dialog
    id="settings-reset-dialog"
    aria-labelledby="settings-reset-title"
    aria-describedby="settings-reset-desc"
    class="fixed inset-0 m-auto rounded-2xl border border-line bg-surface text-fg p-0
           w-[min(28rem,calc(100vw-2rem))] backdrop:bg-black/60">
    <div class="flex flex-col p-5 gap-4">
      <div class="flex items-start gap-3">
        <span class="inline-flex size-10 shrink-0 items-center justify-center rounded-xl bg-bad/10 ring-1 ring-bad/30">
          <IconAlertTriangle aria-hidden="true" stroke={2} class="size-5 text-bad" />
        </span>
        <div class="flex flex-col gap-1 min-w-0 pt-0.5">
          <h2 id="settings-reset-title" class="text-base font-semibold">
            Reset everything?
          </h2>
          <p id="settings-reset-desc" class="text-sm text-fg-2">
            This wipes <span class="text-fg font-medium">all</span> playlists, favorites,
            recents, and cached lists. This can't be undone.
          </p>
        </div>
      </div>
      <div class="flex flex-wrap justify-end gap-2 pt-1">
        <button
          id="settings-reset-cancel"
          type="button"
          class="btn">
          Cancel
        </button>
        <button
          id="settings-reset-confirm"
          type="button"
          class="btn-danger">
          <IconTrash aria-hidden="true" class="btn-icon" />
          Reset everything
        </button>
      </div>
    </div>
  </dialog>

  <script>
    import { Store } from "@tauri-apps/plugin-store"
    import {
      getActiveEntry,
      getEntries,
      refreshActive,
      isTauri,
    } from "@/scripts/lib/creds.js"
    import { getNewestCacheTime } from "@/scripts/lib/cache.js"
    import {
      renderPlaylistRow,
      PLAYLIST_LIST_EMPTY_COPY,
    } from "@/scripts/lib/playlist-rows.js"
    import { injectVersion } from "@/scripts/version.js"
    import { attachDialogSpatialNav } from "@/scripts/lib/dialog-spatial-nav.js"
    import {
      UA_PRESETS,
      getUserAgent,
      setUserAgent,
      getDownloadDir,
      setDownloadDir,
      getDownloadConcurrency,
      setDownloadConcurrency,
    } from "@/scripts/lib/app-settings.js"
    import { isDownloadable } from "@/scripts/lib/downloads.js"

    injectVersion()

    const playlistsEl = document.getElementById("settings-playlists")
    const refreshBtn = /** @type {HTMLButtonElement|null} */ (document.getElementById("settings-refresh-active"))
    const cacheSizeEl = document.getElementById("settings-cache-size")
    const cacheNewestEl = document.getElementById("settings-cache-newest")
    const cacheMsgEl = document.getElementById("settings-cache-msg")
    const clearCacheBtn = /** @type {HTMLButtonElement|null} */ (document.getElementById("settings-clear-cache"))
    const resetBtn = /** @type {HTMLButtonElement|null} */ (document.getElementById("settings-reset-all"))
    const resetMsgEl = document.getElementById("settings-reset-msg")
    const resetDialog = /** @type {HTMLDialogElement|null} */ (document.getElementById("settings-reset-dialog"))
    if (resetDialog) attachDialogSpatialNav(resetDialog, { defaultElement: "#settings-reset-cancel" })
    const resetCancelBtn = document.getElementById("settings-reset-cancel")
    const resetConfirmBtn = /** @type {HTMLButtonElement|null} */ (document.getElementById("settings-reset-confirm"))

    function fmtAge(ts) {
      if (!ts) return "Never"
      const ms = Date.now() - ts
      if (ms < 60_000) return "Just now"
      const m = Math.floor(ms / 60_000)
      if (m < 60) return `${m}m ago`
      const h = Math.floor(m / 60)
      if (h < 24) return `${h}h ago`
      const d = Math.floor(h / 24)
      return `${d}d ago`
    }

    function fmtBytes(n) {
      if (n === 0) return "Empty"
      if (n < 1024) return `${n} B`
      if (n < 1024 * 1024) return `${(n / 1024).toFixed(1)} KB`
      return `${(n / (1024 * 1024)).toFixed(1)} MB`
    }

    /** @type {Map<HTMLElement, number>} */
    const msgTimers = new Map()
    function flashMsg(el, text) {
      if (!el) return
      const prev = msgTimers.get(el)
      if (prev) window.clearTimeout(prev)
      el.textContent = text
      el.classList.remove("opacity-0")
      const t = window.setTimeout(() => {
        el.classList.add("opacity-0")
        const t2 = window.setTimeout(() => {
          if (el.textContent === text) el.textContent = ""
          el.classList.remove("opacity-0")
          msgTimers.delete(el)
        }, 320)
        msgTimers.set(el, t2)
      }, 3500)
      msgTimers.set(el, t)
    }

    function setLoading(btn, loading) {
      if (!btn) return
      if (loading) {
        btn.setAttribute("data-loading", "true")
        btn.setAttribute("aria-busy", "true")
        btn.disabled = true
      } else {
        btn.removeAttribute("data-loading")
        btn.removeAttribute("aria-busy")
        btn.disabled = false
      }
    }

    /** @type {WeakMap<HTMLElement, number>} */
    const successTimers = new WeakMap()
    /** Briefly swap a button's leading icon for the project's check-draw
     *  glyph, then restore. Reuses the same vocabulary PlaylistSwitcher
     *  uses when an entry is selected. */
    function flashSuccess(btn) {
      if (!btn) return
      const icon = btn.querySelector(".btn-icon")
      if (!icon) return
      const prev = successTimers.get(btn)
      if (prev) {
        window.clearTimeout(prev)
        const stash = btn.querySelector('[data-icon-stash="1"]')
        if (stash) stash.remove()
      }
      const original = icon.cloneNode(true)
      original.setAttribute("data-icon-stash", "1")
      original.classList.add("hidden")
      btn.insertBefore(original, icon)

      const tmp = document.createElement("span")
      tmp.innerHTML = ICON_CHECK
      const check = tmp.firstElementChild
      if (!check) return
      check.setAttribute("aria-hidden", "true")
      check.classList.add("btn-icon", "check-draw", "text-accent")
      icon.replaceWith(check)

      const timer = window.setTimeout(() => {
        const stash = btn.querySelector('[data-icon-stash="1"]')
        const live = btn.querySelector(".btn-icon:not([data-icon-stash])")
        if (stash && live) {
          stash.classList.remove("hidden")
          stash.removeAttribute("data-icon-stash")
          live.remove()
        }
        successTimers.delete(btn)
      }, 1100)
      successTimers.set(btn, timer)
    }

    async function renderPlaylists() {
      if (!playlistsEl) return
      const [entries, active] = await Promise.all([
        getEntries(),
        getActiveEntry(),
      ])

      if (!entries.length) {
        playlistsEl.innerHTML = `<div class="px-4 py-4 text-xs text-fg-3">${PLAYLIST_LIST_EMPTY_COPY}</div>`
        refreshBtn?.classList.add("hidden")
        return
      }

      const frag = document.createDocumentFragment()
      for (const e of entries) {
        frag.appendChild(
          renderPlaylistRow({
            entry: e,
            isActive: active?._id === e._id,
            density: "full",
          })
        )
      }
      playlistsEl.replaceChildren(frag)

      if (active) refreshBtn?.classList.remove("hidden")
      else refreshBtn?.classList.add("hidden")
    }

    function syncCache() {
      let bytes = 0
      let entries = 0
      try {
        for (let i = 0; i < localStorage.length; i++) {
          const k = localStorage.key(i)
          if (!k || !k.startsWith("xt_cache:")) continue
          const v = localStorage.getItem(k) || ""
          // Approximate - UTF-16 code units in localStorage; doubling gives
          // closer-to-actual byte count.
          bytes += k.length + v.length * 2
          entries++
        }
      } catch {}
      if (cacheSizeEl) cacheSizeEl.textContent = fmtBytes(bytes)
      if (clearCacheBtn) clearCacheBtn.disabled = entries === 0

      ;(async () => {
        const a = await getActiveEntry()
        const newest = a ? getNewestCacheTime(a._id) : null
        if (cacheNewestEl) cacheNewestEl.textContent = fmtAge(newest)
      })()
    }

    refreshBtn?.addEventListener("click", async () => {
      setLoading(refreshBtn, true)
      let ok = false
      try {
        await refreshActive()
        ok = true
      } finally {
        setLoading(refreshBtn, false)
        syncCache()
        if (ok) flashSuccess(refreshBtn)
      }
    })

    clearCacheBtn?.addEventListener("click", () => {
      setLoading(clearCacheBtn, true)
      let removed = 0
      let ok = false
      try {
        const toRemove = []
        for (let i = 0; i < localStorage.length; i++) {
          const k = localStorage.key(i)
          if (k && (k.startsWith("xt_cache:") || k === "xt_cache_meta"))
            toRemove.push(k)
        }
        for (const k of toRemove) localStorage.removeItem(k)
        try {
          const sessRemove = []
          for (let i = 0; i < sessionStorage.length; i++) {
            const k = sessionStorage.key(i)
            if (k && k.startsWith("xt_cache:")) sessRemove.push(k)
          }
          for (const k of sessRemove) sessionStorage.removeItem(k)
        } catch {}
        removed = toRemove.length
        ok = true
        flashMsg(
          cacheMsgEl,
          removed === 0
            ? "Cache was already empty."
            : `Cleared ${removed} ${removed === 1 ? "entry" : "entries"}.`
        )
      } catch {
        flashMsg(cacheMsgEl, "Couldn't clear cache.")
      } finally {
        setLoading(clearCacheBtn, false)
        syncCache()
        if (ok && removed > 0) flashSuccess(clearCacheBtn)
      }
    })

    function openResetDialog() {
      if (!resetDialog) return
      if (typeof resetDialog.showModal === "function") resetDialog.showModal()
      else resetDialog.setAttribute("open", "")
      requestAnimationFrame(() => {
        window.SpatialNavigation?.makeFocusable?.()
        resetCancelBtn?.focus?.()
      })
    }

    function closeResetDialog() {
      resetDialog?.close?.()
    }

    resetBtn?.addEventListener("click", openResetDialog)
    resetCancelBtn?.addEventListener("click", closeResetDialog)
    resetDialog?.addEventListener("click", (e) => {
      if (e.target === resetDialog) closeResetDialog()
    })
    resetDialog?.addEventListener("close", () => resetBtn?.focus())

    resetConfirmBtn?.addEventListener("click", async () => {
      if (!resetConfirmBtn) return
      setLoading(resetConfirmBtn, true)
      try {
        try { localStorage.clear() } catch {}
        try { sessionStorage.clear() } catch {}
        try {
          const all = document.cookie.split(";")
          for (const c of all) {
            const eq = c.indexOf("=")
            const name = (eq > -1 ? c.slice(0, eq) : c).trim()
            if (!name) continue
            document.cookie = `${name}=; expires=Thu, 01 Jan 1970 00:00:00 GMT; path=/`
          }
        } catch {}

        if (isTauri) {
          try {
            const store = await Store.load(".xtream.creds.json")
            const keys = await store.keys()
            for (const k of keys) await store.delete(k)
            await store.save()
          } catch (e) {
            console.warn("Tauri store reset failed:", e)
          }
        }

        if (resetMsgEl) {
          resetMsgEl.textContent = "Reset complete. Reloading…"
          resetMsgEl.classList.remove("opacity-0")
        }
        closeResetDialog()
        // Hard reload so module-level caches in stream.js / movies.js / etc.
        // are re-initialised from the now-empty stores.
        setTimeout(() => {
          window.location.href = "/"
        }, 400)
      } finally {
        setLoading(resetConfirmBtn, false)
      }
    })

    document.addEventListener("xt:active-changed", () => {
      renderPlaylists()
      syncCache()
    })
    document.addEventListener("xt:entries-updated", () => {
      renderPlaylists()
      syncCache()
    })

    renderPlaylists()
    syncCache()

    // ---------------------------------------------------------------------
    // Font scale - applied inline in <head> on every page load (see
    // Layout.astro). Here we just expose the picker UI and persist changes.
    // ---------------------------------------------------------------------
    const fontScaleGroup = document.getElementById("settings-font-scale")
    function readFontScale() {
      const s = parseFloat(localStorage.getItem("xt_font_scale") || "1")
      return Number.isFinite(s) && s >= 0.75 && s <= 2 ? s : 1
    }
    function applyFontScale(s) {
      document.documentElement.style.setProperty("--xt-font-scale", String(s))
      try {
        if (s === 1) localStorage.removeItem("xt_font_scale")
        else localStorage.setItem("xt_font_scale", String(s))
      } catch {}
      syncFontScaleButtons()
    }
    function syncFontScaleButtons() {
      const current = readFontScale()
      for (const btn of fontScaleGroup?.querySelectorAll(".font-scale-btn") ||
        []) {
        const v = parseFloat(btn.dataset.scale || "1")
        btn.setAttribute("aria-pressed", String(Math.abs(v - current) < 0.001))
      }
    }
    fontScaleGroup?.addEventListener("click", (e) => {
      const t = /** @type {HTMLElement} */ (e.target)
      const btn = t.closest(".font-scale-btn")
      if (!btn) return
      const v = parseFloat(btn.dataset.scale || "1")
      if (!Number.isFinite(v)) return
      applyFontScale(v)
    })
    syncFontScaleButtons()

    // ---------------------------------------------------------------------
    // Theme: light / dark / system. Persisted to xt_theme; applied by the
    // inline script in <head> on page load. CSS uses `light-dark()` so the
    // single `colorScheme` property on :root drives the whole palette.
    // ---------------------------------------------------------------------
    const themeGroup = document.getElementById("settings-theme")
    function readTheme() {
      try {
        return localStorage.getItem("xt_theme") || "dark"
      } catch {
        return "dark"
      }
    }
    function applyTheme(t) {
      if (t === "light") document.documentElement.style.colorScheme = "light"
      else if (t === "dark") document.documentElement.style.colorScheme = "dark"
      else document.documentElement.style.colorScheme = ""
      try {
        localStorage.setItem("xt_theme", t)
      } catch {}
      syncThemeButtons()
    }
    function syncThemeButtons() {
      const current = readTheme()
      for (const btn of themeGroup?.querySelectorAll(".theme-btn") || []) {
        btn.setAttribute("aria-pressed", String(btn.dataset.theme === current))
      }
    }
    themeGroup?.addEventListener("click", (e) => {
      const t = /** @type {HTMLElement} */ (e.target)
      const btn = t.closest(".theme-btn")
      if (!btn) return
      applyTheme(btn.dataset.theme || "system")
    })
    syncThemeButtons()

    // ---------------------------------------------------------------------
    // Live TV layout: default EPG visibility + channel column width.
    // ---------------------------------------------------------------------
    const epgDefaultGroup = document.getElementById("settings-epg-default")
    function readEpgDefault() {
      try {
        const v = localStorage.getItem("xt_epg_open_default")
        return v === null ? true : v === "true"
      } catch {
        return true
      }
    }
    function applyEpgDefault(on) {
      try {
        localStorage.setItem("xt_epg_open_default", String(on))
        // Reset the per-session override so the new default applies on the
        // next visit to /livetv.
        localStorage.removeItem("xt_epg_visible")
      } catch {}
      syncEpgDefaultButtons()
    }
    function syncEpgDefaultButtons() {
      const on = readEpgDefault()
      for (const btn of epgDefaultGroup?.querySelectorAll(".epg-default-btn") ||
        []) {
        const isOn = btn.dataset.epg === "on"
        btn.setAttribute("aria-pressed", String(isOn === on))
      }
    }
    epgDefaultGroup?.addEventListener("click", (e) => {
      const t = /** @type {HTMLElement} */ (e.target)
      const btn = t.closest(".epg-default-btn")
      if (!btn) return
      applyEpgDefault(btn.dataset.epg === "on")
    })
    syncEpgDefaultButtons()

    const channelWidthGroup = document.getElementById("settings-channel-width")
    const CHANNEL_WIDTH_DEFAULT = 28
    function readChannelWidth() {
      const raw = parseFloat(localStorage.getItem("xt_channels_w") || "")
      return Number.isFinite(raw) && raw >= 18 && raw <= 60
        ? raw
        : CHANNEL_WIDTH_DEFAULT
    }
    function applyChannelWidth(rem) {
      document.documentElement.style.setProperty("--xt-channels-w", `${rem}rem`)
      try {
        if (rem === CHANNEL_WIDTH_DEFAULT) localStorage.removeItem("xt_channels_w")
        else localStorage.setItem("xt_channels_w", String(rem))
      } catch {}
      syncChannelWidthButtons()
    }
    function syncChannelWidthButtons() {
      const current = readChannelWidth()
      for (const btn of channelWidthGroup?.querySelectorAll(".channel-width-btn") ||
        []) {
        const v = parseFloat(btn.dataset.width || "0")
        btn.setAttribute("aria-pressed", String(Math.abs(v - current) < 0.001))
      }
    }
    channelWidthGroup?.addEventListener("click", (e) => {
      const t = /** @type {HTMLElement} */ (e.target)
      const btn = t.closest(".channel-width-btn")
      if (!btn) return
      const v = parseFloat(btn.dataset.width || "0")
      if (!Number.isFinite(v) || v <= 0) return
      applyChannelWidth(v)
    })
    syncChannelWidthButtons()

    // ---------------------------------------------------------------------
    // Network / User-Agent
    // ---------------------------------------------------------------------
    const uaPresetEl = /** @type {HTMLSelectElement|null} */ (
      document.getElementById("ua-preset")
    )
    const uaCustomEl = /** @type {HTMLInputElement|null} */ (
      document.getElementById("ua-custom")
    )
    const uaSaveBtn = /** @type {HTMLButtonElement|null} */ (
      document.getElementById("ua-save")
    )
    const uaMsgEl = document.getElementById("ua-msg")

    if (uaPresetEl) {
      for (const p of UA_PRESETS) {
        const opt = document.createElement("option")
        opt.value = p.id
        opt.textContent = p.label
        uaPresetEl.appendChild(opt)
      }
      const opt = document.createElement("option")
      opt.value = "custom"
      opt.textContent = "Custom"
      uaPresetEl.appendChild(opt)

      const current = getUserAgent()
      const matchPreset = UA_PRESETS.find((p) => p.value === current)
      if (current && !matchPreset) {
        uaPresetEl.value = "custom"
        if (uaCustomEl) uaCustomEl.value = current
      } else {
        uaPresetEl.value = matchPreset ? matchPreset.id : "default"
        if (uaCustomEl) uaCustomEl.value = ""
      }
    }

    function readUaFromForm() {
      if (!uaPresetEl) return ""
      const custom = (uaCustomEl?.value || "").trim()
      if (custom) return custom
      if (uaPresetEl.value === "custom") return ""
      const preset = UA_PRESETS.find((p) => p.id === uaPresetEl.value)
      return preset ? preset.value : ""
    }

    uaSaveBtn?.addEventListener("click", () => {
      setUserAgent(readUaFromForm())
      flashMsg(
        uaMsgEl,
        isTauri
          ? "Saved. Reload pages to apply."
          : "Saved. Active in the desktop build only."
      )
      flashSuccess(uaSaveBtn)
    })

    // ---------------------------------------------------------------------
    // Downloads folder
    // ---------------------------------------------------------------------
    const dirInput = /** @type {HTMLInputElement|null} */ (
      document.getElementById("download-dir-input")
    )
    const dirPickBtn = /** @type {HTMLButtonElement|null} */ (
      document.getElementById("download-dir-pick")
    )
    const dirClearBtn = /** @type {HTMLButtonElement|null} */ (
      document.getElementById("download-dir-clear")
    )
    const downloadsAvailEl = document.getElementById("downloads-availability")

    const isAndroid = /Android/i.test(navigator.userAgent || "")

    function prettifyAndroidUri(stored) {
      if (!stored) return ""
      let raw = stored
      try {
        const parsed = JSON.parse(stored)
        if (parsed && typeof parsed.uri === "string") raw = parsed.uri
      } catch {}
      try {
        const u = decodeURIComponent(raw)
        const m = u.match(/document\/(?:tree\/)?([^/]+)$/) ||
                  u.match(/tree\/([^/]+)$/)
        if (m && m[1]) return m[1].replace(/^primary:/, "")
        return u
      } catch {
        return raw
      }
    }

    function syncDir() {
      if (!dirInput) return
      let v = getDownloadDir() || ""
      if (isAndroid && v === "[object Object]") {
        setDownloadDir("")
        v = ""
      }
      if (isAndroid) {
        dirInput.value = v
          ? prettifyAndroidUri(v)
          : "/Download/Extreme InfiniTV/ (default)"
      } else {
        dirInput.value = v
      }
      if (dirClearBtn) dirClearBtn.disabled = !v
    }
    syncDir()

    if (downloadsAvailEl) {
      downloadsAvailEl.textContent = isDownloadable() ? "" : "Desktop only"
    }
    if (!isDownloadable()) {
      if (dirPickBtn) dirPickBtn.disabled = true
      if (dirClearBtn) dirClearBtn.disabled = true
    }

    dirPickBtn?.addEventListener("click", async () => {
      if (!isDownloadable() || !dirPickBtn) return
      setLoading(dirPickBtn, true)
      try {
        if (isAndroid) {
          const { pickDirectory, serializeUri } = await import(
            "@/scripts/lib/android-fs.js"
          )
          const picked = await pickDirectory()
          if (picked) {
            setDownloadDir(serializeUri(picked))
            syncDir()
          }
        } else {
          const { open } = await import("@tauri-apps/plugin-dialog")
          const picked = await open({
            directory: true,
            title: "Choose download folder",
          })
          if (typeof picked === "string" && picked) {
            setDownloadDir(picked)
            syncDir()
          }
        }
      } catch (e) {
        console.error("Pick folder failed:", e)
      } finally {
        setLoading(dirPickBtn, false)
      }
    })

    dirClearBtn?.addEventListener("click", async () => {
      const prev = getDownloadDir()
      if (isAndroid && prev) {
        const { releasePickedDir, deserializeUri } = await import(
          "@/scripts/lib/android-fs.js"
        )
        const uri = deserializeUri(prev)
        if (uri) releasePickedDir(uri).catch(() => {})
      }
      setDownloadDir("")
      syncDir()
    })

    const concurrencyGroup = document.getElementById(
      "settings-download-concurrency"
    )
    function syncConcurrencyButtons() {
      if (!concurrencyGroup) return
      const current = getDownloadConcurrency()
      for (const btn of concurrencyGroup.querySelectorAll(".dl-concurrency-btn")) {
        const v = parseInt(btn.getAttribute("data-concurrency") || "1", 10)
        btn.setAttribute("aria-pressed", v === current ? "true" : "false")
      }
    }
    syncConcurrencyButtons()
    concurrencyGroup?.addEventListener("click", (e) => {
      const btn = /** @type {HTMLElement} */ (e.target).closest(
        ".dl-concurrency-btn"
      )
      if (!btn) return
      const v = parseInt(btn.getAttribute("data-concurrency") || "1", 10)
      setDownloadConcurrency(v)
      syncConcurrencyButtons()
    })

    const updateSectionEl = document.getElementById("update-section")
    const updatePillEl = document.getElementById("update-pill")
    const updateAvailEl = document.getElementById("update-availability")
    const updateCurrentEl = document.getElementById("update-current")
    const updateLatestEl = document.getElementById("update-latest")
    const updateNotesEl = document.getElementById("update-notes")
    const updateMsgEl = document.getElementById("update-msg")
    const updateGithubLink = /** @type {HTMLAnchorElement|null} */ (
      document.getElementById("update-github")
    )
    const updateCheckBtn = /** @type {HTMLButtonElement|null} */ (
      document.getElementById("update-check")
    )
    const updateInstallBtn = /** @type {HTMLButtonElement|null} */ (
      document.getElementById("update-install")
    )
    const updateInstallLabelEl = document.getElementById("update-install-label")
    const updateRelaunchBtn = /** @type {HTMLButtonElement|null} */ (
      document.getElementById("update-relaunch")
    )
    const updateProgressWrap = document.getElementById("update-progress-wrap")
    const updateProgressBar = document.getElementById("update-progress-bar")
    const updateProgressText = document.getElementById("update-progress-text")

    const GITHUB_RELEASES_URL =
      "https://github.com/infinitel8p/xtream/releases"

    function setUpdateState(state) {
      if (updateSectionEl) updateSectionEl.setAttribute("data-state", state)
      if (updatePillEl) {
        if (state === "available") {
          updatePillEl.classList.remove("hidden")
          updatePillEl.classList.add("inline-flex")
        } else {
          updatePillEl.classList.add("hidden")
          updatePillEl.classList.remove("inline-flex")
        }
      }
    }

    const isWindowsDesktop =
      isTauri && /Windows/i.test(navigator.userAgent || "")

    if (updateCurrentEl) {
      try {
        const { getVersion } = await import("@tauri-apps/api/app")
        updateCurrentEl.textContent = await getVersion()
      } catch {
        const tag = document.querySelector(
          'meta[name="x-app-version"]'
        )?.getAttribute("content")
        updateCurrentEl.textContent = tag || "-"
      }
    }

    if (!isTauri && updateAvailEl) {
      updateAvailEl.textContent = "Web build - auto-update is desktop-only."
      updateCheckBtn?.setAttribute("disabled", "")
      updateCheckBtn?.classList.add("opacity-50", "cursor-not-allowed")
    } else if (isTauri && !isWindowsDesktop && updateAvailEl) {
      updateAvailEl.textContent = "Updater is configured for Windows only."
      updateCheckBtn?.setAttribute("disabled", "")
      updateCheckBtn?.classList.add("opacity-50", "cursor-not-allowed")
    }

    let pendingUpdate = null

    function setProgress(pct, text) {
      if (!updateProgressWrap || !updateProgressBar || !updateProgressText) return
      if (pct == null) {
        updateProgressWrap.classList.add("hidden")
        updateProgressWrap.classList.remove("flex")
        return
      }
      updateProgressWrap.classList.remove("hidden")
      updateProgressWrap.classList.add("flex")
      const clamped = Math.max(0, Math.min(100, pct))
      updateProgressBar.style.width = `${clamped}%`
      updateProgressText.textContent = text || `${clamped.toFixed(0)}%`
    }

    function fmtUpdateBytes(n) {
      if (!n) return "0 B"
      if (n < 1024) return `${n} B`
      if (n < 1024 * 1024) return `${(n / 1024).toFixed(1)} KB`
      return `${(n / (1024 * 1024)).toFixed(1)} MB`
    }

    function setInstallLabel(text) {
      if (updateInstallLabelEl) updateInstallLabelEl.textContent = text
    }

    async function checkForUpdates() {
      if (!isWindowsDesktop) return
      if (updateMsgEl) updateMsgEl.textContent = "Checking…"
      setUpdateState("checking")
      updateCheckBtn?.setAttribute("disabled", "")
      updateInstallBtn?.setAttribute("hidden", "")
      updateRelaunchBtn?.setAttribute("hidden", "")
      setInstallLabel("Download & install")
      setProgress(null)
      try {
        const { check } = await import("@tauri-apps/plugin-updater")
        const update = await check()
        if (!update) {
          pendingUpdate = null
          if (updateLatestEl) updateLatestEl.textContent = "Up to date"
          if (updateMsgEl) updateMsgEl.textContent = "You're on the latest version."
          if (updateNotesEl) {
            updateNotesEl.textContent = ""
            updateNotesEl.classList.add("hidden")
          }
          if (updateGithubLink) {
            updateGithubLink.href = `${GITHUB_RELEASES_URL}/latest`
          }
          setUpdateState("up-to-date")
          return
        }
        pendingUpdate = update
        if (updateLatestEl) {
          updateLatestEl.textContent = update.version
            ? `v${update.version}`
            : "Available"
        }
        if (updateNotesEl && update.body) {
          updateNotesEl.textContent = update.body
          updateNotesEl.classList.remove("hidden")
        }
        if (updateMsgEl) {
          updateMsgEl.textContent = update.date
            ? `Released ${new Date(update.date).toLocaleDateString()}.`
            : "Update available."
        }
        if (updateGithubLink) {
          updateGithubLink.href = update.version
            ? `${GITHUB_RELEASES_URL}/tag/v${update.version}`
            : `${GITHUB_RELEASES_URL}/latest`
        }
        updateInstallBtn?.removeAttribute("hidden")
        setUpdateState("available")
      } catch (e) {
        console.error("Update check failed:", e)
        if (updateMsgEl) {
          updateMsgEl.textContent = `Check failed - ${String(e?.message || e)}`
        }
        setUpdateState("error")
      } finally {
        updateCheckBtn?.removeAttribute("disabled")
      }
    }

    async function installUpdate() {
      if (!pendingUpdate) return
      updateInstallBtn?.setAttribute("disabled", "")
      updateCheckBtn?.setAttribute("disabled", "")
      let total = 0
      let received = 0
      setProgress(0, "Preparing…")
      try {
        await pendingUpdate.downloadAndInstall((event) => {
          if (event.event === "Started") {
            total = event.data?.contentLength || 0
            setProgress(0, total ? `0 / ${fmtUpdateBytes(total)}` : "Starting…")
          } else if (event.event === "Progress") {
            received += event.data?.chunkLength || 0
            const pct = total ? (received / total) * 100 : 0
            setProgress(
              pct,
              total
                ? `${fmtUpdateBytes(received)} / ${fmtUpdateBytes(total)}`
                : fmtUpdateBytes(received)
            )
          } else if (event.event === "Finished") {
            setProgress(100, "Installed.")
          }
        })
        if (updateMsgEl) {
          updateMsgEl.textContent = "Update installed. Restart to apply."
        }
        setInstallLabel("Download & install")
        updateRelaunchBtn?.removeAttribute("hidden")
      } catch (e) {
        console.error("Update install failed:", e)
        if (updateMsgEl) {
          updateMsgEl.textContent =
            `Download failed - ${String(e?.message || e)}. ` +
            "Click Re-download to start over."
        }
        setProgress(null)
        setInstallLabel("Re-download")
        updateInstallBtn?.removeAttribute("disabled")
      } finally {
        updateCheckBtn?.removeAttribute("disabled")
      }
    }

    async function relaunchApp() {
      try {
        const { relaunch } = await import("@tauri-apps/plugin-process")
        await relaunch()
      } catch (e) {
        console.error("Relaunch failed:", e)
        if (updateMsgEl) {
          updateMsgEl.textContent = `Restart failed - ${String(e?.message || e)}`
        }
      }
    }

    updateCheckBtn?.addEventListener("click", checkForUpdates)
    updateInstallBtn?.addEventListener("click", installUpdate)
    updateRelaunchBtn?.addEventListener("click", relaunchApp)

    if (isWindowsDesktop) checkForUpdates()
  </script>
</Layout>
