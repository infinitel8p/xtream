---
import Sidebar from "@/components/Sidebar.astro"
import "../styles/global.css"

interface Props {
  pageTitle?: string
}
const { pageTitle } = Astro.props
const documentTitle = pageTitle
  ? `${pageTitle} | Extreme InfiniTV`
  : "Extreme InfiniTV"
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1,viewport-fit=cover"
    />
    <title>{documentTitle}</title>
    <meta name="theme-color" content="#f8fafc" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0e1628" media="(prefers-color-scheme: dark)" />
    <script is:inline>
      try {
        var s = parseFloat(localStorage.getItem("xt_font_scale") || "1");
        if (!isFinite(s) || s < 0.75 || s > 2) s = 1;
        document.documentElement.style.fontSize = (16 * s) + "px";
      } catch (e) {}
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />
  </head>

  <body
    class="antialiased bg-bg text-fg selection:bg-accent-soft min-h-screen
           flex flex-row pr-[env(safe-area-inset-right)]"
  >
    <Sidebar />
    <div class="flex-1 min-w-0 min-h-0 flex flex-col">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      scroll-behavior: auto !important;
    }
  }

  :is(a, button, input, summary, [tabindex]):focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  @media (min-width: 64rem) {
    :is(a, button, input, summary, [tabindex]):focus-visible {
      outline-width: 3px;
      outline-offset: 3px;
    }
  }
</style>

<script>
  import "@/scripts/spatial-navigation"
  const SpatialNavigation = window.SpatialNavigation

  console.log(
    "%c∞ Extreme InfiniTV",
    "color: oklch(0.78 0.15 330); font: italic 1.25rem/1 'Instrument Serif', serif"
  )

  window.addEventListener("load", function () {
    SpatialNavigation.init()

    SpatialNavigation.add({
      selector:
        "a, button, summary, input, textarea, [contenteditable='true'], select, [tabindex]:not([tabindex='-1'])",
    })

    SpatialNavigation.makeFocusable()

    SpatialNavigation.focus()
  })
</script>
