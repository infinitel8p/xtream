---
import Sidebar from "@/components/Sidebar.astro"
import CatalogWarmingIndicator from "@/components/CatalogWarmingIndicator.svelte"
import "../styles/global.css"

interface Props {
  pageTitle?: string
}
const { pageTitle } = Astro.props
const documentTitle = pageTitle
  ? `${pageTitle} | Extreme InfiniTV`
  : "Extreme InfiniTV"
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1,viewport-fit=cover"
    />
    <title>{documentTitle}</title>
    <meta name="theme-color" content="#f8fafc" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0e1628" media="(prefers-color-scheme: dark)" />
    <script is:inline>
      try {
        var fontScale = parseFloat(localStorage.getItem("xt_font_scale") || "1");
        if (!isFinite(fontScale) || fontScale < 0.75 || fontScale > 2) fontScale = 1;
        document.documentElement.style.setProperty("--xt-font-scale", String(fontScale));
        var cw = parseFloat(localStorage.getItem("xt_channels_w") || "");
        if (isFinite(cw) && cw >= 18 && cw <= 60) {
          document.documentElement.style.setProperty("--xt-channels-w", cw + "rem");
        }
        if (localStorage.getItem("xt_perf_mode") === "1") {
          document.documentElement.setAttribute("data-perf-mode", "on");
        }

        var KNOWN_LOCALES = ["en","es","de","fr","pt-BR","it","ru","zh","ja"];
        var storedLocale = localStorage.getItem("xt_locale") || "";
        if (storedLocale && KNOWN_LOCALES.indexOf(storedLocale) !== -1) {
          document.documentElement.setAttribute("lang", storedLocale);
        }

        // Translate [data-i18n*] elements before first paint
        if (storedLocale && storedLocale !== "en") {
          var rawMessages = localStorage.getItem("xt_locale_messages_v1");
          if (rawMessages) {
            var cached = JSON.parse(rawMessages);
            if (cached && cached.code === storedLocale && cached.messages) {
              var msgs = cached.messages;
              var translateEl = function (el) {
                if (!el || el.nodeType !== 1) return;
                var textKey = el.getAttribute("data-i18n");
                if (textKey && msgs[textKey] != null) el.textContent = msgs[textKey];
                var htmlKey = el.getAttribute("data-i18n-html");
                if (htmlKey && msgs[htmlKey] != null) el.innerHTML = msgs[htmlKey];
                var attrSpec = el.getAttribute("data-i18n-attr");
                if (attrSpec) {
                  var pairs = attrSpec.split(";");
                  for (var pi = 0; pi < pairs.length; pi++) {
                    var parts = pairs[pi].split(":");
                    var attrName = (parts[0] || "").trim();
                    var attrKey = (parts[1] || "").trim();
                    if (attrName && attrKey && msgs[attrKey] != null) {
                      el.setAttribute(attrName, msgs[attrKey]);
                    }
                  }
                }
              };
              var i18nObserver = new MutationObserver(function (mutations) {
                for (var mi = 0; mi < mutations.length; mi++) {
                  var added = mutations[mi].addedNodes;
                  for (var ai = 0; ai < added.length; ai++) {
                    var node = added[ai];
                    if (node.nodeType !== 1) continue;
                    if (
                      node.hasAttribute("data-i18n") ||
                      node.hasAttribute("data-i18n-html") ||
                      node.hasAttribute("data-i18n-attr")
                    ) {
                      translateEl(node);
                    }
                    var matches = node.querySelectorAll
                      ? node.querySelectorAll("[data-i18n], [data-i18n-html], [data-i18n-attr]")
                      : null;
                    if (matches) {
                      for (var qi = 0; qi < matches.length; qi++) translateEl(matches[qi]);
                    }
                  }
                }
              });
              i18nObserver.observe(document.documentElement, { childList: true, subtree: true });
              document.addEventListener("DOMContentLoaded", function () {
                i18nObserver.disconnect();
              });
            }
          }
        }

        var currentTheme = localStorage.getItem("xt_theme") || "dark";
        if (currentTheme === "light") document.documentElement.style.colorScheme = "light";
        else if (currentTheme === "dark") document.documentElement.style.colorScheme = "dark";

        function applyAndroidStatusBar(theme) {
          try {
            if (!window.AndroidStatusBar) return;
            var isLight;
            if (theme === "light") isLight = true;
            else if (theme === "dark") isLight = false;
            else isLight = !window.matchMedia("(prefers-color-scheme: dark)").matches;
            window.AndroidStatusBar.setAppearance(isLight);
          } catch (e) {}
        }
        applyAndroidStatusBar(currentTheme);
        var systemThemeMql = window.matchMedia("(prefers-color-scheme: dark)");
        if (systemThemeMql.addEventListener) {
          systemThemeMql.addEventListener("change", function () {
            var t = localStorage.getItem("xt_theme") || "dark";
            if (t !== "light" && t !== "dark") applyAndroidStatusBar(t);
          });
        }
        window.__applyAndroidStatusBar = applyAndroidStatusBar;
      } catch (e) {}
    </script>
  </head>

  <body
    class="antialiased bg-bg text-fg selection:bg-accent-soft
           h-dvh min-h-0 overflow-hidden
           flex flex-col md:flex-row landscape-phone:flex-row
           pt-[env(safe-area-inset-top)]
           pr-[env(safe-area-inset-right)]"
  >
    <Sidebar />
    <div class="flex-1 min-w-0 min-h-0 flex flex-col order-first md:order-0
                overflow-x-clip overflow-y-auto">
      <slot />
    </div>
    <CatalogWarmingIndicator client:load />
  </body>
</html>

<style is:global>
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      scroll-behavior: auto !important;
    }
  }

  :is(a, button, input, summary, [tabindex]):focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 0;
  }
</style>

<script>
  import "@/scripts/spatial-navigation"
  import { initFocusGlide } from "@/scripts/lib/focus-glide.js"
  import { initKeyboardHelp } from "@/scripts/lib/keyboard-help.js"
  import { initI18n } from "@/scripts/lib/i18n.js"
  initI18n()
  const SpatialNavigation = window.SpatialNavigation

  console.log(
    "%c∞ Extreme InfiniTV%c\nCurious? Source: https://github.com/infinitel8p/Extreme-InfiniTV",
    "color: oklch(0.78 0.15 330); font: italic 1.25rem/1 'Instrument Serif', serif",
    "color: oklch(0.6 0.011 250); font: 0.75rem/1.4 ui-sans-serif, system-ui;"
  )

  const onLogin = () =>
    location.pathname === "/login" || location.pathname.startsWith("/login/")
  if (!onLogin()) {
    import("@/scripts/expiration.js").then((m) => m.injectExpirationDate?.())
  }
  document.addEventListener("xt:active-changed", () => {
    if (onLogin()) return
    import("@/scripts/expiration.js").then((m) => m.injectExpirationDate?.())
  })

  document.addEventListener("keydown", (ev) => {
    if (!(ev.metaKey || ev.ctrlKey) || ev.key.toLowerCase() !== "k") return
    ev.preventDefault()
    if (location.pathname === "/search" || location.pathname.startsWith("/search/")) {
      const input = document.querySelector(
        'main input[type="search"]'
      )
      if (input) {
        input.focus()
        input.select?.()
      }
      return
    }
    location.href = "/search"
  })

  initFocusGlide()
  initKeyboardHelp()

  // -----------------------------------------------------------------------
  // Discord idle presence: push "Browsing the catalog" on every page load
  // -----------------------------------------------------------------------
  function pageArea() {
    const pathname = location.pathname || "/"
    if (pathname === "/" || pathname === "") return "the hub"
    if (pathname.startsWith("/livetv")) return "Live TV"
    if (pathname.startsWith("/movies")) return "Movies"
    if (pathname.startsWith("/series")) return "Series"
    if (pathname.startsWith("/epg")) return "the EPG grid"
    if (pathname.startsWith("/search")) return "Search"
    if (pathname.startsWith("/favorites")) return "Favorites"
    if (pathname.startsWith("/recently-added")) return "Recently Added"
    if (pathname.startsWith("/downloads")) return "Downloads"
    if (pathname.startsWith("/settings")) return "Settings"
    return "the catalog"
  }

  async function pushIdlePresence() {
    if (onLogin()) return
    try {
      const [{ setIdleRichPresence }, { getActiveEntry }] = await Promise.all([
        import("@/scripts/lib/discord-rpc.js"),
        import("@/scripts/lib/creds.js"),
      ])
      const active = await getActiveEntry()
      setIdleRichPresence({
        playlistId: active?._id || "",
        playlistTitle: active?.title || "",
        area: pageArea(),
      }).catch(() => {})
    } catch {}
  }
  pushIdlePresence()
  document.addEventListener("xt:active-changed", pushIdlePresence)

  window.addEventListener("load", function () {
    SpatialNavigation.init()

    SpatialNavigation.add({
      id: "main",
      selector:
        "a, button, summary, input, textarea, [contenteditable='true'], select, [tabindex]:not([tabindex='-1'])",
    })

    SpatialNavigation.makeFocusable()

    const ARROWS = new Set([
      "ArrowUp",
      "ArrowDown",
      "ArrowLeft",
      "ArrowRight",
    ])
    const onFirstArrow = (e) => {
      if (!ARROWS.has(e.key)) return
      const active = document.activeElement
      if (!active || active === document.body) {
        e.preventDefault()
        SpatialNavigation.focus()
      }
      document.removeEventListener("keydown", onFirstArrow, true)
    }
    document.addEventListener("keydown", onFirstArrow, true)
  })
</script>
